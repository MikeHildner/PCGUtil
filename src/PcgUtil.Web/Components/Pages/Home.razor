    // ----- Start page: bank-occupancy map ("Where your sounds live") -----

    sealed record BankMapRow(int Bank, string Label, string? Tag, int Total, int Used);

    // One row per bank the file carries. "Used" counts slots that aren't empty/Init —
    // the complement of the free slots Add-sounds can land in.
    List<BankMapRow> CombiBankMapRows()
    {
        var rows = new List<BankMapRow>();
        if (_catalog is null) return rows;
        foreach (var b in PresentBanks(_catalog.CombiBanks))
        {
            var bank = _catalog.CombiBanks[b];
            rows.Add(new BankMapRow(b, PcgBankLabels.Combi(b), null,
                bank.Count, bank.Count - PcgDeepCopy.FreeCombiSlots(bank).Count));
        }
        return rows;
    }

    List<BankMapRow> ProgramBankMapRows()
    {
        var rows = new List<BankMapRow>();
        if (_catalog is null) return rows;
        foreach (var b in PresentBanks(_catalog.ProgramBanks))
        {
            var bank = _catalog.ProgramBanks[b];
            rows.Add(new BankMapRow(b, PcgBankLabels.Program(b),
                _catalog.ProgramBankTypes[b] is { } t ? PcgBankIdentity.TypeLabel(t) : null,
                bank.Count, bank.Count - PcgDeepCopy.FreeProgramSlots(bank).Count));
        }
        return rows;
    }

    // Bank-level jumps from the map; reset what the bank pickers reset so the tab opens clean.
    void OpenCombiBank(int bank)
    {
        if (_catalog is null || bank < 0 || bank >= _catalog.CombiBanks.Count
            || _catalog.CombiBanks[bank].Count == 0) return;
        _view = View.Combis;
        _selectedCombiBank = bank;
        _combiFilter = string.Empty;
        _timbreCombi = null;
        _timbreDetail = null;
    }

    void OpenProgramBank(int bank)
    {
        if (_catalog is null || bank < 0 || bank >= _catalog.ProgramBanks.Count
            || _catalog.ProgramBanks[bank].Count == 0) return;
        _view = View.Programs;
        _selectedProgramBank = bank;
        _programFilter = string.Empty;
    }

    private RenderFragment BankMapColumn(string heading, IReadOnlyList<BankMapRow> rows, Action<int> open) => __builder =>
    {
        <h3 class="h6 mb-2">@heading</h3>
        @foreach (var row in rows)
        {
            <button type="button" class="bank-map-row" @key="row.Bank"
                    title="Open @row.Label in @heading" @onclick="() => open(row.Bank)">
                <span class="bank-map-label small text-nowrap">
                    @row.Label
                    @if (row.Tag is not null)
                    {
                        <span class="text-body-secondary"> · @row.Tag</span>
                    }
                </span>
                <span class="bank-map-track" aria-hidden="true">
                    @if (row.Used > 0)
                    {
                        <span class="bank-map-fill" style="width:@(Pct(row.Used * 100.0 / row.Total))%"></span>
                    }
                </span>
                <span class="bank-map-count small text-body-secondary text-nowrap">@row.Used of @row.Total in use</span>
            </button>
        }
    };

    static string TabLabel(View v) => v switch
    {
        View.Home => "Start",
        View.AddSounds => "Add sounds",
        View.Overview => "File info",
        View.SetLists => "Set Lists",
        View.Combis => "Combis",
        View.Programs => "Programs",
        View.Copy => "Copy",
        View.Differences => "Differences",
        View.Usage => "Usage",
        View.Duplicates => "Duplicates",
        View.Search => "Search",
        View.Strings => "Strings",
        View.Tree => "Chunk tree",
        _ => v.ToString(),
    };

    string SelectedChunkName => _selectedChunk?.Id ?? "pcg";

    async Task ExportStringsCsv()
    {
        var sb = new StringBuilder();
        sb.Append("offset,text\n");
        foreach (var s in FilteredStrings)
            sb.Append("0x").Append(s.Offset.ToString("X")).Append(",\"")
              .Append(s.Value.Replace("\"", "\"\"")).Append("\"\n");
        await Download($"{SelectedChunkName}-strings.csv", "text/csv", sb.ToString());
    }

    async Task ExportStringsJson()
    {
        var items = FilteredStrings
            .Select(s => new { offset = s.Offset, hex = "0x" + s.Offset.ToString("X"), text = s.Value });
        var json = System.Text.Json.JsonSerializer.Serialize(
            items, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await Download($"{SelectedChunkName}-strings.json", "application/json", json);
    }

    async Task ExportUsageCsv()
    {
        var usage = CurrentUsage;
        var sb = new StringBuilder();
        sb.Append("program_bank,program_number,program_name,ref_count,used_by_kind,used_by_detail\n");
        foreach (var p in usage.Programs)
            foreach (var site in p.Sites)
                sb.Append(PcgBankLabels.Program(p.BankIndex)).Append(',')
                  .Append(p.Number).Append(",\"")
                  .Append(Csv(p.Name)).Append("\",")
                  .Append(p.ReferenceCount).Append(',')
                  .Append(site.Kind).Append(",\"")
                  .Append(Csv(site.Description)).Append("\"\n");
        await Download("program-usage.csv", "text/csv", sb.ToString());
    }

    async Task ExportCurrentSetListHtml()
    {
        if (_catalog is null) return;
        var sl = _setLists[_selectedSetList];
        await Download($"setlist-{sl.Index:D3}.html", "text/html", PcgHtmlReport.SetList(sl, _catalog));
    }

    async Task ExportAllSetListsHtml()
    {
        if (_catalog is null) return;
        await Download("setlists.html", "text/html", PcgHtmlReport.AllSetLists(_setLists, _catalog));
    }

    async Task ExportUsageHtml() =>
        await Download("program-usage.html", "text/html", PcgHtmlReport.Usage(CurrentUsage));

    void OnSetListChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < _setLists.Count)
        {
            _selectedSetList = idx;
            _descSlot = null;
            _colorSlot = null;
            _repointSlot = null;
            _slotDetailSlot = null;  // panel is keyed by slot index; another list's slot would inherit it
            _slotDetailCombi = null;
        }
    }

    async Task ExportCurrentSetListCsv()
    {
        var sl = _setLists[_selectedSetList];
        var sb = new StringBuilder();
        sb.Append("slot,slot_name,kind,bank,number,loads,description\n");
        AppendSlotRows(sb, sl, includeSetListColumns: false);
        await Download($"setlist-{sl.Index:D3}.csv", "text/csv", sb.ToString());
    }

    async Task ExportAllSetListsCsv()
    {
        var sb = new StringBuilder();
        sb.Append("set_list,set_list_name,slot,slot_name,kind,bank,number,loads,description\n");
        foreach (var sl in _setLists)
            AppendSlotRows(sb, sl, includeSetListColumns: true);
        await Download("setlists.csv", "text/csv", sb.ToString());
    }

    void AppendSlotRows(StringBuilder sb, SetList sl, bool includeSetListColumns)
    {
        foreach (var slot in sl.Slots)
        {
            if (slot.IsEmpty && !_showEmptySlots) continue;
            if (includeSetListColumns)
                sb.Append(sl.Index).Append(",\"").Append(Csv(sl.Name)).Append("\",");
            var target = _catalog?.Resolve(slot.Reference) ?? string.Empty;
            sb.Append(slot.Index).Append(",\"").Append(Csv(slot.Name)).Append("\",")
              .Append(slot.Reference.Kind).Append(',')
              .Append(slot.Reference.Bank).Append(',')
              .Append(slot.Reference.Index).Append(",\"").Append(Csv(target)).Append("\",\"")
              .Append(Csv(slot.Description)).Append("\"\n");
        }
    }

    static string Csv(string value) => value.Replace("\"", "\"\"");

    // ----- Editing operations (each produces a new byte image via PcgEditor) -----

    void MoveSlot(int slot, int delta)
    {
        if (_pcg is null) return;
        int target = slot + delta;
        if (target < 0 || target >= _setLists[_selectedSetList].Slots.Count) return;
        ApplyEdit(PcgEditor.SwapSetListSlots(_pcg, _selectedSetList, slot, target));
    }

    void RenameSlot(int slot, string? name)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.RenameSetListSlot(_pcg, _selectedSetList, slot, name ?? string.Empty));
    }

    void RenameCurrentSetList(string? name)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.RenameSetList(_pcg, _selectedSetList, name ?? string.Empty));
    }

    void StartCopy(SetListSlot slot)
    {
        _copySource = (_selectedSetList, slot.Index);
        _copySourceName = slot.IsEmpty ? $"slot {slot.Index:D3}" : slot.Name;
    }

    void ToggleDescEditor(int slot)
    {
        _repointSlot = null;
        _colorSlot = null;
        _descSlot = _descSlot == slot ? null : slot;
    }

    void SetSlotDescription(int slot, string? text)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.SetSetListSlotDescription(_pcg, _selectedSetList, slot, text ?? string.Empty));
    }

    void ToggleColorEditor(int slot)
    {
        _descSlot = null;
        _repointSlot = null;
        _colorSlot = _colorSlot == slot ? null : slot;
    }

    void SetSlotColor(int slot, int color)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.SetSetListSlotColor(_pcg, _selectedSetList, slot, color));
    }

    void ToggleRepoint(SetListSlot slot)
    {
        _descSlot = null;
        _colorSlot = null;
        if (_repointSlot == slot.Index)
        {
            _repointSlot = null;
            return;
        }
        _repointSlot = slot.Index;
        var r = slot.Reference;
        if (r.Kind == PcgItemKind.Program)
        {
            _repointKind = PcgItemKind.Program;
            _repointBank = _catalog is null
                ? 0
                : SnapToPresent(PcgCatalog.ProgramBankIndexForPcgId(r.Bank), _catalog.ProgramBanks);
            _repointIndex = r.Index;
        }
        else
        {
            _repointKind = PcgItemKind.Combi;
            _repointBank = r.Kind == PcgItemKind.Combi && _catalog is not null
                ? SnapToPresent(r.Bank, _catalog.CombiBanks)
                : 0;
            _repointIndex = r.Kind == PcgItemKind.Combi ? r.Index : 0;
        }
    }

    void SetRepointKind(PcgItemKind kind)
    {
        _repointKind = kind;
        _repointBank = _catalog is null
            ? 0
            : SnapToPresent(0, kind == PcgItemKind.Program ? _catalog.ProgramBanks : _catalog.CombiBanks);
        _repointIndex = 0;
    }

    void OnRepointBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            _repointBank = idx;
            _repointIndex = 0;
        }
    }

    void OnRepointIndexChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
            _repointIndex = idx;
    }

    void ApplyRepoint()
    {
        if (_pcg is null || _repointSlot is null) return;
        ApplyEdit(PcgEditor.RepointSetListSlot(_pcg, _selectedSetList, _repointSlot.Value, _repointKind, _repointBank, _repointIndex));
        _repointSlot = null;
    }

    void PasteInto(int slot)
    {
        if (_pcg is null || _copySource is null) return;
        var src = _copySource.Value;
        ApplyEdit(PcgEditor.CopySetListSlot(_pcg, src.SetList, src.Slot, _selectedSetList, slot));
    }

    async Task DownloadEditedPcg()
    {
        if (_pcg is null) return;
        var baseName = string.IsNullOrEmpty(_fileName)
            ? "edited"
            : System.IO.Path.GetFileNameWithoutExtension(_fileName);
        // Time-stamped so repeated saves stop colliding as "(1) (2)" in Downloads.
        await SaveBytes($"{baseName}-edited-{DateTime.Now:HHmm}.PCG", _pcg.Data);
    }

    async Task SaveBytes(string fileName, byte[] bytes)
    {
        using var stream = new MemoryStream(bytes);
        using var streamRef = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("pcgSaveFile", fileName, streamRef);
    }

    // ----- Combi reorganization -----

    void OnCombiBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && _catalog is not null
            && idx >= 0 && idx < _catalog.CombiBanks.Count)
        {
            _selectedCombiBank = idx;
            _combiFilter = string.Empty;
            _timbreCombi = null;
            _timbreDetail = null;
        }
    }

    // ----- Combi timbre inspector -----

    int? _timbreCombi;
    Combi? _timbreDetail;

    void ToggleTimbres(int index)
    {
        if (_timbreCombi == index)
        {
            _timbreCombi = null;
            _timbreDetail = null;
            return;
        }
        _timbreCombi = index;
        _timbreDetail = FindCombi(_selectedCombiBank, index);
    }

    Combi? FindCombi(int bank, int index) => _pcg is null ? null
        : CombiReader.Read(_pcg).FirstOrDefault(c => c.Bank == bank && c.Index == index);

    // Companion .KGE: user KARMA GE names (USER-A..L), attached from the file header.
    IReadOnlyList<IReadOnlyList<string>>? _kgeBanks;
    string? _kgeFileName;

    string? UserGeDisplayName(int geId) =>
        _kgeBanks is null ? null : KgeReader.UserGeName(_kgeBanks, geId);

    async Task LoadKge(InputFileChangeEventArgs e)
    {
        _error = null;
        try
        {
            using var ms = new MemoryStream();
            await using (var stream = e.File.OpenReadStream(MaxFileSize))
            {
                await stream.CopyToAsync(ms);
            }
            var banks = KgeReader.Read(ms.ToArray());
            if (banks is null)
            {
                _error = $"'{e.File.Name}' doesn't look like a KARMA GE (.KGE) file.";
                return;
            }
            _kgeBanks = banks;
            _kgeFileName = e.File.Name;
        }
        catch (Exception ex)
        {
            _error = $"Could not read '{e.File.Name}': {ex.Message}";
        }
    }

    // Program metadata (category/favorite/engine), decoded once per file in LoadDerived.
    Dictionary<(int Bank, int Index), ProgramInfo> _programInfos = new();

    ProgramInfo? ProgramInfoAt(int bank, int index) =>
        _programInfos.GetValueOrDefault((bank, index));

    // ----- Cross-view jumps: Start card, search results, set-list slot links -----

    string? _pendingReveal;   // row element id to scroll to and flash after the next render
    bool _focusSearch;        // focus the Search query box after the next render
    ElementReference _searchInput;

    void OpenSearch()
    {
        _view = View.Search;
        _focusSearch = true;
    }

    void OpenCombi(int bank, int index)
    {
        if (_catalog is null || bank < 0 || bank >= _catalog.CombiBanks.Count
            || _catalog.CombiBanks[bank].Count == 0) return;
        _view = View.Combis;
        _selectedCombiBank = bank;
        _combiFilter = string.Empty;  // a direct bank assignment bypasses OnCombiBankChanged's clearing
        _timbreCombi = index;
        _timbreDetail = FindCombi(bank, index);
        _pendingReveal = $"combi-row-{index}";
    }

    void OpenProgram(int bank, int index)  // bank is a catalog list index, not a hardware PcgId
    {
        if (_catalog is null || bank < 0 || bank >= _catalog.ProgramBanks.Count
            || _catalog.ProgramBanks[bank].Count == 0) return;
        _view = View.Programs;
        _selectedProgramBank = bank;
        _programFilter = string.Empty;
        _pendingReveal = $"program-row-{index}";
    }

    void OpenSetListSlot(int setListIndex, int slotIndex)
    {
        var pos = _setLists.FindIndex(s => s.Index == setListIndex);
        if (pos < 0) return;
        _view = View.SetLists;
        _selectedSetList = pos;
        _descSlot = null;
        _colorSlot = null;
        _repointSlot = null;
        _slotDetailSlot = null;
        _slotDetailCombi = null;
        var slot = _setLists[pos].Slots.FirstOrDefault(s => s.Index == slotIndex);
        if (slot is { IsEmpty: false } && slot.Reference.Kind == PcgItemKind.Combi)
            ShowSlotDetail(slot);  // answer "what does this song load?" right away
        _pendingReveal = $"slot-row-{slotIndex}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingReveal is { } revealId)
        {
            _pendingReveal = null;
            await JS.InvokeVoidAsync("pcgRevealRow", revealId);
        }
        if (_focusSearch)
        {
            _focusSearch = false;
            await _searchInput.FocusAsync();
        }
    }

    // ----- Set-list slots: the combi a song loads, inline -----

    int? _slotDetailSlot;
    Combi? _slotDetailCombi;

    void ShowSlotDetail(SetListSlot slot)
    {
        if (slot.Reference.Kind != PcgItemKind.Combi) return;
        _slotDetailCombi = FindCombi(slot.Reference.Bank, slot.Reference.Index);
        _slotDetailSlot = _slotDetailCombi is null ? null : slot.Index;
    }

    void OnSlotRowClick(SetListSlot slot)
    {
        if (_editMode || slot.IsEmpty || _catalog?.Resolve(slot.Reference) is null) return;
        if (slot.Reference.Kind == PcgItemKind.Combi)
        {
            if (_slotDetailSlot == slot.Index)
            {
                _slotDetailSlot = null;
                _slotDetailCombi = null;
            }
            else
            {
                ShowSlotDetail(slot);
            }
        }
        else if (slot.Reference.Kind == PcgItemKind.Program)
        {
            OpenProgram(PcgCatalog.ProgramBankIndexForPcgId(slot.Reference.Bank), slot.Reference.Index);
        }
        // Song slots live in the sequencer — nothing to show here.
    }

    void OnSlotRowKeyDown(KeyboardEventArgs e, SetListSlot slot)
    {
        if (e.Key == "Enter") OnSlotRowClick(slot);
    }

    // Search-result actions; null = nothing to jump to (drum kits and wave seqs have no view).
    Action? HitAction(SearchHit h) => h.Kind switch
    {
        SearchHitKind.Combi => () => OpenCombi(h.Bank, h.Index),
        SearchHitKind.Program => () => OpenProgram(h.Bank, h.Index),
        SearchHitKind.SetListSlot => () => OpenSetListSlot(h.Bank, h.Index),
        _ => null,
    };

    void OnHitRowKeyDown(KeyboardEventArgs e, Action? open)
    {
        if (e.Key == "Enter") open?.Invoke();
    }

    // "What's inside this combi": category/tempo header, a key-zone map of the splits and
    // layers, and the timbre table — programs resolved against the given catalog (the main
    // file's or the Copy tab's read-only source).
    private RenderFragment TimbreTable(Combi combi, PcgCatalog? catalog) => __builder =>
    {
        var activeTimbres = combi.Timbres.Where(t => t.Status != TimbreStatus.Off).ToList();
        <div class="small text-body-secondary mb-1">
            @(catalog?.CombiCategoryName(combi.Category) ?? CombiCategories.Name(combi.Category))@(combi.Tempo > 0 ? $" · {combi.Tempo:0.##} BPM" : "")@(combi.Favorite ? " · ★ favorite" : "")
            · @activeTimbres.Count of @CombiReader.TimbresPerCombi timbres active
        </div>
        @if (activeTimbres.Count == 0)
        {
            <span class="text-body-secondary small">No active timbres.</span>
            return;
        }

        <div class="mb-2" style="max-width:44rem">
            @foreach (var t in activeTimbres)
            {
                var left = Pct(t.BottomKey * 100.0 / 128);
                var width = Pct((t.TopKey - t.BottomKey + 1) * 100.0 / 128);
                var label = $"{PcgNotes.Name(t.BottomKey)}–{PcgNotes.Name(t.TopKey)}"
                    + (t.HasVelocityZone ? $" · vel {t.BottomVelocity}–{t.TopVelocity}" : "");
                <div class="d-flex align-items-center zone-bar-row">
                    <div class="small text-body-secondary text-end pe-2 flex-shrink-0" style="width:2.6rem">T@(t.Index + 1)</div>
                    <div class="position-relative flex-grow-1 zone-bar-lane">
                        <div class="position-absolute top-0 bottom-0 rounded @(t.Mute ? "opacity-25" : null)"
                             style="left:@(left)%; width:@(width)%; background:var(--pcg-zone-fill); border:1px solid var(--pcg-zone-border);"></div>
                        @if (t.BottomKey > 96)
                        {
                            <span class="position-absolute small text-nowrap @(t.Mute ? "text-body-tertiary" : null)"
                                  style="right:0; line-height:1.15rem;">@label@(t.Mute ? " · muted" : "")</span>
                        }
                        else
                        {
                            <span class="position-absolute small text-nowrap @(t.Mute ? "text-body-tertiary" : null)"
                                  style="left:@(left)%; padding-left:.3rem; line-height:1.15rem;">@label@(t.Mute ? " · muted" : "")</span>
                        }
                    </div>
                </div>
            }
            <div class="d-flex" style="height:1rem">
                <div class="flex-shrink-0" style="width:2.6rem"></div>
                <div class="position-relative flex-grow-1 border-top">
                    <span class="position-absolute small text-body-tertiary" style="left:0">C-1</span>
                    <span class="position-absolute small text-body-tertiary" style="left:28.1%">C2</span>
                    <span class="position-absolute small text-body-tertiary" style="left:46.9%">C4</span>
                    <span class="position-absolute small text-body-tertiary" style="left:65.6%">C6</span>
                    <span class="position-absolute small text-body-tertiary" style="right:0">G9</span>
                </div>
            </div>
        </div>

        @* The one rigid block in this panel; on narrow screens it scrolls inside
           its own box instead of widening the page. width:0 + min-width:100% keeps
           the wrapper out of the host table cell's min-content negotiation. *@
        <div class="table-scroll">
        <table class="table table-sm mb-1" style="max-width:52rem">
            <thead>
                <tr>
                    <th style="width:3.5rem">T#</th><th style="width:5rem">Status</th><th>Program</th>
                    <th style="width:6.5rem">Keys</th><th style="width:5.5rem">Vel</th>
                    <th style="width:3.5rem" class="d-none d-md-table-cell">Ch</th><th style="width:3.5rem" class="d-none d-md-table-cell">Vol</th><th style="width:4rem" class="d-none d-md-table-cell">Xpose</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in activeTimbres)
                {
                    <tr class="@(t.Mute ? "opacity-50" : null)">
                        <td>T@(t.Index + 1)</td>
                        <td>@t.Status@(t.Mute ? " 🔇" : "")</td>
                        <td>
                            @PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(t.ProgramBankPcgId)) #@t.ProgramNumber.ToString("D3")
                            @{ var timbreProgram = catalog?.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber); }
                            @if (timbreProgram is not null)
                            {
                                <span> — @timbreProgram</span>
                            }
                        </td>
                        <td class="@(t.HasKeyZone ? null : "text-body-tertiary")">@PcgNotes.Name(t.BottomKey)–@PcgNotes.Name(t.TopKey)</td>
                        <td class="@(t.HasVelocityZone ? null : "text-body-tertiary")">@t.BottomVelocity–@t.TopVelocity</td>
                        <td class="d-none d-md-table-cell">@(t.MidiChannel == 16 ? "Gch" : (t.MidiChannel + 1).ToString())</td>
                        <td class="d-none d-md-table-cell">@t.Volume</td>
                        <td class="d-none d-md-table-cell @(t.Transpose == 0 ? "text-body-tertiary" : null)">@(t.Transpose == 0 ? "—" : t.Transpose.ToString("+0;-0"))</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        var effects = combi.ActiveEffects.ToList();
        var karmaOn = combi.KarmaModules.Where(m => m.IsOn).ToList();
        <div class="d-flex flex-wrap align-items-baseline gap-1 mb-1" style="max-width:52rem">
            <span class="small text-body-secondary me-1">Effects:</span>
            @if (effects.Count == 0)
            {
                <span class="small text-body-tertiary">none</span>
            }
            @foreach (var e in effects)
            {
                <span class="badge text-bg-light fw-normal @(e.IsOn ? null : "opacity-50")"
                      title="@(e.IsOn ? "This effect is on" : "This effect is switched off")">
                    @e.Label · @e.TypeId.ToString("D3") @e.TypeName@(e.IsOn ? "" : " (off)")
                </span>
            }
        </div>
        @if (karmaOn.Count > 0)
        {
            <div class="d-flex flex-wrap align-items-baseline gap-1 mb-1" style="max-width:52rem">
                <span class="small text-body-secondary me-1">KARMA:</span>
                @foreach (var m in karmaOn)
                {
                    var geName = UserGeDisplayName(m.GeId);
                    <span class="badge text-bg-light fw-normal" title="KARMA module @m.Label">
                        @m.Label · @m.GeLabel@(geName is not null ? $" — {geName}" : "")
                    </span>
                }
                @if (combi.UsesUserKarmaGes)
                {
                    <span class="small text-body-secondary">— user GEs travel in the matching .KGE file</span>
                }
            </div>
        }
    };

    // "Song → combi → programs" flow for the set-list slot panel: the sounds this song
    // actually drives, grouped by referenced program with the timbre numbers riding along.
    private RenderFragment SongFlow(string songName, Combi combi, PcgCatalog? catalog) => __builder =>
    {
        const int maxGroups = 8;
        var groups = combi.Timbres
            .Where(t => t.UsesInternalProgram)
            .GroupBy(t => (t.ProgramBankPcgId, t.ProgramNumber))
            .Select(g => (
                BankPcgId: g.Key.ProgramBankPcgId,
                Number: g.Key.ProgramNumber,
                Timbres: g.Select(t => t.Index + 1).OrderBy(n => n).ToList(),
                AllMuted: g.All(t => t.Mute)))
            .OrderBy(g => g.Timbres[0])
            .ToList();

        <div class="song-flow small mb-2" aria-label="What this song loads">
            <span class="song-flow-chip song-flow-song" title="Set-list slot">@DisplayName(songName)</span>
            <span class="song-flow-link" aria-hidden="true"></span>
            <span class="song-flow-chip song-flow-combi" title="The combi this slot loads">
                @DisplayName(combi.Name)
                <span class="text-body-secondary">@PcgBankLabels.Combi(combi.Bank) #@combi.Index.ToString("D3")</span>
            </span>
            <span class="song-flow-link" aria-hidden="true"></span>
            @if (groups.Count == 0)
            {
                <span class="song-flow-none text-body-secondary">no internal programs</span>
            }
            else
            {
                <ul class="song-flow-programs">
                    @foreach (var g in groups.Take(maxGroups))
                    {
                        var programName = catalog?.ResolveProgram(g.BankPcgId, g.Number);
                        <li class="song-flow-chip song-flow-program @(g.AllMuted ? "opacity-50" : null)">
                            <span class="song-flow-t">@TimbreRunLabel(g.Timbres)</span>
                            @PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(g.BankPcgId)) #@g.Number.ToString("D3")
                            @if (programName is not null)
                            {
                                <span> — @programName</span>
                            }
                            @if (g.AllMuted)
                            {
                                <span class="text-body-secondary"> · muted</span>
                            }
                        </li>
                    }
                    @if (groups.Count > maxGroups)
                    {
                        <li class="song-flow-more text-body-secondary">+@(groups.Count - maxGroups) more</li>
                    }
                </ul>
            }
        </div>
    };

    // Compresses sorted timbre numbers into runs: [1] → "T1"; [5..16] → "T5–T16"; [1,3,4] → "T1·T3–T4".
    static string TimbreRunLabel(IReadOnlyList<int> sorted)
    {
        var parts = new List<string>();
        for (int i = 0; i < sorted.Count;)
        {
            int start = i;
            while (i + 1 < sorted.Count && sorted[i + 1] == sorted[i] + 1) i++;
            parts.Add(start == i ? $"T{sorted[start]}" : $"T{sorted[start]}–T{sorted[i]}");
            i++;
        }
        return string.Join("·", parts);
    }

    // CSS percentages must use invariant formatting regardless of server culture.
    static string Pct(double value) =>
        value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

