    static int CountNonEmpty(IReadOnlyList<string> names)
    {
        var count = 0;
        foreach (var name in names)
            if (!string.IsNullOrEmpty(name))
                count++;
        return count;
    }

    // Canonical bank indices the file actually carries. Partial files (vendor packs) leave
    // absent banks as empty placeholders in the catalog; those aren't offered in pickers.
    static IEnumerable<int> PresentBanks(IReadOnlyList<IReadOnlyList<string>> banks)
    {
        for (var i = 0; i < banks.Count; i++)
            if (banks[i].Count > 0)
                yield return i;
    }

    // "EXi, " / "HD-1, " prefix for program-bank labels; empty when the type is unknown.
    static string ProgramTypeTag(PcgCatalog? catalog, int bank) =>
        catalog is not null && bank >= 0 && bank < catalog.ProgramBankTypes.Count
            && catalog.ProgramBankTypes[bank] is { } t
            ? $"{PcgBankIdentity.TypeLabel(t)}, "
            : "";

    // Keeps a bank selection on a bank the file carries, preferring the desired index.
    static int SnapToPresent(int desired, IReadOnlyList<IReadOnlyList<string>> banks)
    {
        if (desired >= 0 && desired < banks.Count && banks[desired].Count > 0)
            return desired;
        foreach (var i in PresentBanks(banks))
            return i;
        return 0;
    }

    // True when a patch row matches the Find box: empty query, a name substring, or a number match.
    static bool MatchesFilter(string? name, int index, string query)
    {
        if (string.IsNullOrWhiteSpace(query)) return true;
        query = query.Trim();
        if (!string.IsNullOrEmpty(name) && name.Contains(query, StringComparison.OrdinalIgnoreCase))
            return true;
        return index.ToString("D3").Contains(query) || index.ToString().Contains(query);
    }

    void ClearUsageFilters()
    {
        _usageFilter = string.Empty;
        _usageBankFilter = -1;
        _usageSort = UsageSort.BankNumber;
    }

    static string SlotBankLabel(SetListReference r) => r.Kind switch
    {
        PcgItemKind.Combi => PcgBankLabels.Combi(r.Bank),
        PcgItemKind.Program => PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(r.Bank)),
        _ => "—",
    };

    static string MemberList(DuplicateGroup g, bool isProgram)
    {
        const int max = 12;
        var labels = g.Members.Take(max).Select(m =>
            $"{(isProgram ? PcgBankLabels.Program(m.Bank) : PcgBankLabels.Combi(m.Bank))} #{m.Index:D3}");
        var text = string.Join(", ", labels);
        return g.Count > max ? $"{text} … +{g.Count - max} more" : text;
    }

    static string HitKindLabel(SearchHitKind k) => k switch
    {
        SearchHitKind.Program => "Program",
        SearchHitKind.Combi => "Combi",
        SearchHitKind.SetListSlot => "Set List",
        SearchHitKind.DrumKit => "Drum kit",
        SearchHitKind.WaveSequence => "Wave seq",
        _ => k.ToString(),
    };

    // Named (non-init) items across a section's banks, for the File info browse lists.
    static List<(int Bank, int Index, string Name)> NamedBankItems(IReadOnlyList<IReadOnlyList<string>> banks)
    {
        var items = new List<(int, int, string)>();
        for (int b = 0; b < banks.Count; b++)
            for (int i = 0; i < banks[b].Count; i++)
                if (!string.IsNullOrEmpty(banks[b][i]) &&
                    !banks[b][i].StartsWith("Init ", StringComparison.OrdinalIgnoreCase))
                    items.Add((b, i, banks[b][i]));
        return items;
    }

    async Task Download(string fileName, string mime, string content) =>
        await JS.InvokeVoidAsync("pcgDownload", fileName, mime, content);
