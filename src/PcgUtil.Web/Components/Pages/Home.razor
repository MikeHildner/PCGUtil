    async Task ExportCombiContentsHtml()
    {
        if (_pcg is null || _catalog is null) return;
        var label = PcgBankLabels.Combi(_selectedCombiBank);
        var combis = CombiReader.Read(_pcg).Where(c => c.Bank == _selectedCombiBank && !c.IsEmptyOrInit).ToList();
        await Download($"combi-{label}-contents.html", "text/html", PcgHtmlReport.CombiContents(label, combis, _catalog));
    }

    async Task ExportCombiContentsCsv()
    {
        if (_pcg is null || _catalog is null) return;
        var label = PcgBankLabels.Combi(_selectedCombiBank);
        var sb = new StringBuilder();
        sb.Append("combi_bank,combi_number,combi_name,timbre,status,program,program_name\n");
        foreach (var combi in CombiReader.Read(_pcg).Where(c => c.Bank == _selectedCombiBank && !c.IsEmptyOrInit))
            foreach (var t in combi.Timbres.Where(t => t.Status != TimbreStatus.Off))
            {
                var programLabel = PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(t.ProgramBankPcgId));
                sb.Append(label).Append(',').Append(combi.Index).Append(",\"").Append(Csv(combi.Name)).Append("\",")
                  .Append(t.Index + 1).Append(',').Append(t.Status).Append(',')
                  .Append(programLabel).Append(" #").Append(t.ProgramNumber.ToString("D3")).Append(",\"")
                  .Append(Csv(_catalog.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? string.Empty)).Append("\"\n");
            }
        await Download($"combi-{label}-contents.csv", "text/csv", sb.ToString());
    }

