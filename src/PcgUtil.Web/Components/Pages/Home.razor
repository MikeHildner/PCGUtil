@page "/"
@rendermode InteractiveServer
@using System.Text
@using PcgUtil.Core
@inject IJSRuntime JS
@inject ILogger<Home> Logger

<PageTitle>PCG Util</PageTitle>

@if (_pcg is null)
{
    <div class="hero mx-auto text-center">
        <h1 class="d-flex align-items-center justify-content-center gap-2 mb-3">
            <svg width="34" height="24" viewBox="0 0 20 14" fill="none" aria-hidden="true"><polyline points="1,7 5.5,7 8.5,2.5 11.5,11.5 14.5,7 19,7" fill="none" stroke="var(--pcg-wave)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
            PCG Util
        </h1>
        <p class="text-body-secondary mb-4">
            Open the backup file from your instrument to see and organize what's inside.
        </p>
        <label class="btn btn-primary btn-lg upload-btn">
            Open a .PCG file
            <InputFile OnChange="OnFileSelected" accept=".PCG,.pcg" class="visually-hidden" />
        </label>
        @if (_loading)
        {
            <div class="mt-3 text-body-secondary">
                <span class="spinner-border spinner-border-sm" role="status"></span>
                Reading and parsing @_fileName …
            </div>
        }
        @if (_error is not null)
        {
            <div class="alert alert-danger text-start mt-3 mb-0">@_error</div>
        }
        <p class="small text-body-secondary mt-3 mb-0">
            Files are read in memory — nothing is saved on the server.
        </p>
    </div>
}

@if (_pcg is not null)
{
    <div class="file-header d-flex align-items-center gap-2 flex-wrap">
        <span class="fw-semibold text-truncate" style="max-width:20rem" title="@_fileName">@_fileName</span>
        <span class="small text-body-secondary">@Format.Bytes(_pcg.Length)</span>
        @if (_dirty)
        {
            <span class="badge text-bg-warning" title="Edits are held in memory until you download the new file">unsaved edits</span>
            <button type="button" class="btn btn-sm btn-success" @onclick="DownloadEditedPcg">Download edited .PCG</button>
        }
        @if (_loading)
        {
            <span class="small text-body-secondary">
                <span class="spinner-border spinner-border-sm" role="status"></span> Reading @_fileName …
            </span>
        }
        @if (_error is not null)
        {
            <span class="small text-danger">@_error</span>
        }
        @if (_kgeFileName is not null)
        {
            <span class="badge text-bg-light fw-normal" title="KARMA user GE names loaded from @_kgeFileName">GE names ✓</span>
        }
        <span class="ms-auto"></span>
        <label class="btn btn-sm btn-outline-secondary mb-0" title="Open another backup, or this backup's companion .KGE to name its KARMA GEs">
            Open another file
            <InputFile OnChange="OnFileSelected" accept=".PCG,.pcg,.KGE,.kge" class="d-none" />
        </label>
    </div>

    <ul class="nav nav-tabs mb-3">
        @foreach (var tab in Enum.GetValues<View>().Where(t => !AdvancedViews.Contains(t) && !HiddenViews.Contains(t)))
        {
            <li class="nav-item">
                <button type="button" class="nav-link @(_view == tab ? "active" : null)"
                        @onclick="() => _view = tab">
                    @TabLabel(tab)
                </button>
            </li>
        }
        @{ var advancedOpen = _showAdvanced || AdvancedViews.Contains(_view); }
        <li class="nav-item">
            <button type="button" class="nav-link text-body-secondary"
                    title="Copying between files, differences, usage, duplicates — plus file internals"
                    @onclick="() => _showAdvanced = !advancedOpen">
                @(advancedOpen ? "More ▾" : "More ▸")
            </button>
        </li>
        @if (advancedOpen)
        {
            @foreach (var tab in AdvancedViews)
            {
                <li class="nav-item">
                    <button type="button" class="nav-link @(_view == tab ? "active" : null)"
                            @onclick="() => _view = tab">
                        @TabLabel(tab)
                    </button>
                </li>
            }
        }
    </ul>

    @switch (_view)
    {
        case View.Home:
        {
            @if (_catalog is not null)
            {
                var combiCount = NamedBankItems(_catalog.CombiBanks).Count;
                var programCount = NamedBankItems(_catalog.ProgramBanks).Count;
                var listsInUse = _setLists.Count(s => s.NamedSlots.Any());
                var mainList = _selectedSetList >= 0 && _selectedSetList < _setLists.Count ? _setLists[_selectedSetList] : null;
                var songCount = mainList?.NamedSlots.Count() ?? 0;

                <h2 class="h4 mb-3">Here's what's in @_fileName</h2>
                <div class="row g-3 mb-4" style="max-width:52rem">
                    @if (songCount > 0)
                    {
                        <div class="col-6 col-xl-3">
                            <div class="stat-tile border rounded p-3 h-100">
                                <div class="stat-value">@songCount</div>
                                <div class="small text-body-secondary text-truncate" title="@mainList!.DisplayName">
                                    song@(songCount == 1 ? "" : "s") in @mainList.DisplayName
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-6 col-xl-3">
                        <div class="stat-tile border rounded p-3 h-100">
                            <div class="stat-value">@listsInUse</div>
                            <div class="small text-body-secondary">set list@(listsInUse == 1 ? "" : "s") in use</div>
                        </div>
                    </div>
                    <div class="col-6 col-xl-3">
                        <div class="stat-tile border rounded p-3 h-100">
                            <div class="stat-value">@combiCount</div>
                            <div class="small text-body-secondary">combi@(combiCount == 1 ? "" : "s")</div>
                        </div>
                    </div>
                    <div class="col-6 col-xl-3">
                        <div class="stat-tile border rounded p-3 h-100">
                            <div class="stat-value">@programCount</div>
                            <div class="small text-body-secondary">program@(programCount == 1 ? "" : "s")</div>
                        </div>
                    </div>
                </div>
                @if (_catalog.Global is { } g && (g.MasterTune != 0 || g.KeyTranspose != 0))
                {
                    <div class="alert alert-warning py-2 px-3 small mb-4" style="max-width:52rem">
                        Heads up: this backup's global tuning isn't standard —
                        @if (g.MasterTune != 0)
                        {
                            <strong>master tune @g.MasterTune.ToString("+0;-0")¢</strong>
                        }
                        @if (g.MasterTune != 0 && g.KeyTranspose != 0)
                        {
                            <text>, </text>
                        }
                        @if (g.KeyTranspose != 0)
                        {
                            <strong>transpose @g.KeyTranspose.ToString("+0;-0") semitone@(Math.Abs(g.KeyTranspose) == 1 ? "" : "s")</strong>
                        }
                        <text> — every sound plays shifted until you reset it on the instrument.</text>
                    </div>
                }
            }

            <h2 class="h4 mb-1">What would you like to do?</h2>
            <p class="text-body-secondary small">
                Your backup stays untouched — every change lands in a new file you download.
            </p>
            @TaskCardGrid(PrimaryTaskCards(), "row-cols-1 row-cols-md-3")

            <button type="button" class="btn btn-link btn-sm text-body-secondary text-decoration-none px-0 mb-2"
                    @onclick="() => _showMoreCards = !_showMoreCards">
                @(_showMoreCards ? "More you can do ▾" : "More you can do ▸")
            </button>
            @if (_showMoreCards)
            {
                @TaskCardGrid(MoreTaskCards(), "row-cols-1 row-cols-md-2 row-cols-xl-4")
            }

            @if (_catalog is not null)
            {
                var combiMapRows = CombiBankMapRows();
                var programMapRows = ProgramBankMapRows();
                @if (combiMapRows.Count > 0 || programMapRows.Count > 0)
                {
                    <h2 class="h4 mb-1 mt-4">Where your sounds live</h2>
                    <p class="text-body-secondary small mb-2">
                        Each bar is one bank on the instrument — tap a row to open that bank.
                        Free slots are where added sounds can land.
                    </p>
                    <div class="row g-4 mb-3" style="max-width:52rem">
                        @if (combiMapRows.Count > 0)
                        {
                            <div class="col-md-6">@BankMapColumn("Combis", combiMapRows, OpenCombiBank)</div>
                        }
                        @if (programMapRows.Count > 0)
                        {
                            <div class="col-md-6">@BankMapColumn("Programs", programMapRows, OpenProgramBank)</div>
                        }
                    </div>
                }
            }
            break;
        }

        case View.AddSounds:
        {
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-1">
                <h2 class="h4 mb-0">Add sounds from another file</h2>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _view = View.Home">← Start</button>
            </div>
            <div class="wizard-steps small text-body-secondary mb-3">
                <span class="@(_addStep == AddStep.Source ? "wizard-step-active" : null)">1 · Choose file</span>
                <span class="@(_addStep == AddStep.Pick ? "wizard-step-active" : null)">2 · Pick the song</span>
                <span class="@(_addStep == AddStep.Review ? "wizard-step-active" : null)">3 · Review</span>
                <span class="@(_addStep == AddStep.Done ? "wizard-step-active" : null)">4 · Done</span>
            </div>

            @switch (_addStep)
            {
                case AddStep.Source:
                {
                    @if (_srcPcg is not null)
                    {
                        <div class="card mb-3" style="max-width:36rem">
                            <div class="card-body">
                                <div class="fw-semibold">@_srcFileName</div>
                                <div class="small text-body-secondary mb-2">
                                    @Format.Bytes(_srcPcg.Length) — read-only; this file is never changed.
                                </div>
                                <button type="button" class="btn btn-sm btn-primary" @onclick="() => _addStep = AddStep.Pick">Use this file</button>
                            </div>
                        </div>
                        <label class="form-label small">Or choose a different file</label>
                    }
                    else
                    {
                        <p class="text-body-secondary" style="max-width:44rem">
                            Open the file that has the sounds you want — a purchased pack or another backup.
                            It's only read, never changed.
                        </p>
                    }
                    <div style="max-width:36rem">
                        <InputFile OnChange="OnAddSourceSelected" accept=".PCG,.pcg" class="form-control form-control-sm" />
                        @if (_srcLoading)
                        {
                            <div class="mt-2 text-body-secondary small">
                                <span class="spinner-border spinner-border-sm" role="status"></span> Reading the file …
                            </div>
                        }
                        @if (_srcError is not null)
                        {
                            <div class="alert alert-danger mt-2 mb-0 small">@_srcError</div>
                        }
                    </div>
                    break;
                }

                case AddStep.Pick:
                {
                    var songs = SrcCombis
                        .Where(c => !c.IsEmptyOrInit)
                        .Where(c => string.IsNullOrWhiteSpace(_addFilter)
                            || c.Name.Contains(_addFilter.Trim(), StringComparison.OrdinalIgnoreCase))
                        .ToList();
                    <div class="d-flex align-items-end gap-3 flex-wrap mb-2">
                        <div>
                            <label class="form-label small mb-1">Find</label>
                            <input type="text" class="form-control form-control-sm" placeholder="song name…"
                                   @bind="_addFilter" @bind:event="oninput" />
                        </div>
                        <div class="small text-body-secondary pb-1">@songs.Count song(s) in @_srcFileName</div>
                    </div>
                    <table class="table table-sm table-hover align-middle" style="max-width:56rem">
                        <thead>
                            <tr>
                                <th>Song</th>
                                <th style="width:9rem" class="d-none d-sm-table-cell">Where</th>
                                <th style="width:13rem" class="d-none d-md-table-cell">Info</th>
                                <th style="width:11rem"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in songs.Take(MaxRows))
                            {
                                <tr @key="@($"add-{c.Bank}-{c.Index}")">
                                    <td>@c.Name</td>
                                    <td class="small text-body-secondary d-none d-sm-table-cell">@PcgBankLabels.Combi(c.Bank) #@c.Index.ToString("D3")</td>
                                    <td class="small text-body-secondary d-none d-md-table-cell">
                                        @(_srcCatalog?.CombiCategoryName(c.Category) ?? CombiCategories.Name(c.Category))@(c.Tempo > 0 ? $" · {c.Tempo:0.##} BPM" : "")
                                    </td>
                                    <td class="text-nowrap">
                                        <button type="button"
                                                class="btn btn-sm @(_addTimbreOpen == (c.Bank, c.Index) ? "btn-secondary" : "btn-outline-secondary") px-2 me-1"
                                                title="What's inside this song" @onclick="() => ToggleAddTimbres(c)">Timbres</button>
                                        <button type="button" class="btn btn-sm btn-primary px-2" @onclick="() => ChooseAddSong(c)">Choose</button>
                                    </td>
                                </tr>
                                @if (_addTimbreOpen == (c.Bank, c.Index) && _addTimbreDetail is not null)
                                {
                                    <tr @key="@($"add-timbres-{c.Bank}-{c.Index}")">
                                        <td></td>
                                        <td colspan="3">@TimbreTable(_addTimbreDetail, _srcCatalog)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    break;
                }

                case AddStep.Review:
                {
                    if (_addSelection is not { } sel || _srcPcg is null || _catalog is null)
                    {
                        <p class="text-body-secondary">Pick a song first.</p>
                        break;
                    }
                    var plan = CurrentAddPlan();
                    var occupant = _addDstBank < _catalog.CombiBanks.Count && _addDstIndex < _catalog.CombiBanks[_addDstBank].Count
                        ? _catalog.CombiBanks[_addDstBank][_addDstIndex] : "";
                    var destFree = Combi.IsEmptyOrInitName(occupant);
                    <div style="max-width:46rem">
                        <p class="mb-2">
                            <strong>@sel.Name</strong> will be added as a new combi at
                            <strong>@PcgBankLabels.Combi(_addDstBank) #@_addDstIndex.ToString("D3")</strong>@(destFree ? " (an empty slot)." : ".")
                            @if (!destFree)
                            {
                                <span class="text-danger"> This will overwrite '@occupant'.</span>
                            }
                        </p>
                        @if (plan is not null)
                        {
                            @foreach (var g in plan.Copies.GroupBy(m => m.DestinationBank).Where(g => g.Key >= 0))
                            {
                                <p class="mb-1">
                                    <strong>@g.Count() sound(s)</strong> travel with it into empty slots of
                                    <strong>@PcgBankLabels.Program(g.Key)</strong> (@(ProgramTypeTag(_catalog, g.Key).TrimEnd(',', ' ')) bank).
                                </p>
                            }
                            @if (plan.Reused.Any())
                            {
                                <p class="mb-1"><strong>@plan.Reused.Count() sound(s)</strong> are already in this file and will be shared.</p>
                            }
                            @if (plan.Skips.Count > 0)
                            {
                                <details class="small mb-2">
                                    <summary class="text-body-secondary">@plan.Skips.Count timbre(s) left as they are</summary>
                                    <ul class="mb-0">
                                        @foreach (var s in plan.Skips)
                                        {
                                            <li>T@(s.Timbre + 1): @DeepSkipText(s)</li>
                                        }
                                    </ul>
                                </details>
                            }
                            <details class="small mb-2">
                                <summary class="text-body-secondary">Exactly what will be copied</summary>
                                <ul class="mb-0">
                                    @foreach (var m in plan.Copies)
                                    {
                                        <li>@m.Name — @PcgBankLabels.Program(m.SourceBank) #@m.SourceIndex.ToString("D3")
                                            → @(m.DestinationIndex >= 0 ? $"{PcgBankLabels.Program(m.DestinationBank)} #{m.DestinationIndex:D3}" : "(no free slot)")</li>
                                    }
                                    @foreach (var m in plan.Reused)
                                    {
                                        <li>@m.Name — shares @PcgBankLabels.Program(m.DestinationBank) #@m.DestinationIndex.ToString("D3")</li>
                                    }
                                </ul>
                            </details>
                            @if (plan.UsesUserKarmaGes)
                            {
                                var geLabels = SrcCombis.FirstOrDefault(c => c.Bank == sel.Bank && c.Index == sel.Index)?.KarmaGeIds
                                    .Where(id => id >= Combi.KarmaUserGeBase).Distinct().Select(Combi.KarmaGeLabel) ?? Enumerable.Empty<string>();
                                <div class="alert alert-info py-2 px-3 small mb-2">
                                    This song drives KARMA with user GE(s) @string.Join(", ", geLabels).
                                    Load the pack's <code>.KGE</code> file on the instrument too, or KARMA will play differently.
                                </div>
                            }
                            @if (plan.Error is not null)
                            {
                                <div class="alert alert-warning py-2 px-3 small mb-2">@plan.Error</div>
                            }
                        }
                        @if (_addError is not null)
                        {
                            <div class="alert alert-warning py-2 px-3 small mb-2">@_addError</div>
                        }
                        <details class="mb-3">
                            <summary class="text-body-secondary small">Adjust locations</summary>
                            <div class="d-flex align-items-end gap-2 flex-wrap mt-2">
                                <div>
                                    <label class="form-label small mb-1">Combi bank</label>
                                    <select class="form-select form-select-sm" @onchange="OnAddDstBankChanged">
                                        @foreach (var i in PresentBanks(_catalog.CombiBanks))
                                        {
                                            <option value="@i" selected="@(i == _addDstBank)">@PcgBankLabels.Combi(i)</option>
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small mb-1">Slot <span class="text-body-secondary">(current occupant shown)</span></label>
                                    <select class="form-select form-select-sm" style="max-width:20rem" @onchange="OnAddDstIndexChanged">
                                        @for (var i = 0; i < _catalog.CombiBanks[_addDstBank].Count; i++)
                                        {
                                            var nm = _catalog.CombiBanks[_addDstBank][i];
                                            <option value="@i" selected="@(i == _addDstIndex)">@i.ToString("D3") — @(string.IsNullOrEmpty(nm) ? "(empty)" : nm)</option>
                                        }
                                    </select>
                                </div>
                                @if (plan is not null)
                                {
                                    @foreach (var bankType in new[] { ProgramBankType.Exi, ProgramBankType.Hd1 })
                                    {
                                        if (!plan.Needs(bankType))
                                            continue;
                                        var typeLabel = PcgBankIdentity.TypeLabel(bankType);
                                        var selectedBank = bankType == ProgramBankType.Hd1 ? _crossDeepHd1Bank : _crossDeepExiBank;
                                        <div>
                                            <label class="form-label small mb-1">@typeLabel sounds go to</label>
                                            <select class="form-select form-select-sm" @onchange="e => OnCrossDeepBankChanged(bankType, e)">
                                                @foreach (var i in PresentBanks(_catalog.ProgramBanks))
                                                {
                                                    if (_catalog.ProgramBankTypes[i] != bankType)
                                                        continue;
                                                    <option value="@i" selected="@(i == selectedBank)">
                                                        @PcgBankLabels.Program(i) (@typeLabel, @PcgDeepCopy.FreeProgramSlots(_catalog.ProgramBanks[i]).Count free)
                                                    </option>
                                                }
                                            </select>
                                        </div>
                                    }
                                }
                            </div>
                        </details>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => _addStep = AddStep.Pick">← Back</button>
                            <button type="button" class="btn btn-primary" disabled="@(plan is null || !plan.CanApply)" @onclick="ApplyAddSong">
                                Add it — combi to @PcgBankLabels.Combi(_addDstBank) #@_addDstIndex.ToString("D3") + @(plan?.Copies.Count() ?? 0) sound(s)
                            </button>
                        </div>
                    </div>
                    break;
                }

                case AddStep.Done:
                {
                    <div style="max-width:46rem">
                        <div class="alert alert-success">@_addLastResult</div>
                        <div class="d-flex gap-2 flex-wrap mb-3">
                            <button type="button" class="btn btn-success" @onclick="DownloadEditedPcg">Download edited .PCG</button>
                            <button type="button" class="btn btn-outline-primary" @onclick="AddAnotherSong">Add another song</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => _view = View.SetLists">Put it in a set list</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => _view = View.Home">Back to Start</button>
                        </div>
                        <p class="small text-body-secondary">
                            On the instrument: load the downloaded file with <strong>.PCG Contents: All</strong>.
                            Your added song and its sounds land in the banks shown in the review step.
                        </p>
                    </div>
                    break;
                }
            }
            break;
        }

        case View.Overview:
        {
            var sections = TopLevelSections().ToList();
            var totalBytes = sections.Sum(s => (long)s.Size);
            @if (totalBytes > 0)
            {
                <h2 class="h5 mb-1">The file at a glance</h2>
                <p class="text-body-secondary small mb-2">
                    Every byte of @_fileName, left to right — one segment per top-level section.
                </p>
                <div class="anatomy-strip mb-2" role="img" aria-label="Relative sizes of this file's top-level sections">
                    @foreach (var s in sections)
                    {
                        <div class="anatomy-seg"
                             style="flex-grow:@Pct(s.Size * 100.0 / totalBytes); background:@SectionColor(s.Id)"
                             title="@s.Id · @PcgChunkInfo.Describe(s.Id) — @Format.Bytes(s.Size)"></div>
                    }
                </div>
                <div class="d-flex flex-wrap column-gap-3 row-gap-1 small mb-4">
                    @foreach (var s in sections)
                    {
                        <span class="text-nowrap">
                            <span class="anatomy-dot" style="background:@SectionColor(s.Id)" aria-hidden="true"></span>
                            @PcgChunkInfo.Describe(s.Id)
                            <span class="text-body-secondary">@Format.Bytes(s.Size)</span>
                        </span>
                    }
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">File</div>
                        <div class="fw-semibold text-truncate" title="@_fileName">@_fileName</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">Size</div>
                        <div class="fw-semibold">@Format.Bytes(_pcg.Length)</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">Signature</div>
                        <div class="fw-semibold">@_pcg.Magic</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">Total chunks</div>
                        <div class="fw-semibold">@_pcg.EnumerateChunks().Count()</div>
                    </div>
                </div>
                @if (_catalog?.Global is { } g)
                {
                    <div class="col-6 col-lg-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-body-secondary small">Master tune</div>
                            <div class="fw-semibold">@(g.MasterTune == 0 ? "standard (A440)" : $"{g.MasterTune:+0;-0}¢")</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-body-secondary small">Global transpose</div>
                            <div class="fw-semibold">@(g.KeyTranspose == 0 ? "none" : $"{g.KeyTranspose:+0;-0} semitone{(Math.Abs(g.KeyTranspose) == 1 ? "" : "s")}")</div>
                        </div>
                    </div>
                }
            </div>

            <h2 class="h5">Top-level sections</h2>
            <table class="table table-sm table-striped align-middle">
                <thead>
                    <tr><th>Chunk</th><th>Contents</th><th class="text-end">Size</th><th class="text-end">Banks</th></tr>
                </thead>
                <tbody>
                    @foreach (var section in TopLevelSections())
                    {
                        <tr>
                            <td><code>@section.Id</code></td>
                            <td>@PcgChunkInfo.Describe(section.Id)</td>
                            <td class="text-end">@Format.Bytes(section.Size)</td>
                            <td class="text-end">@(section.HasChildren ? section.Children.Count.ToString() : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (_catalog is not null)
            {
                var drumKits = NamedBankItems(_catalog.DrumKitBanks);
                var waveSeqs = NamedBankItems(_catalog.WaveSequenceBanks);
                @if (drumKits.Count > 0)
                {
                    <details class="mb-2">
                        <summary class="h6 d-inline">Drum kits (@drumKits.Count)</summary>
                        <ul class="small mt-1">
                            @foreach (var d in drumKits.Take(MaxRows))
                            {
                                <li>@PcgBankLabels.DrumKit(d.Bank) #@d.Index.ToString("D3") — @d.Name</li>
                            }
                        </ul>
                    </details>
                }
                @if (waveSeqs.Count > 0)
                {
                    <details class="mb-2">
                        <summary class="h6 d-inline">Wave sequences (@waveSeqs.Count)</summary>
                        <ul class="small mt-1">
                            @foreach (var w in waveSeqs.Take(MaxRows))
                            {
                                <li>@PcgBankLabels.WaveSequence(w.Bank) #@w.Index.ToString("D3") — @w.Name</li>
                            }
                        </ul>
                        @if (waveSeqs.Count > MaxRows)
                        {
                            <p class="text-body-secondary small">… showing first @MaxRows of @waveSeqs.Count.</p>
                        }
                    </details>
                }
            }
            break;
        }

        case View.SetLists:
        {
            if (_setLists.Count == 0)
            {
                <p class="text-body-secondary">This file doesn't contain any set lists.</p>
            }
            else
            {
                var sl = _setLists[_selectedSetList];
                var slots = (_editMode || _showEmptySlots ? sl.Slots : sl.NamedSlots).ToList();

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-7">
                        <label class="form-label small mb-1">Set List</label>
                        <select class="form-select form-select-sm" @onchange="OnSetListChanged">
                            @for (var i = 0; i < _setLists.Count; i++)
                            {
                                var item = _setLists[i];
                                var songs = item.NamedSlots.Count();
                                <option value="@i" selected="@(i == _selectedSetList)">
                                    @i.ToString("D3") — @item.DisplayName (@songs song@(songs == 1 ? "" : "s"))
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-5 d-flex gap-3 align-items-center pt-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="editMode" @bind="_editMode" />
                            <label class="form-check-label small" for="editMode">Edit mode</label>
                        </div>
                        @if (!_editMode)
                        {
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="showEmpty" @bind="_showEmptySlots" />
                                <label class="form-check-label small" for="showEmpty">Show empty slots</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    @if (_editMode)
                    {
                        <input class="form-control form-control-sm fw-semibold" style="max-width:22rem" maxlength="24"
                               value="@sl.Name" placeholder="(set list name)"
                               @onchange="@(e => RenameCurrentSetList(e.Value?.ToString()))" />
                    }
                    else
                    {
                        <h2 class="h5 mb-0">@sl.DisplayName</h2>
                    }
                    <div class="d-flex gap-2">
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportCurrentSetListCsv">CSV: this</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportAllSetListsCsv">CSV: all</button>
                        </div>
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportCurrentSetListHtml">Print: this</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportAllSetListsHtml">Print: all</button>
                        </div>
                    </div>
                </div>

                @if (_copySource is not null)
                {
                    <div class="alert alert-info d-flex justify-content-between align-items-center py-1 px-2 small">
                        <span>Copying <strong>@_copySourceName</strong> — click <em>Paste</em> on a target slot.</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _copySource = null">Cancel</button>
                    </div>
                }

                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:4rem">Slot</th>
                            <th>Name</th>
                            <th>Loads</th>
                            @if (_editMode)
                            {
                                <th style="width:20rem">Edit</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in slots)
                        {
                            var target = _catalog?.Resolve(slot.Reference);
                            var canShowCombi = !_editMode && !slot.IsEmpty && slot.Reference.Kind == PcgItemKind.Combi && target is not null;
                            var canJumpProgram = !_editMode && !slot.IsEmpty && slot.Reference.Kind == PcgItemKind.Program && target is not null;
                            var clickable = canShowCombi || canJumpProgram;
                            <tr @key="slot.Index" id="slot-row-@slot.Index"
                                class="@(slot.IsEmpty ? "text-body-secondary" : null) @(clickable ? "row-clickable" : null)"
                                role="@(clickable ? "button" : null)" tabindex="@(clickable ? "0" : null)"
                                aria-expanded="@(canShowCombi ? (_slotDetailSlot == slot.Index ? "true" : "false") : null)"
                                title="@(canShowCombi ? "Show the combi this song loads" : canJumpProgram ? "Show this program in the Programs tab" : null)"
                                @onclick="() => OnSlotRowClick(slot)"
                                @onkeydown="e => OnSlotRowKeyDown(e, slot)">
                                <td class="text-nowrap">
                                    @if (!slot.IsEmpty)
                                    {
                                        <span class="slot-color" style="background:@SetListSlotColors.Css(slot.Color)"
                                              title="@SetListSlotColors.Name(slot.Color)" aria-hidden="true"></span>
                                    }
                                    @slot.Index.ToString("D3")
                                </td>
                                <td>
                                    @if (_editMode)
                                    {
                                        <input class="form-control form-control-sm" maxlength="24" placeholder="(empty)"
                                               value="@slot.Name" @onchange="@(e => RenameSlot(slot.Index, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        @(slot.IsEmpty ? "—" : slot.Name)
                                        @if (!string.IsNullOrEmpty(slot.Description))
                                        {
                                            <div class="small text-body-secondary" style="white-space:pre-line">@slot.Description</div>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (!slot.IsEmpty || _editMode)
                                    {
                                        <span class="badge text-bg-light">@slot.Reference.Kind</span>
                                        <span class="text-body-secondary small">@SlotBankLabel(slot.Reference) · #@slot.Reference.Index.ToString("D3")</span>
                                        @if (target is not null)
                                        {
                                            <span> — @target</span>
                                        }
                                        @if (canShowCombi)
                                        {
                                            <span class="small ms-1" aria-hidden="true">@(_slotDetailSlot == slot.Index ? "▾" : "▸")</span>
                                        }
                                        else if (canJumpProgram)
                                        {
                                            <span class="small ms-1" aria-hidden="true">›</span>
                                        }
                                    }
                                </td>
                                @if (_editMode)
                                {
                                    <td class="text-nowrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move up" aria-label="Move up"
                                                disabled="@(slot.Index == 0)" @onclick="() => MoveSlot(slot.Index, -1)">▲</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move down" aria-label="Move down"
                                                disabled="@(slot.Index >= sl.Slots.Count - 1)" @onclick="() => MoveSlot(slot.Index, 1)">▼</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Copy this slot"
                                                @onclick="() => StartCopy(slot)">Copy</button>
                                        <button type="button" class="btn btn-sm @(_descSlot == slot.Index ? "btn-secondary" : "btn-outline-secondary") px-2"
                                                title="Edit this slot's notes (shown on the device and printed set lists)"
                                                @onclick="() => ToggleDescEditor(slot.Index)">Notes</button>
                                        <button type="button" class="btn btn-sm @(_colorSlot == slot.Index ? "btn-secondary" : "btn-outline-secondary") px-2"
                                                title="Pick this slot's color (shown on the device's set list)"
                                                @onclick="() => ToggleColorEditor(slot.Index)">Color</button>
                                        <button type="button" class="btn btn-sm @(_repointSlot == slot.Index ? "btn-secondary" : "btn-outline-secondary") px-2"
                                                title="Change which Program/Combi this slot loads"
                                                @onclick="() => ToggleRepoint(slot)">Load</button>
                                        @if (_copySource is not null)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary px-2" title="Paste here"
                                                    @onclick="() => PasteInto(slot.Index)">Paste</button>
                                        }
                                    </td>
                                }
                            </tr>
                            @if (!_editMode && _slotDetailSlot == slot.Index && _slotDetailCombi is not null)
                            {
                                <tr @key="@($"combi-{slot.Index}")">
                                    <td></td>
                                    <td colspan="2">
                                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                            <span class="fw-semibold">@_slotDetailCombi.Name</span>
                                            <span class="small text-body-secondary">@SlotBankLabel(slot.Reference) · #@slot.Reference.Index.ToString("D3")</span>
                                            @if (slot.Volume != 127)
                                            {
                                                <span class="small text-body-secondary">· volume @slot.Volume</span>
                                            }
                                            @if (slot.Transpose != 0)
                                            {
                                                <span class="small text-body-secondary">· transpose @slot.Transpose.ToString("+0;-0")</span>
                                            }
                                            <button type="button" class="btn btn-link btn-sm p-0 align-baseline"
                                                    @onclick="() => OpenCombi(slot.Reference.Bank, slot.Reference.Index)">Open in Combis ›</button>
                                        </div>
                                        @SongFlow(slot.Name, _slotDetailCombi, _catalog)
                                        @TimbreTable(_slotDetailCombi, _catalog)
                                    </td>
                                </tr>
                            }
                            @if (_editMode && _descSlot == slot.Index)
                            {
                                <tr @key="@($"desc-{slot.Index}")">
                                    <td></td>
                                    <td colspan="3">
                                        <label class="form-label small mb-1">
                                            Notes for slot @slot.Index.ToString("D3")
                                            <span class="text-body-secondary">— up to 512 chars, line breaks OK; shows on the device and printed set lists</span>
                                        </label>
                                        <textarea class="form-control form-control-sm" rows="3" maxlength="512"
                                                  value="@slot.Description"
                                                  @onchange="@(e => SetSlotDescription(slot.Index, e.Value?.ToString()))"></textarea>
                                    </td>
                                </tr>
                            }
                            @if (_editMode && _colorSlot == slot.Index)
                            {
                                <tr @key="@($"color-{slot.Index}")">
                                    <td></td>
                                    <td colspan="3">
                                        <div class="small text-body-secondary mb-1">Color for slot @slot.Index.ToString("D3") — shows on the device's set list</div>
                                        <div class="d-flex flex-wrap gap-1">
                                            @for (int c = 0; c < SetListSlotColors.Count; c++)
                                            {
                                                var color = c;
                                                <button type="button"
                                                        class="slot-color-choice @(slot.Color == color ? "slot-color-current" : null)"
                                                        style="background:@SetListSlotColors.Css(color)"
                                                        title="@SetListSlotColors.Name(color)"
                                                        aria-label="@SetListSlotColors.Name(color)"
                                                        @onclick="() => SetSlotColor(slot.Index, color)"></button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (_editMode && _repointSlot == slot.Index)
                            {
                                <tr @key="@($"repoint-{slot.Index}")">
                                    <td></td>
                                    <td colspan="3">
                                        <div class="d-flex align-items-end gap-2 flex-wrap">
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-sm @(_repointKind == PcgItemKind.Combi ? "btn-secondary" : "btn-outline-secondary")"
                                                        @onclick="() => SetRepointKind(PcgItemKind.Combi)">Combi</button>
                                                <button type="button" class="btn btn-sm @(_repointKind == PcgItemKind.Program ? "btn-secondary" : "btn-outline-secondary")"
                                                        @onclick="() => SetRepointKind(PcgItemKind.Program)">Program</button>
                                            </div>
                                            <div>
                                                <label class="form-label small mb-1">Bank</label>
                                                <select class="form-select form-select-sm" @onchange="OnRepointBankChanged">
                                                    @if (_repointKind == PcgItemKind.Program)
                                                    {
                                                        @foreach (var i in PresentBanks(_catalog!.ProgramBanks))
                                                        {
                                                            <option value="@i" selected="@(i == _repointBank)">@PcgBankLabels.Program(i)</option>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @foreach (var i in PresentBanks(_catalog!.CombiBanks))
                                                        {
                                                            <option value="@i" selected="@(i == _repointBank)">@PcgBankLabels.Combi(i)</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div>
                                                <label class="form-label small mb-1">Patch</label>
                                                <select class="form-select form-select-sm" style="max-width:20rem" @onchange="OnRepointIndexChanged">
                                                    @{
                                                        var repointNames = _repointKind == PcgItemKind.Program
                                                            ? _catalog!.ProgramBanks[_repointBank]
                                                            : _catalog!.CombiBanks[_repointBank];
                                                    }
                                                    @for (var i = 0; i < repointNames.Count; i++)
                                                    {
                                                        <option value="@i" selected="@(i == _repointIndex)">@i.ToString("D3") — @(string.IsNullOrEmpty(repointNames[i]) ? "(empty)" : repointNames[i])</option>
                                                    }
                                                </select>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-primary" @onclick="ApplyRepoint">Load this</button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _repointSlot = null">Cancel</button>
                                        </div>
                                        <div class="small text-body-secondary mt-1">Changes what the slot loads — its name and notes stay put.</div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <p class="text-body-secondary small">
                    "Loads" is the Program/Combi each slot recalls. In <strong>Edit mode</strong> you can rename, reorder
                    (▲▼), and copy slots; changes accumulate in memory until you Download edited .PCG.
                </p>
            }
            break;
        }

        case View.Combis:
        {
            if (_catalog is null || _catalog.CombiBanks.All(b => b.Count == 0))
            {
                <p class="text-body-secondary">This file doesn't contain any combis.</p>
            }
            else
            {
                var bank = _catalog.CombiBanks[_selectedCombiBank];
                var rows = Enumerable.Range(0, bank.Count)
                    .Where(i => _editMode || _showEmptySlots || !string.IsNullOrEmpty(bank[i]))
                    .Where(i => MatchesFilter(bank[i], i, _combiFilter))
                    .ToList();

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-5">
                        <label class="form-label small mb-1">Combi bank</label>
                        <select class="form-select form-select-sm" @onchange="OnCombiBankChanged">
                            @foreach (var i in PresentBanks(_catalog.CombiBanks))
                            {
                                <option value="@i" selected="@(i == _selectedCombiBank)">
                                    @PcgBankLabels.Combi(i) (@CountNonEmpty(_catalog.CombiBanks[i]) combis)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Find</label>
                        <input type="text" class="form-control form-control-sm" placeholder="name or #…"
                               @bind="_combiFilter" @bind:event="oninput" />
                    </div>
                    <div class="col-md-4 d-flex gap-3 align-items-center pt-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="combiEdit" @bind="_editMode" />
                            <label class="form-check-label small" for="combiEdit">Edit mode</label>
                        </div>
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="combiShowEmpty" @bind="_showEmptySlots" />
                            <label class="form-check-label small" for="combiShowEmpty">Show empty</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    <h2 class="h5 mb-0">Combi bank @PcgBankLabels.Combi(_selectedCombiBank)</h2>
                    <div class="d-flex gap-2">
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    title="Printable sheet: every combi in this bank with its timbre programs"
                                    @onclick="ExportCombiContentsHtml">Print contents</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportCombiContentsCsv">CSV</button>
                        </div>
                        @if (_editMode)
                        {
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Sort this bank A–Z (empty slots go last) — every song keeps its sound"
                                        @onclick="SortCombiBank">Sort A–Z</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Move empty slots to the end — every song keeps its sound"
                                        @onclick="CompactCombiBank">Compact</button>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_combiFilter))
                {
                    <div class="text-body-secondary small mb-2">
                        @rows.Count match@(rows.Count == 1 ? "" : "es") for "@_combiFilter" in this bank
                        <button type="button" class="btn btn-link btn-sm p-0 ms-1 align-baseline"
                                @onclick="@(() => _combiFilter = string.Empty)">clear</button>
                    </div>
                }

                @if (_combiCopySource is not null)
                {
                    <div class="alert alert-info d-flex justify-content-between align-items-center py-1 px-2 small">
                        <span>Copying combi <strong>@_combiCopySourceName</strong> — click <em>Paste</em> on a target.</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _combiCopySource = null">Cancel</button>
                    </div>
                }

                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:4rem">#</th>
                            <th>Name</th>
                            <th style="width:6rem" class="d-none d-md-table-cell" title="Set-list slots that load this combi">Used by</th>
                            <th style="width:6.5rem"></th>
                            @if (_editMode)
                            {
                                <th style="width:13rem">Edit</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var idx in rows)
                        {
                            var name = bank[idx];
                            var isEmpty = string.IsNullOrEmpty(name);
                            var refs = _combiRefCounts.GetValueOrDefault((_selectedCombiBank, idx));
                            <tr @key="idx" id="combi-row-@idx" class="@(isEmpty ? "text-body-secondary" : null)">
                                <td>@idx.ToString("D3")</td>
                                <td>
                                    @if (_editMode)
                                    {
                                        <input class="form-control form-control-sm" maxlength="24" placeholder="(empty)"
                                               value="@name" @onchange="@(e => RenameCombiAt(idx, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        @(isEmpty ? "—" : name)
                                    }
                                </td>
                                <td class="d-none d-md-table-cell">@(refs > 0 ? refs.ToString() : "")</td>
                                <td>
                                    @if (!isEmpty)
                                    {
                                        <button type="button" class="btn btn-sm @(_timbreCombi == idx ? "btn-secondary" : "btn-outline-secondary") px-2"
                                                title="What's inside this combi" @onclick="() => ToggleTimbres(idx)">Timbres</button>
                                    }
                                </td>
                                @if (_editMode)
                                {
                                    <td class="text-nowrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move up" aria-label="Move up"
                                                disabled="@(idx == 0)" @onclick="() => MoveCombi(idx, -1)">▲</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move down" aria-label="Move down"
                                                disabled="@(idx >= bank.Count - 1)" @onclick="() => MoveCombi(idx, 1)">▼</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Copy this combi"
                                                @onclick="() => StartCombiCopy(idx)">Copy</button>
                                        @if (_combiCopySource is not null)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary px-2" title="Paste here"
                                                    @onclick="() => PasteCombiInto(idx)">Paste</button>
                                        }
                                    </td>
                                }
                            </tr>
                            @if (_timbreCombi == idx && _timbreDetail is not null)
                            {
                                <tr @key="@($"timbres-{idx}")">
                                    <td></td>
                                    <td colspan="@(_editMode ? 4 : 3)">@TimbreTable(_timbreDetail, _catalog)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <p class="text-body-secondary small">
                    Reorder (▲▼) swaps two combis; the set lists that use them follow automatically, so your songs keep
                    their sound. "Used by" is how many set-list slots load each combi. Copy overwrites the target.
                    <strong>Sort A–Z</strong> / <strong>Compact</strong> reorganize the whole bank the same safe way
                    (empty slots go last). Use <strong>Find</strong> to jump to a combi by name or number;
                    clear it before reordering so you can see the neighbour a swap will hit.
                </p>
            }
            break;
        }

        case View.Programs:
        {
            if (_catalog is null || _catalog.ProgramBanks.All(b => b.Count == 0))
            {
                <p class="text-body-secondary">This file doesn't contain any programs.</p>
            }
            else
            {
                var bank = _catalog.ProgramBanks[_selectedProgramBank];
                var refCounts = CurrentUsage.Programs.ToDictionary(p => (p.BankIndex, p.Number), p => p.ReferenceCount);
                var rows = Enumerable.Range(0, bank.Count)
                    .Where(i => _editMode || _showEmptySlots || !string.IsNullOrEmpty(bank[i]))
                    .Where(i => MatchesFilter(bank[i], i, _programFilter)
                        || (!string.IsNullOrWhiteSpace(_programFilter)
                            && ProgramInfoAt(_selectedProgramBank, i) is { IsEmpty: false } fi
                            && _catalog.ProgramCategoryName(fi.Category).Contains(_programFilter.Trim(), StringComparison.OrdinalIgnoreCase)))
                    .ToList();

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-5">
                        <label class="form-label small mb-1">Program bank</label>
                        <select class="form-select form-select-sm" @onchange="OnProgramBankChanged">
                            @foreach (var i in PresentBanks(_catalog.ProgramBanks))
                            {
                                <option value="@i" selected="@(i == _selectedProgramBank)">
                                    @PcgBankLabels.Program(i) (@ProgramTypeTag(_catalog, i)@CountNonEmpty(_catalog.ProgramBanks[i]) programs)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Find</label>
                        <input type="text" class="form-control form-control-sm" placeholder="name, category, or #…"
                               @bind="_programFilter" @bind:event="oninput" />
                    </div>
                    <div class="col-md-4 d-flex gap-3 align-items-center pt-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="programEdit" @bind="_editMode" />
                            <label class="form-check-label small" for="programEdit">Edit mode</label>
                        </div>
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="programShowEmpty" @bind="_showEmptySlots" />
                            <label class="form-check-label small" for="programShowEmpty">Show empty</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    <h2 class="h5 mb-0">Program bank @PcgBankLabels.Program(_selectedProgramBank)</h2>
                    <div class="d-flex gap-2">
                        @if (_editMode)
                        {
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Sort this bank A–Z (empty slots go last) — every song keeps its sound"
                                        @onclick="SortProgramBank">Sort A–Z</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Move empty slots to the end — every song keeps its sound"
                                        @onclick="CompactProgramBank">Compact</button>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_programFilter))
                {
                    <div class="text-body-secondary small mb-2">
                        @rows.Count match@(rows.Count == 1 ? "" : "es") for "@_programFilter" in this bank
                        <button type="button" class="btn btn-link btn-sm p-0 ms-1 align-baseline"
                                @onclick="@(() => _programFilter = string.Empty)">clear</button>
                    </div>
                }

                @if (_programCopySource is not null)
                {
                    var pasteTypeOk = _catalog.ProgramBankTypes[_programCopySource.Value.Bank] == _catalog.ProgramBankTypes[_selectedProgramBank];
                    <div class="alert alert-info d-flex justify-content-between align-items-center py-1 px-2 small">
                        <span>
                            Copying program <strong>@_programCopySourceName</strong> (@ProgramTypeTag(_catalog, _programCopySource.Value.Bank)from @PcgBankLabels.Program(_programCopySource.Value.Bank)) — click <em>Paste</em> on a target.
                            @if (!pasteTypeOk)
                            {
                                <strong> This bank has the other engine type — pick an @(ProgramTypeTag(_catalog, _programCopySource.Value.Bank).TrimEnd(',', ' ')) bank to paste into.</strong>
                            }
                        </span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _programCopySource = null">Cancel</button>
                    </div>
                }

                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:4rem">#</th>
                            <th>Name</th>
                            <th style="width:12rem" class="d-none d-sm-table-cell">Category</th>
                            <th style="width:6rem" class="d-none d-md-table-cell" title="Combi timbres + program-type set-list slots that use this program">Used by</th>
                            @if (_editMode)
                            {
                                <th style="width:13rem">Edit</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var idx in rows)
                        {
                            var name = bank[idx];
                            var isEmpty = string.IsNullOrEmpty(name);
                            var refs = refCounts.GetValueOrDefault((_selectedProgramBank, idx));
                            <tr @key="idx" id="program-row-@idx" class="@(isEmpty ? "text-body-secondary" : null)">
                                <td>@idx.ToString("D3")</td>
                                <td>
                                    @if (_editMode)
                                    {
                                        <input class="form-control form-control-sm" maxlength="24" placeholder="(empty)"
                                               value="@name" @onchange="@(e => RenameProgramAt(idx, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        @(isEmpty ? "—" : name)
                                    }
                                </td>
                                <td class="d-none d-sm-table-cell">
                                    @if (!isEmpty && ProgramInfoAt(_selectedProgramBank, idx) is { } info)
                                    {
                                        <span class="small">@_catalog.ProgramCategoryName(info.Category)</span>
                                        @if (info.ExiEngine is { } engine)
                                        {
                                            <span class="badge text-bg-light fw-normal ms-1">@ExiEngines.Name(engine)</span>
                                        }
                                        @if (info.Favorite)
                                        {
                                            <span class="ms-1" title="Favorite">★</span>
                                        }
                                    }
                                </td>
                                <td class="d-none d-md-table-cell">@(refs > 0 ? refs.ToString() : "")</td>
                                @if (_editMode)
                                {
                                    <td class="text-nowrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move up" aria-label="Move up"
                                                disabled="@(idx == 0)" @onclick="() => MoveProgram(idx, -1)">▲</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move down" aria-label="Move down"
                                                disabled="@(idx >= bank.Count - 1)" @onclick="() => MoveProgram(idx, 1)">▼</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Copy this program"
                                                @onclick="() => StartProgramCopy(idx)">Copy</button>
                                        @if (_programCopySource is not null)
                                        {
                                            var pasteOk = _catalog.ProgramBankTypes[_programCopySource!.Value.Bank] == _catalog.ProgramBankTypes[_selectedProgramBank];
                                            <button type="button" class="btn btn-sm btn-outline-primary px-2" disabled="@(!pasteOk)"
                                                    title="@(pasteOk ? "Paste here" : "This bank's engine type (HD-1/EXi) differs from the copied program's bank")"
                                                    @onclick="() => PasteProgramInto(idx)">Paste</button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
                <p class="text-body-secondary small">
                    Reorder (▲▼) swaps two programs; the combis and set lists that use them follow automatically, so
                    everything keeps its sound. "Used by" is how many places load each program. Copy overwrites the target.
                    <strong>Sort A–Z</strong> / <strong>Compact</strong> reorganize the whole bank the same safe way
                    (empty slots go last). Use <strong>Find</strong> to jump to a program by name or number;
                    clear it before reordering so you can see the neighbour a swap will hit.
                </p>
            }
            break;
        }

        case View.Copy:
        {
            <h2 class="h5">Copy between files</h2>
            <p class="text-body-secondary small">
                Open a second <code>.PCG</code> as a read-only <strong>source</strong>, then copy programs,
                combis, or set-list slots into the file you're editing. A copy <strong>overwrites</strong> the
                destination slot you choose; edits accumulate in memory until you download the edited .PCG.
            </p>

            <div class="row g-3 mb-3">
                <div class="col-lg-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                            <span class="text-body-secondary small">Destination — your main file</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary" title="Save an unmodified copy under a new name"
                                    @onclick="DownloadDestinationCopy">Download a copy</button>
                        </div>
                        <div class="fw-semibold text-truncate" title="@_fileName">@_fileName</div>
                        <div class="text-body-secondary small">@Format.Bytes(_pcg.Length)@(_dirty ? " — has unsaved edits" : "")</div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="border rounded p-3 h-100">
                        @if (_srcPcg is null)
                        {
                            <label class="form-label small fw-semibold mb-1">Source — choose a second .PCG to copy from</label>
                            <InputFile OnChange="OnSourceFileSelected" accept=".PCG,.pcg" class="form-control form-control-sm" />
                            @if (_srcLoading)
                            {
                                <div class="mt-2 text-body-secondary small">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Reading and parsing @_srcFileName …
                                </div>
                            }
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                                <span class="text-body-secondary small">Source — read-only</span>
                                <span class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="DownloadSourceCopy">Download a copy</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearSource">Clear</button>
                                </span>
                            </div>
                            <div class="fw-semibold text-truncate" title="@_srcFileName">@_srcFileName</div>
                            <div class="text-body-secondary small">@Format.Bytes(_srcPcg.Length)</div>
                        }
                        @if (_srcError is not null)
                        {
                            <div class="alert alert-danger mt-2 mb-0 py-1 px-2 small">@_srcError</div>
                        }
                    </div>
                </div>
            </div>

            @if (_srcPcg is not null && _srcCatalog is not null)
            {
                var compat = PcgCompat.Compare(_srcPcg, _pcg);
                if (!compat.AllMatch)
                {
                    <div class="alert alert-danger">
                        <strong>These files come from different instruments</strong> (@compat.MismatchSummary) —
                        songs and sounds can't be copied between them.
                    </div>
                }
                else
                {
                    var srcRows = CrossSourceRows();

                    <div class="d-flex align-items-end gap-2 flex-wrap mb-2">
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm @(_crossKind == CrossKind.Programs ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="() => SetCrossKind(CrossKind.Programs)">Programs</button>
                            <button type="button" class="btn btn-sm @(_crossKind == CrossKind.Combis ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="() => SetCrossKind(CrossKind.Combis)">Combis</button>
                            <button type="button" class="btn btn-sm @(_crossKind == CrossKind.SetListSlots ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="() => SetCrossKind(CrossKind.SetListSlots)">Set-list slots</button>
                        </div>
                        <div>
                            <label class="form-label small mb-1">@(_crossKind == CrossKind.SetListSlots ? "Source set list" : "Source bank")</label>
                            <select class="form-select form-select-sm" @onchange="OnCrossSrcBankChanged">
                                @if (_crossKind == CrossKind.Programs)
                                {
                                    @foreach (var i in PresentBanks(_srcCatalog.ProgramBanks))
                                    {
                                        <option value="@i" selected="@(i == _crossSrcBank)">@PcgBankLabels.Program(i) (@ProgramTypeTag(_srcCatalog, i)@CountNonEmpty(_srcCatalog.ProgramBanks[i]))</option>
                                    }
                                }
                                else if (_crossKind == CrossKind.Combis)
                                {
                                    @foreach (var i in PresentBanks(_srcCatalog.CombiBanks))
                                    {
                                        <option value="@i" selected="@(i == _crossSrcBank)">@PcgBankLabels.Combi(i) (@CountNonEmpty(_srcCatalog.CombiBanks[i]))</option>
                                    }
                                }
                                else
                                {
                                    @for (var i = 0; i < _srcSetLists.Count; i++)
                                    {
                                        <option value="@i" selected="@(i == _crossSrcBank)">@i.ToString("D3") — @_srcSetLists[i].DisplayName (@_srcSetLists[i].NamedSlots.Count())</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="form-label small mb-1">Find</label>
                            <input type="text" class="form-control form-control-sm" placeholder="name or #…"
                                   @bind="_crossFilter" @bind:event="oninput" />
                        </div>
                    </div>

                    @if (_crossSelection is { } sel)
                    {
                        <div class="alert alert-info">
                            <div class="d-flex align-items-end gap-2 flex-wrap">
                                <div class="me-2 pb-1">
                                    Copy <strong>@sel.Name</strong>
                                    <span class="text-body-secondary small">(@CrossSrcLabel(sel.Bank) #@sel.Index.ToString("D3"))</span> to:
                                </div>
                                <div>
                                    <label class="form-label small mb-1">@(_crossKind == CrossKind.SetListSlots ? "Set list" : "Bank")</label>
                                    <select class="form-select form-select-sm" @onchange="OnCrossDstBankChanged">
                                        @if (_crossKind == CrossKind.Programs)
                                        {
                                            var srcType = _srcCatalog?.ProgramBankTypes.ElementAtOrDefault(sel.Bank);
                                            @foreach (var i in PresentBanks(_catalog!.ProgramBanks))
                                            {
                                                @* Program records can't cross HD-1/EXi banks — offer matching-type banks only. *@
                                                if (srcType is not null && _catalog.ProgramBankTypes[i] != srcType)
                                                    continue;
                                                <option value="@i" selected="@(i == _crossDstBank)">@PcgBankLabels.Program(i) (@ProgramTypeTag(_catalog, i)@CountNonEmpty(_catalog.ProgramBanks[i]))</option>
                                            }
                                        }
                                        else if (_crossKind == CrossKind.Combis)
                                        {
                                            @foreach (var i in PresentBanks(_catalog!.CombiBanks))
                                            {
                                                <option value="@i" selected="@(i == _crossDstBank)">@PcgBankLabels.Combi(i)</option>
                                            }
                                        }
                                        else
                                        {
                                            @for (var i = 0; i < _setLists.Count; i++)
                                            {
                                                <option value="@i" selected="@(i == _crossDstBank)">@i.ToString("D3") — @_setLists[i].DisplayName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small mb-1">Slot <span class="text-body-secondary">(current occupant shown)</span></label>
                                    <select class="form-select form-select-sm" style="max-width:22rem" @onchange="OnCrossDstIndexChanged">
                                        @if (_crossKind == CrossKind.SetListSlots)
                                        {
                                            @foreach (var slot in _setLists[_crossDstBank].Slots)
                                            {
                                                <option value="@slot.Index" selected="@(slot.Index == _crossDstIndex)">@slot.Index.ToString("D3") — @(slot.IsEmpty ? "(empty)" : slot.Name)</option>
                                            }
                                        }
                                        else
                                        {
                                            var dstNames = _crossKind == CrossKind.Programs
                                                ? _catalog!.ProgramBanks[_crossDstBank]
                                                : _catalog!.CombiBanks[_crossDstBank];
                                            @for (var i = 0; i < dstNames.Count; i++)
                                            {
                                                <option value="@i" selected="@(i == _crossDstIndex)">@i.ToString("D3") — @(string.IsNullOrEmpty(dstNames[i]) ? "(empty)" : dstNames[i])</option>
                                            }
                                        }
                                    </select>
                                </div>
                                @if (!(_crossKind == CrossKind.Combis && _crossDeepMode))
                                {
                                    <button type="button" class="btn btn-sm btn-primary" @onclick="DoCrossCopy">Copy</button>
                                }
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelCrossSelection">Cancel</button>
                            </div>
                            <div class="small mt-1">Copying <strong>overwrites</strong> the destination slot shown above.</div>
                            @if (_crossKind == CrossKind.Combis && _crossSelectedCombi is not null)
                            {
                                <div class="btn-group btn-group-sm mt-2">
                                    <button type="button" class="btn @(!_crossDeepMode ? "btn-secondary" : "btn-outline-secondary")"
                                            @onclick="() => SetCrossDeepMode(false)">Combi only</button>
                                    <button type="button" class="btn @(_crossDeepMode ? "btn-secondary" : "btn-outline-secondary")"
                                            title="Also copy the programs this combi's timbres reference, so it keeps its sound"
                                            @onclick="() => SetCrossDeepMode(true)">Combi + its programs</button>
                                </div>
                                @if (!_crossDeepMode)
                                {
                                    var timbres = _crossSelectedCombi.Timbres.Where(t => t.UsesInternalProgram).ToList();
                                    var matching = timbres.Count(t =>
                                        (_srcCatalog.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)")
                                        == (_catalog!.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)"));
                                    <div class="small mt-2">
                                        In your file this combi will play whatever lives at those program slots —
                                        <strong>@matching of @timbres.Count</strong> sounds currently match by name.
                                        Use <em>Combi + its programs</em> to bring its own sounds along.
                                        <details class="mt-1">
                                            <summary class="text-body-secondary">show timbres</summary>
                                            <ul class="mb-0">
                                                @foreach (var t in timbres)
                                                {
                                                    var srcName = _srcCatalog.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)";
                                                    var dstName = _catalog!.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)";
                                                    <li>
                                                        T@(t.Index + 1): @PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(t.ProgramBankPcgId)) #@t.ProgramNumber.ToString("D3")
                                                        — source '@srcName'@(srcName == dstName ? " (same in destination)" : $" vs destination '{dstName}'")
                                                    </li>
                                                }
                                            </ul>
                                        </details>
                                    </div>
                                }
                                else
                                {
                                    var plan = CurrentDeepPlan();
                                    <div class="small mt-2">
                                        <div class="d-flex align-items-end gap-2 flex-wrap mb-1">
                                            @foreach (var bankType in new[] { ProgramBankType.Exi, ProgramBankType.Hd1 })
                                            {
                                                if (plan is null || !plan.Needs(bankType))
                                                    continue;
                                                var typeLabel = PcgBankIdentity.TypeLabel(bankType);
                                                var selectedBank = bankType == ProgramBankType.Hd1 ? _crossDeepHd1Bank : _crossDeepExiBank;
                                                <div>
                                                    <label class="form-label small mb-1">@typeLabel programs go to</label>
                                                    <select class="form-select form-select-sm" @onchange="e => OnCrossDeepBankChanged(bankType, e)">
                                                        @foreach (var i in PresentBanks(_catalog!.ProgramBanks))
                                                        {
                                                            if (_catalog.ProgramBankTypes[i] != bankType)
                                                                continue;
                                                            <option value="@i" selected="@(i == selectedBank)">
                                                                @PcgBankLabels.Program(i) (@typeLabel, @PcgDeepCopy.FreeProgramSlots(_catalog.ProgramBanks[i]).Count free)
                                                            </option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            @if (plan is not null)
                                            {
                                                <button type="button" class="btn btn-sm btn-primary" disabled="@(!plan.CanApply)" @onclick="DoCrossCopy">
                                                    Apply — copy combi to @CrossDstLabel() + @plan.Copies.Count() program(s)
                                                </button>
                                            }
                                        </div>
                                        @if (plan is not null)
                                        {
                                            @if (plan.Error is not null)
                                            {
                                                <div class="alert alert-warning py-1 px-2 my-1">@plan.Error</div>
                                            }
                                            <ul class="my-1">
                                                @foreach (var m in plan.Copies)
                                                {
                                                    <li>
                                                        <strong>@m.Name</strong> — @PcgBankLabels.Program(m.SourceBank) #@m.SourceIndex.ToString("D3")
                                                        → @(m.DestinationIndex >= 0 ? $"{PcgBankLabels.Program(m.DestinationBank)} #{m.DestinationIndex:D3}" : "(no free slot)")
                                                        <span class="text-body-secondary">T@(string.Join(", T", m.Timbres.Select(t => t + 1)))</span>
                                                    </li>
                                                }
                                                @foreach (var m in plan.Reused)
                                                {
                                                    <li>
                                                        <strong>@m.Name</strong> — reuses @PcgBankLabels.Program(m.DestinationBank) #@m.DestinationIndex.ToString("D3")
                                                        <span class="text-body-secondary">(identical program already in this file) T@(string.Join(", T", m.Timbres.Select(t => t + 1)))</span>
                                                    </li>
                                                }
                                            </ul>
                                            @if (plan.Skips.Count > 0)
                                            {
                                                <details class="mb-1">
                                                    <summary class="text-body-secondary">@plan.Skips.Count timbre(s) left as-is</summary>
                                                    <ul class="mb-0">
                                                        @foreach (var s in plan.Skips)
                                                        {
                                                            <li>T@(s.Timbre + 1): @DeepSkipText(s)</li>
                                                        }
                                                    </ul>
                                                </details>
                                            }
                                            @if (plan.UsesUserKarmaGes)
                                            {
                                                var userGes = _crossSelectedCombi.KarmaGeIds
                                                    .Where(id => id >= Combi.KarmaUserGeBase).Distinct()
                                                    .Select(Combi.KarmaGeLabel);
                                                <div class="text-body-secondary">
                                                    This combi drives KARMA with user GE(s) @string.Join(", ", userGes) — user GEs live
                                                    in the pack's <code>.KGE</code> file, which a <code>.PCG</code> copy can't carry. The combi
                                                    still copies; KARMA plays differently until that <code>.KGE</code> is loaded on the instrument.
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }

                    @if (_crossLastCopy is not null)
                    {
                        <div class="alert @(_crossLastCopyIsError ? "alert-warning" : "alert-success") py-1 px-2 small">@_crossLastCopy</div>
                    }

                    <div class="text-body-secondary small mb-1">
                        @srcRows.Count item(s)@(string.IsNullOrWhiteSpace(_crossFilter) ? "" : $" matching \"{_crossFilter}\"") in the source — click <em>Select</em>, then choose a destination.
                    </div>
                    <table class="table table-sm table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width:4rem">#</th>
                                <th>Name</th>
                                @if (_crossKind == CrossKind.SetListSlots)
                                {
                                    <th class="d-none d-md-table-cell">Loads</th>
                                }
                                <th style="@(_crossKind == CrossKind.Combis ? "width:10rem" : "width:6rem")"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in srcRows.Take(MaxRows))
                            {
                                <tr @key="row.Index" class="@(_crossSelection is { } cs && cs.Bank == _crossSrcBank && cs.Index == row.Index ? "table-active" : null)">
                                    <td>@row.Index.ToString("D3")</td>
                                    <td>@row.Name</td>
                                    @if (_crossKind == CrossKind.SetListSlots)
                                    {
                                        <td class="small text-body-secondary d-none d-md-table-cell">@row.Extra</td>
                                    }
                                    <td class="text-nowrap">
                                        @if (_crossKind == CrossKind.Combis)
                                        {
                                            <button type="button" class="btn btn-sm @(_crossTimbreIndex == row.Index ? "btn-secondary" : "btn-outline-secondary") px-2 me-1"
                                                    title="What's inside this combi" @onclick="() => ToggleCrossTimbres(row.Index)">Timbres</button>
                                        }
                                        <button type="button" class="btn btn-sm btn-outline-primary px-2" @onclick="() => SelectCrossItem(row.Index, row.Name)">Select</button>
                                    </td>
                                </tr>
                                @if (_crossKind == CrossKind.Combis && _crossTimbreIndex == row.Index && _crossTimbreDetail is not null)
                                {
                                    <tr @key="@($"cross-timbres-{row.Index}")">
                                        <td></td>
                                        <td colspan="2">@TimbreTable(_crossTimbreDetail, _srcCatalog)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
            }
            break;
        }

        case View.Differences:
        {
            <h2 class="h5">Differences</h2>
            @if (_srcPcg is null || _srcCatalog is null)
            {
                <p class="text-body-secondary">
                    Open a second <code>.PCG</code> as the read-only source on the
                    <button type="button" class="btn btn-sm btn-outline-secondary align-baseline"
                            @onclick="() => _view = View.Copy">Copy</button>
                    tab, then come back — this view lists every program, combi, and set-list slot that
                    differs between that file (before) and the file you're editing (after).
                </p>
            }
            else
            {
                var compat = PcgCompat.Compare(_srcPcg, _pcg);
                if (!compat.AllMatch)
                {
                    <div class="alert alert-danger">
                        <strong>These files come from different instruments</strong> (@compat.MismatchSummary) —
                        so they can't be compared.
                    </div>
                }
                else
                {
                    var diff = _diffReport ??= PcgDiff.Compare(_srcPcg, _pcg);

                    <p class="text-body-secondary small mb-2">
                        Changes from <strong>@_srcFileName</strong> (before) to
                        <strong>@_fileName</strong> (after)@(_dirty ? " — including your unsaved edits" : "").
                        A <em>moved</em> entry is the same patch found at a new position (a reorg);
                        <em>edited</em> entries often accompany a move because they were updated to follow it.
                    </p>

                    @if (diff.IsEmpty)
                    {
                        <div class="alert alert-success">
                            The two files' programs, combis, and set lists are identical.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                            <div class="text-body-secondary small">
                                Programs: @DiffSummary(diff.Programs) &nbsp;·&nbsp; Combis: @DiffSummary(diff.Combis)
                                &nbsp;·&nbsp; Set-list slots: @DiffSummary(diff.SetListSlots)@(
                                    diff.RenamedSetLists.Count > 0 ? $" · set lists renamed: {diff.RenamedSetLists.Count}" : "")
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportDifferencesCsv">CSV</button>
                        </div>

                        @DiffSection("Programs", diff.Programs, PcgBankLabels.Program)
                        @DiffSection("Combis", diff.Combis, PcgBankLabels.Combi)
                        @DiffSection("Set-list slots", diff.SetListSlots, sl => $"SL {sl:D3}")

                        @if (diff.RenamedSetLists.Count > 0)
                        {
                            <h3 class="h6 mt-3">Renamed set lists (@diff.RenamedSetLists.Count)</h3>
                            <table class="table table-sm table-hover align-middle">
                                <thead><tr><th style="width:6rem">Set list</th><th>Name</th></tr></thead>
                                <tbody>
                                    @foreach (var e in diff.RenamedSetLists)
                                    {
                                        <tr>
                                            <td>@e.Bank.ToString("D3")</td>
                                            <td>@DisplayName(e.NameBefore) <span class="text-body-secondary">→</span> @DisplayName(e.NameAfter)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                }
            }
            break;
        }

        case View.Usage:
        {
            var usage = CurrentUsage;
            var usageBanks = usage.Programs.Select(p => p.BankIndex).Distinct().OrderBy(b => b).ToList();
            IEnumerable<ProgramUsage> usageQuery = usage.Programs;
            if (_usageBankFilter >= 0)
                usageQuery = usageQuery.Where(p => p.BankIndex == _usageBankFilter);
            if (!string.IsNullOrWhiteSpace(_usageFilter))
            {
                var needle = _usageFilter.Trim();
                usageQuery = usageQuery.Where(p =>
                    p.Name.Contains(needle, StringComparison.OrdinalIgnoreCase)
                    || p.Number.ToString("D3").Contains(needle)
                    || PcgBankLabels.Program(p.BankIndex).Contains(needle, StringComparison.OrdinalIgnoreCase));
            }
            usageQuery = _usageSort switch
            {
                UsageSort.Name => usageQuery.OrderBy(p => p.Name, StringComparer.OrdinalIgnoreCase),
                UsageSort.MostUsed => usageQuery.OrderByDescending(p => p.ReferenceCount)
                                                .ThenBy(p => p.BankIndex).ThenBy(p => p.Number),
                _ => usageQuery.OrderBy(p => p.BankIndex).ThenBy(p => p.Number),
            };
            var programsView = usageQuery.ToList();
            var usageFiltered = _usageBankFilter >= 0 || !string.IsNullOrWhiteSpace(_usageFilter);
            <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                <h2 class="h5 mb-0">Program usage</h2>
                <div class="btn-group">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportUsageCsv">CSV</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportUsageHtml">HTML</button>
                </div>
            </div>
            <p class="text-body-secondary small">
                Which programs your combis and set lists actually use —
                <strong>@usage.Programs.Count</strong> in use,
                <strong>@usage.UnreferencedPrograms.Count</strong> programs and
                <strong>@usage.UnreferencedCombis.Count</strong> combis that nothing uses.
                "Nothing uses it" means nothing in <em>this file</em> loads it; songs in separate
                sequencer files aren't counted yet.
            </p>

            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Find program</label>
                    <input type="text" class="form-control form-control-sm" placeholder="name, # or bank…"
                           @bind="_usageFilter" @bind:event="oninput" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-1">Bank</label>
                    <select class="form-select form-select-sm" @bind="_usageBankFilter">
                        <option value="-1">All banks</option>
                        @foreach (var b in usageBanks)
                        {
                            <option value="@b">@PcgBankLabels.Program(b)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-1">Sort</label>
                    <select class="form-select form-select-sm" @bind="_usageSort">
                        <option value="@UsageSort.BankNumber">Bank, #</option>
                        <option value="@UsageSort.Name">Name</option>
                        <option value="@UsageSort.MostUsed">Most used</option>
                    </select>
                </div>
            </div>

            <div class="text-body-secondary small mb-2">
                Showing @programsView.Count of @usage.Programs.Count program@(usage.Programs.Count == 1 ? "" : "s") in use@(usageFiltered ? " (filtered)" : "").
                @if (usageFiltered)
                {
                    <button type="button" class="btn btn-link btn-sm p-0 ms-1 align-baseline" @onclick="ClearUsageFilters">clear</button>
                }
            </div>

            <table class="table table-sm table-hover align-middle">
                <thead>
                    <tr>
                        <th style="width:5rem" class="d-none d-md-table-cell">Bank</th>
                        <th style="width:4rem">#</th>
                        <th>Program</th>
                        <th style="width:4rem" class="text-end">Refs</th>
                        <th>Used by</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in programsView)
                    {
                        <tr>
                            <td class="d-none d-md-table-cell">@PcgBankLabels.Program(p.BankIndex)</td>
                            <td>@p.Number.ToString("D3")</td>
                            <td>@(string.IsNullOrEmpty(p.Name) ? "—" : p.Name)</td>
                            <td class="text-end">@p.ReferenceCount</td>
                            <td>
                                <details>
                                    <summary class="small text-body-secondary">show</summary>
                                    <ul class="small mb-0">
                                        @foreach (var s in p.Sites)
                                        {
                                            <li>@s.Description</li>
                                        }
                                    </ul>
                                </details>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (usage.UnreferencedCombis.Count > 0)
            {
                <details class="mb-3">
                    <summary class="h6 d-inline">Combis nothing uses (@usage.UnreferencedCombis.Count)</summary>
                    <p class="text-body-secondary small mb-1 mt-1">Combis no set-list slot loads — cleanup candidates.</p>
                    <ul class="small">
                        @foreach (var c in usage.UnreferencedCombis)
                        {
                            <li>@PcgBankLabels.Combi(c.BankIndex) #@c.Number.ToString("D3") — @c.Name</li>
                        }
                    </ul>
                </details>
            }

            @if (usage.UnreferencedPrograms.Count > 0)
            {
                <details>
                    <summary class="h6 d-inline">Programs nothing uses (@usage.UnreferencedPrograms.Count)</summary>
                    <p class="text-body-secondary small mb-1 mt-1">Not loaded by any combi or set-list slot in this file (many factory programs land here).</p>
                    <ul class="small">
                        @foreach (var p in usage.UnreferencedPrograms.Take(MaxRows))
                        {
                            <li>@PcgBankLabels.Program(p.BankIndex) #@p.Number.ToString("D3") — @p.Name</li>
                        }
                    </ul>
                    @if (usage.UnreferencedPrograms.Count > MaxRows)
                    {
                        <p class="text-body-secondary small">… showing first @MaxRows of @usage.UnreferencedPrograms.Count.</p>
                    }
                </details>
            }
            break;
        }

        case View.Duplicates:
        {
            var dupCombis = PcgDuplicates.Combis(_pcg);
            var dupPrograms = PcgDuplicates.Programs(_pcg);

            <h2 class="h5">Duplicate patches</h2>
            <p class="text-body-secondary small">
                Programs and combis that share a name. <span class="badge text-bg-secondary">identical</span>
                means they're exact copies of the same sound (a true redundant copy); without it, the name is
                reused for a different sound.
            </p>

            <h3 class="h6 mt-3">Combis — @dupCombis.Count duplicate name@(dupCombis.Count == 1 ? "" : "s")</h3>
            @if (dupCombis.Count == 0)
            {
                <p class="text-body-secondary small">No duplicate combi names.</p>
            }
            else
            {
                <table class="table table-sm align-middle">
                    <thead><tr><th>Name</th><th style="width:5rem" class="text-end">Count</th><th>Members</th></tr></thead>
                    <tbody>
                        @foreach (var g in dupCombis)
                        {
                            <tr>
                                <td>
                                    @g.Name
                                    @if (g.AllByteIdentical) { <span class="badge text-bg-secondary">identical</span> }
                                </td>
                                <td class="text-end">@g.Count</td>
                                <td class="small text-body-secondary">@MemberList(g, isProgram: false)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <h3 class="h6 mt-4">Programs — @dupPrograms.Count duplicate name@(dupPrograms.Count == 1 ? "" : "s")</h3>
            @if (dupPrograms.Count == 0)
            {
                <p class="text-body-secondary small">No duplicate program names.</p>
            }
            else
            {
                <table class="table table-sm align-middle">
                    <thead><tr><th>Name</th><th style="width:5rem" class="text-end">Count</th><th>Members</th></tr></thead>
                    <tbody>
                        @foreach (var g in dupPrograms)
                        {
                            <tr>
                                <td>
                                    @g.Name
                                    @if (g.AllByteIdentical) { <span class="badge text-bg-secondary">identical</span> }
                                </td>
                                <td class="text-end">@g.Count</td>
                                <td class="small text-body-secondary">@MemberList(g, isProgram: true)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            break;
        }

        case View.Search:
        {
            var hits = _catalog is null
                ? new List<SearchHit>()
                : PcgSearch.Find(_catalog, _setLists, _nameQuery).ToList();

            <h2 class="h5">Find a song or sound</h2>
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <input type="text" class="form-control form-control-sm" @ref="_searchInput"
                           placeholder="search Program / Combi / Set List / Drum kit / Wave seq names…"
                           @bind="_nameQuery" @bind:event="oninput" />
                </div>
            </div>

            @if (string.IsNullOrWhiteSpace(_nameQuery))
            {
                <p class="text-body-secondary small">Type to search names across Programs, Combis, Set List slots, Drum kits, and Wave Sequences. Click a result to jump to it.</p>
            }
            else
            {
                <div class="text-body-secondary small mb-2">
                    @hits.Count match@(hits.Count == 1 ? "" : "es")@(hits.Count > MaxRows ? $" — showing first {MaxRows}" : "")
                </div>
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:7rem">Type</th>
                            <th>Name</th>
                            <th style="width:14rem">Location</th>
                            <th style="width:5.5rem"><span class="visually-hidden">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in hits.Take(MaxRows))
                        {
                            var open = HitAction(h);
                            <tr class="@(open is not null ? "row-clickable" : null)"
                                role="@(open is not null ? "button" : null)"
                                tabindex="@(open is not null ? "0" : null)"
                                @onclick="() => open?.Invoke()"
                                @onkeydown="e => OnHitRowKeyDown(e, open)">
                                <td><span class="badge text-bg-light">@HitKindLabel(h.Kind)</span></td>
                                <td>@h.Name</td>
                                <td class="small text-body-secondary">@h.Location</td>
                                <td class="text-end">
                                    @if (open is not null)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2"
                                                aria-label="Show @h.Name (@h.Location)"
                                                @onclick="open" @onclick:stopPropagation="true">Show</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            break;
        }

        case View.Strings:
        {
            var filtered = FilteredStrings.ToList();
            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-5">
                    <label class="form-label small mb-1">Chunk</label>
                    <select class="form-select form-select-sm" @onchange="OnChunkChanged">
                        @for (var i = 0; i < _chunkChoices.Count; i++)
                        {
                            var (chunk, depth) = _chunkChoices[i];
                            <option value="@i" selected="@(ReferenceEquals(chunk, _selectedChunk))">
                                @(new string(' ', depth * 3))@chunk.Id — @PcgChunkInfo.Describe(chunk.Id) (@Format.Bytes(chunk.Size))
                            </option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Min length</label>
                    <input type="number" min="1" max="64" class="form-control form-control-sm"
                           value="@_minLen" @onchange="OnMinLenChanged" />
                </div>
                <div class="col-6 col-md-4">
                    <label class="form-label small mb-1">Search</label>
                    <input type="text" class="form-control form-control-sm" placeholder="filter…"
                           @bind="_search" @bind:event="oninput" />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-body-secondary small">
                    @filtered.Count string(s)@(filtered.Count > MaxRows ? $" — showing first {MaxRows}" : "")
                </div>
                <div class="btn-group">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportStringsCsv">CSV</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportStringsJson">JSON</button>
                </div>
            </div>

            <table class="table table-sm table-hover font-monospace small">
                <thead><tr><th style="width:9rem">Offset</th><th>Text</th></tr></thead>
                <tbody>
                    @foreach (var s in filtered.Take(MaxRows))
                    {
                        <tr>
                            <td class="text-body-secondary">@Format.Hex(s.Offset)</td>
                            <td>@s.Value</td>
                        </tr>
                    }
                </tbody>
            </table>
            break;
        }

        case View.Tree:
        {
            <p class="text-body-secondary">Full chunk hierarchy — click a row to expand or collapse.</p>
            @foreach (var top in _pcg.TopLevel)
            {
                <ChunkNode Chunk="top" Open="true" />
            }
            break;
        }
    }
}

@code {
    enum View { Home, SetLists, Combis, Programs, Copy, Differences, Usage, Duplicates, Search, AddSounds, Overview, Strings, Tree }
    enum UsageSort { BankNumber, Name, MostUsed }
    enum CrossKind { Programs, Combis, SetListSlots }

    const long MaxFileSize = 256L * 1024 * 1024; // OpenReadStream ceiling
    const int MaxRows = 1000;                    // cap rendered string rows

    PcgFile? _pcg;
    string? _fileName;
    string? _error;
    bool _loading;
    View _view = View.Home;

    List<(PcgChunk Chunk, int Depth)> _chunkChoices = new();
    PcgChunk? _selectedChunk;
    int _minLen = 3;
    string _search = string.Empty;
    string _nameQuery = string.Empty;
    List<PcgString> _stringsForChunk = new();
    List<SetList> _setLists = new();
    PcgCatalog? _catalog;
    int _selectedSetList;
    bool _showEmptySlots;

    // Editing state
    bool _editMode;
    bool _dirty;
    (int SetList, int Slot)? _copySource;
    string _copySourceName = string.Empty;

    // Slot notes / re-point panels (one of each open at a time)
    int? _descSlot;
    int? _colorSlot;
    int? _repointSlot;
    PcgItemKind _repointKind = PcgItemKind.Combi;
    int _repointBank;
    int _repointIndex;

    // Combi reorganization state
    int _selectedCombiBank;
    (int Bank, int Index)? _combiCopySource;
    string _combiCopySourceName = string.Empty;
    IReadOnlyDictionary<(int Bank, int Index), int> _combiRefCounts = new Dictionary<(int, int), int>();
    UsageReport? _usageReport;

    // Program reorganization state
    int _selectedProgramBank;
    (int Bank, int Index)? _programCopySource;
    string _programCopySourceName = string.Empty;

    // Find / sort navigation aids (per-tab)
    string _programFilter = string.Empty;
    string _combiFilter = string.Empty;
    string _usageFilter = string.Empty;
    int _usageBankFilter = -1;                 // -1 = all banks
    UsageSort _usageSort = UsageSort.BankNumber;

    // Cross-file copy state (the main file is the destination; the source is read-only)
    PcgFile? _srcPcg;
    string? _srcFileName;
    string? _srcError;
    bool _srcLoading;
    PcgCatalog? _srcCatalog;
    List<SetList> _srcSetLists = new();
    CrossKind _crossKind = CrossKind.Programs;
    int _crossSrcBank;                          // source bank (or set-list index)
    string _crossFilter = string.Empty;
    (int Bank, int Index, string Name)? _crossSelection;
    Combi? _crossSelectedCombi;                 // timbre preview for a selected combi
    int _crossDstBank;
    int _crossDstIndex;
    string? _crossLastCopy;
    PcgDiffReport? _diffReport;                 // Differences tab cache; rebuilt after any edit

    IEnumerable<PcgString> FilteredStrings =>
        string.IsNullOrWhiteSpace(_search)
            ? _stringsForChunk
            : _stringsForChunk.Where(s => s.Value.Contains(_search, StringComparison.OrdinalIgnoreCase));

    // Built on first view of the Usage tab and cached until the next edit / file load.
    UsageReport CurrentUsage => _usageReport ??= PcgUsage.BuildUsageReport(_pcg!);

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        if (e.File.Name.EndsWith(".KGE", StringComparison.OrdinalIgnoreCase))
        {
            await LoadKge(e);
            return;
        }
        _error = null;
        _pcg = null;
        _fileName = e.File.Name;
        _loading = true;
        try
        {
            using var ms = new MemoryStream();
            await using (var stream = e.File.OpenReadStream(MaxFileSize))
            {
                await stream.CopyToAsync(ms);
            }

            _pcg = PcgReader.Parse(ms.ToArray());
            _view = View.Home; // land on the task cards: "what would you like to do?"
            _showAdvanced = false;
            _showMoreCards = false;
            _dirty = false;
            _editMode = false;
            _copySource = null;
            _combiCopySource = null;
            _programCopySource = null;
            _programFilter = _combiFilter = _usageFilter = string.Empty;
            _usageBankFilter = -1;
            _usageSort = UsageSort.BankNumber;
            LoadDerived(preserveSelection: false);
        }
        catch (Exception ex)
        {
            _error = $"Could not parse '{_fileName}': {ex.Message}";
            Logger.LogWarning(ex, "Failed to parse PCG {File}", _fileName);
        }
        finally
        {
            _loading = false;
        }
    }

    void LoadDerived(bool preserveSelection)
    {
        if (_pcg is null) return;

        _chunkChoices = _pcg.Flatten().ToList();
        _selectedChunk = _pcg.FindFirst("SDB1") ?? _pcg.FindFirst("SLS1") ?? _pcg.TopLevel.FirstOrDefault();
        RefreshStrings();

        _setLists = SetListReader.Read(_pcg).ToList();
        _catalog = PcgCatalog.Build(_pcg);
        _programInfos = ProgramReader.Read(_pcg).ToDictionary(p => (p.Bank, p.Index));
        _combiRefCounts = PcgUsage.CombiReferenceCounts(_setLists);
        _usageReport = null;  // rebuilt lazily the next time the Usage tab is viewed
        _diffReport = null;   // likewise for the Differences tab
        _crossDeepPlan = null; // free slots / records may have changed
        _addPlan = null;       // wizard plan too
        _timbreCombi = null;  // combi records may have moved
        _timbreDetail = null;
        _slotDetailSlot = null;  // likewise for the set-list slot panel
        _slotDetailCombi = null;

        if (preserveSelection)
        {
            _selectedSetList = Math.Clamp(_selectedSetList, 0, Math.Max(0, _setLists.Count - 1));
        }
        else
        {
            _selectedSetList = _setLists.FindIndex(s => s.NamedSlots.Any());
            if (_selectedSetList < 0) _selectedSetList = 0;
            _selectedCombiBank = 0;
            _selectedProgramBank = 0;
        }
        // Either way, land on a bank the file carries (partial files skip banks).
        _selectedCombiBank = SnapToPresent(_selectedCombiBank, _catalog.CombiBanks);
        _selectedProgramBank = SnapToPresent(_selectedProgramBank, _catalog.ProgramBanks);
        _crossDeepHd1Bank = SanitizeDeepBank(_crossDeepHd1Bank, ProgramBankType.Hd1);
        _crossDeepExiBank = SanitizeDeepBank(_crossDeepExiBank, ProgramBankType.Exi);
    }

    // Applies an edit (a new byte image) and refreshes, staying on the current set list.
    void ApplyEdit(byte[] newData)
    {
        _pcg = PcgReader.Parse(newData);
        _dirty = true;
        LoadDerived(preserveSelection: true);
    }

    void RefreshStrings()
    {
        _stringsForChunk = _pcg is null || _selectedChunk is null
            ? new List<PcgString>()
            : PcgStrings.Extract(_pcg.Data, _selectedChunk, _minLen).ToList();
    }

    void OnChunkChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < _chunkChoices.Count)
        {
            _selectedChunk = _chunkChoices[idx].Chunk;
            RefreshStrings();
        }
    }

    void OnMinLenChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _minLen = Math.Clamp(v, 1, 64);
            RefreshStrings();
        }
    }

    IEnumerable<PcgChunk> TopLevelSections()
    {
        if (_pcg is null) return Enumerable.Empty<PcgChunk>();
        return _pcg.TopLevel.Count == 1 && _pcg.TopLevel[0].HasChildren
            ? _pcg.TopLevel[0].Children
            : _pcg.TopLevel;
    }

    // Fixed per-section tints for the anatomy strip — theme vars so both themes read.
    static string SectionColor(string id) => id switch
    {
        "SLS1" => "rgba(var(--pcg-wave-rgb), 0.55)",
        "PRG1" => "rgba(var(--bs-primary-rgb), 0.45)",
        "CMB1" => "rgba(var(--bs-primary-rgb), 0.75)",
        "DKT1" => "rgba(var(--bs-emphasis-color-rgb), 0.25)",
        "WSQ1" => "rgba(var(--bs-emphasis-color-rgb), 0.45)",
        "GLB1" => "rgba(var(--bs-warning-rgb), 0.6)",
        "DIV1" => "rgba(var(--bs-emphasis-color-rgb), 0.15)",
        _ => "rgba(var(--bs-emphasis-color-rgb), 0.35)",
    };

    // Workspaces a musician doesn't need on day one — folded behind "More".
    static readonly View[] AdvancedViews = { View.Copy, View.Differences, View.Usage, View.Duplicates, View.Overview, View.Strings, View.Tree };

    // Views reachable from Start cards (or in-flow links) only — no tab of their own.
    static readonly View[] HiddenViews = { View.AddSounds };
    bool _showAdvanced;
    bool _showMoreCards;

    // ----- Start page: task cards in musician language, each opening a workspace -----

    sealed record TaskCardDef(string Title, string Blurb, string IconPaths, Action Open);

    // Icon path data from Bootstrap Icons (MIT) — inline so no icon font is needed.
    // The primary three answer "where do I start?"; the rest live behind "More you can do".
    TaskCardDef[] PrimaryTaskCards() => new[]
    {
