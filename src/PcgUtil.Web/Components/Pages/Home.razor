@page "/"
@rendermode InteractiveServer
@using System.Text
@using PcgUtil.Core
@inject IJSRuntime JS
@inject ILogger<Home> Logger

<PageTitle>PCG Util</PageTitle>

<h1 class="mb-3">PCG Util</h1>

<p class="text-body-secondary">
    Upload a <code>.PCG</code> file to inspect its chunk structure and embedded names
    (Set Lists, Programs, Combis, Drum Kits, Wave Sequences, Global). The file is parsed in
    server memory and is not saved to disk.
</p>

<div class="card mb-4">
    <div class="card-body">
        <label class="form-label fw-semibold">Choose a .PCG file</label>
        <InputFile OnChange="OnFileSelected" accept=".PCG,.pcg" class="form-control" />
        @if (_loading)
        {
            <div class="mt-2 text-body-secondary">
                <span class="spinner-border spinner-border-sm" role="status"></span>
                Reading and parsing @_fileName …
            </div>
        }
        @if (_error is not null)
        {
            <div class="alert alert-danger mt-3 mb-0">@_error</div>
        }
    </div>
</div>

@if (_pcg is not null)
{
    <ul class="nav nav-tabs mb-3">
        @foreach (var tab in Enum.GetValues<View>().Where(t => !AdvancedViews.Contains(t)))
        {
            <li class="nav-item">
                <button type="button" class="nav-link @(_view == tab ? "active" : null)"
                        @onclick="() => _view = tab">
                    @TabLabel(tab)
                </button>
            </li>
        }
        @{ var advancedOpen = _showAdvanced || AdvancedViews.Contains(_view); }
        <li class="nav-item">
            <button type="button" class="nav-link text-body-secondary"
                    title="File internals — chunk structure, raw strings"
                    @onclick="() => _showAdvanced = !advancedOpen">
                @(advancedOpen ? "Advanced ▾" : "Advanced ▸")
            </button>
        </li>
        @if (advancedOpen)
        {
            @foreach (var tab in AdvancedViews)
            {
                <li class="nav-item">
                    <button type="button" class="nav-link @(_view == tab ? "active" : null)"
                            @onclick="() => _view = tab">
                        @TabLabel(tab)
                    </button>
                </li>
            }
        }
    </ul>

    @switch (_view)
    {
        case View.Overview:
        {
            <div class="row g-3 mb-4">
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">File</div>
                        <div class="fw-semibold text-truncate" title="@_fileName">@_fileName</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">Size</div>
                        <div class="fw-semibold">@Format.Bytes(_pcg.Length)</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">Signature</div>
                        <div class="fw-semibold">@_pcg.Magic</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-3 h-100">
                        <div class="text-body-secondary small">Total chunks</div>
                        <div class="fw-semibold">@_pcg.EnumerateChunks().Count()</div>
                    </div>
                </div>
            </div>

            <h2 class="h5">Top-level sections</h2>
            <table class="table table-sm table-striped align-middle">
                <thead>
                    <tr><th>Chunk</th><th>Contents</th><th class="text-end">Size</th><th class="text-end">Banks</th></tr>
                </thead>
                <tbody>
                    @foreach (var section in TopLevelSections())
                    {
                        <tr>
                            <td><code>@section.Id</code></td>
                            <td>@PcgChunkInfo.Describe(section.Id)</td>
                            <td class="text-end">@Format.Bytes(section.Size)</td>
                            <td class="text-end">@(section.HasChildren ? section.Children.Count.ToString() : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
            break;
        }

        case View.SetLists:
        {
            if (_setLists.Count == 0)
            {
                <p class="text-body-secondary">No Set Lists found (this file has no <code>SBK1</code> chunk).</p>
            }
            else
            {
                var sl = _setLists[_selectedSetList];
                var slots = (_editMode || _showEmptySlots ? sl.Slots : sl.NamedSlots).ToList();

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-7">
                        <label class="form-label small mb-1">Set List</label>
                        <select class="form-select form-select-sm" @onchange="OnSetListChanged">
                            @for (var i = 0; i < _setLists.Count; i++)
                            {
                                var item = _setLists[i];
                                var songs = item.NamedSlots.Count();
                                <option value="@i" selected="@(i == _selectedSetList)">
                                    @i.ToString("D3") — @item.DisplayName (@songs song@(songs == 1 ? "" : "s"))
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-5 d-flex gap-3 align-items-center pt-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="editMode" @bind="_editMode" />
                            <label class="form-check-label small" for="editMode">Edit mode</label>
                        </div>
                        @if (!_editMode)
                        {
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="showEmpty" @bind="_showEmptySlots" />
                                <label class="form-check-label small" for="showEmpty">Show empty slots</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    @if (_editMode)
                    {
                        <input class="form-control form-control-sm fw-semibold" style="max-width:22rem" maxlength="24"
                               value="@sl.Name" placeholder="(set list name)"
                               @onchange="@(e => RenameCurrentSetList(e.Value?.ToString()))" />
                    }
                    else
                    {
                        <h2 class="h5 mb-0">@sl.DisplayName</h2>
                    }
                    <div class="d-flex gap-2">
                        @if (_dirty)
                        {
                            <button type="button" class="btn btn-sm btn-success" @onclick="DownloadEditedPcg">Download edited .PCG</button>
                        }
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportCurrentSetListCsv">CSV: this</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportAllSetListsCsv">CSV: all</button>
                        </div>
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportCurrentSetListHtml">Print: this</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportAllSetListsHtml">Print: all</button>
                        </div>
                    </div>
                </div>

                @if (_dirty)
                {
                    <p class="text-success small mb-2">
                        Unsaved edits held in memory — click <strong>Download edited .PCG</strong> to save a new file. The uploaded file is never modified.
                    </p>
                }

                @if (_copySource is not null)
                {
                    <div class="alert alert-info d-flex justify-content-between align-items-center py-1 px-2 small">
                        <span>Copying <strong>@_copySourceName</strong> — click <em>Paste</em> on a target slot.</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _copySource = null">Cancel</button>
                    </div>
                }

                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:4rem">Slot</th>
                            <th>Name</th>
                            <th>Loads</th>
                            @if (_editMode)
                            {
                                <th style="width:20rem">Edit</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in slots)
                        {
                            <tr @key="slot.Index" class="@(slot.IsEmpty ? "text-body-secondary" : null)">
                                <td>@slot.Index.ToString("D3")</td>
                                <td>
                                    @if (_editMode)
                                    {
                                        <input class="form-control form-control-sm" maxlength="24" placeholder="(empty)"
                                               value="@slot.Name" @onchange="@(e => RenameSlot(slot.Index, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        @(slot.IsEmpty ? "—" : slot.Name)
                                        @if (!string.IsNullOrEmpty(slot.Description))
                                        {
                                            <div class="small text-body-secondary" style="white-space:pre-line">@slot.Description</div>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (!slot.IsEmpty || _editMode)
                                    {
                                        var target = _catalog?.Resolve(slot.Reference);
                                        <span class="badge text-bg-light">@slot.Reference.Kind</span>
                                        <span class="text-body-secondary small">@SlotBankLabel(slot.Reference) · #@slot.Reference.Index.ToString("D3")</span>
                                        @if (target is not null)
                                        {
                                            <span> — @target</span>
                                        }
                                    }
                                </td>
                                @if (_editMode)
                                {
                                    <td class="text-nowrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move up"
                                                disabled="@(slot.Index == 0)" @onclick="() => MoveSlot(slot.Index, -1)">▲</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move down"
                                                disabled="@(slot.Index >= sl.Slots.Count - 1)" @onclick="() => MoveSlot(slot.Index, 1)">▼</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Copy this slot"
                                                @onclick="() => StartCopy(slot)">Copy</button>
                                        <button type="button" class="btn btn-sm @(_descSlot == slot.Index ? "btn-secondary" : "btn-outline-secondary") px-2"
                                                title="Edit this slot's notes (shown on the device and printed set lists)"
                                                @onclick="() => ToggleDescEditor(slot.Index)">Notes</button>
                                        <button type="button" class="btn btn-sm @(_repointSlot == slot.Index ? "btn-secondary" : "btn-outline-secondary") px-2"
                                                title="Change which Program/Combi this slot loads"
                                                @onclick="() => ToggleRepoint(slot)">Load</button>
                                        @if (_copySource is not null)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary px-2" title="Paste here"
                                                    @onclick="() => PasteInto(slot.Index)">Paste</button>
                                        }
                                    </td>
                                }
                            </tr>
                            @if (_editMode && _descSlot == slot.Index)
                            {
                                <tr @key="@($"desc-{slot.Index}")">
                                    <td></td>
                                    <td colspan="3">
                                        <label class="form-label small mb-1">
                                            Notes for slot @slot.Index.ToString("D3")
                                            <span class="text-body-secondary">— up to 512 chars, line breaks OK; shows on the device and printed set lists</span>
                                        </label>
                                        <textarea class="form-control form-control-sm" rows="3" maxlength="512"
                                                  value="@slot.Description"
                                                  @onchange="@(e => SetSlotDescription(slot.Index, e.Value?.ToString()))"></textarea>
                                    </td>
                                </tr>
                            }
                            @if (_editMode && _repointSlot == slot.Index)
                            {
                                <tr @key="@($"repoint-{slot.Index}")">
                                    <td></td>
                                    <td colspan="3">
                                        <div class="d-flex align-items-end gap-2 flex-wrap">
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-sm @(_repointKind == PcgItemKind.Combi ? "btn-secondary" : "btn-outline-secondary")"
                                                        @onclick="() => SetRepointKind(PcgItemKind.Combi)">Combi</button>
                                                <button type="button" class="btn btn-sm @(_repointKind == PcgItemKind.Program ? "btn-secondary" : "btn-outline-secondary")"
                                                        @onclick="() => SetRepointKind(PcgItemKind.Program)">Program</button>
                                            </div>
                                            <div>
                                                <label class="form-label small mb-1">Bank</label>
                                                <select class="form-select form-select-sm" @onchange="OnRepointBankChanged">
                                                    @if (_repointKind == PcgItemKind.Program)
                                                    {
                                                        @for (var i = 0; i < _catalog!.ProgramBanks.Count; i++)
                                                        {
                                                            <option value="@i" selected="@(i == _repointBank)">@PcgBankLabels.Program(i)</option>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @for (var i = 0; i < _catalog!.CombiBanks.Count; i++)
                                                        {
                                                            <option value="@i" selected="@(i == _repointBank)">@PcgBankLabels.Combi(i)</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div>
                                                <label class="form-label small mb-1">Patch</label>
                                                <select class="form-select form-select-sm" style="max-width:20rem" @onchange="OnRepointIndexChanged">
                                                    @{
                                                        var repointNames = _repointKind == PcgItemKind.Program
                                                            ? _catalog!.ProgramBanks[_repointBank]
                                                            : _catalog!.CombiBanks[_repointBank];
                                                    }
                                                    @for (var i = 0; i < repointNames.Count; i++)
                                                    {
                                                        <option value="@i" selected="@(i == _repointIndex)">@i.ToString("D3") — @(string.IsNullOrEmpty(repointNames[i]) ? "(empty)" : repointNames[i])</option>
                                                    }
                                                </select>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-primary" @onclick="ApplyRepoint">Load this</button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _repointSlot = null">Cancel</button>
                                        </div>
                                        <div class="small text-body-secondary mt-1">Changes what the slot loads — its name and notes stay put.</div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <p class="text-body-secondary small">
                    "Loads" is the Program/Combi each slot recalls. In <strong>Edit mode</strong> you can rename, reorder
                    (▲▼), and copy slots; changes accumulate in memory until you Download edited .PCG.
                </p>
            }
            break;
        }

        case View.Combis:
        {
            if (_catalog is null || _catalog.CombiBanks.Count == 0)
            {
                <p class="text-body-secondary">No Combis found (this file has no <code>CMB1</code> chunk).</p>
            }
            else
            {
                var bank = _catalog.CombiBanks[_selectedCombiBank];
                var rows = Enumerable.Range(0, bank.Count)
                    .Where(i => _editMode || _showEmptySlots || !string.IsNullOrEmpty(bank[i]))
                    .Where(i => MatchesFilter(bank[i], i, _combiFilter))
                    .ToList();

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-5">
                        <label class="form-label small mb-1">Combi bank</label>
                        <select class="form-select form-select-sm" @onchange="OnCombiBankChanged">
                            @for (var i = 0; i < _catalog.CombiBanks.Count; i++)
                            {
                                <option value="@i" selected="@(i == _selectedCombiBank)">
                                    @PcgBankLabels.Combi(i) (@CountNonEmpty(_catalog.CombiBanks[i]) combis)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Find</label>
                        <input type="text" class="form-control form-control-sm" placeholder="name or #…"
                               @bind="_combiFilter" @bind:event="oninput" />
                    </div>
                    <div class="col-md-4 d-flex gap-3 align-items-center pt-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="combiEdit" @bind="_editMode" />
                            <label class="form-check-label small" for="combiEdit">Edit mode</label>
                        </div>
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="combiShowEmpty" @bind="_showEmptySlots" />
                            <label class="form-check-label small" for="combiShowEmpty">Show empty</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    <h2 class="h5 mb-0">Combi bank @PcgBankLabels.Combi(_selectedCombiBank)</h2>
                    <div class="d-flex gap-2">
                        @if (_editMode)
                        {
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Sort this bank by name (A–Z, init/empty slots last) — references follow"
                                        @onclick="SortCombiBank">Sort A–Z</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Push init/empty slots to the end — references follow"
                                        @onclick="CompactCombiBank">Compact</button>
                            </div>
                        }
                        @if (_dirty)
                        {
                            <button type="button" class="btn btn-sm btn-success" @onclick="DownloadEditedPcg">Download edited .PCG</button>
                        }
                    </div>
                </div>

                @if (_dirty)
                {
                    <p class="text-success small mb-2">
                        Unsaved edits held in memory — click <strong>Download edited .PCG</strong> to save a new file. The uploaded file is never modified.
                    </p>
                }

                @if (!string.IsNullOrWhiteSpace(_combiFilter))
                {
                    <div class="text-body-secondary small mb-2">
                        @rows.Count match@(rows.Count == 1 ? "" : "es") for "@_combiFilter" in this bank
                        <button type="button" class="btn btn-link btn-sm p-0 ms-1 align-baseline"
                                @onclick="@(() => _combiFilter = string.Empty)">clear</button>
                    </div>
                }

                @if (_combiCopySource is not null)
                {
                    <div class="alert alert-info d-flex justify-content-between align-items-center py-1 px-2 small">
                        <span>Copying combi <strong>@_combiCopySourceName</strong> — click <em>Paste</em> on a target.</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _combiCopySource = null">Cancel</button>
                    </div>
                }

                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:4rem">#</th>
                            <th>Name</th>
                            <th style="width:6rem" title="Set-list slots that load this combi">Used by</th>
                            @if (_editMode)
                            {
                                <th style="width:13rem">Edit</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var idx in rows)
                        {
                            var name = bank[idx];
                            var isEmpty = string.IsNullOrEmpty(name);
                            var refs = _combiRefCounts.GetValueOrDefault((_selectedCombiBank, idx));
                            <tr @key="idx" class="@(isEmpty ? "text-body-secondary" : null)">
                                <td>@idx.ToString("D3")</td>
                                <td>
                                    @if (_editMode)
                                    {
                                        <input class="form-control form-control-sm" maxlength="24" placeholder="(empty)"
                                               value="@name" @onchange="@(e => RenameCombiAt(idx, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        @(isEmpty ? "—" : name)
                                    }
                                </td>
                                <td>@(refs > 0 ? refs.ToString() : "")</td>
                                @if (_editMode)
                                {
                                    <td class="text-nowrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move up"
                                                disabled="@(idx == 0)" @onclick="() => MoveCombi(idx, -1)">▲</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move down"
                                                disabled="@(idx >= bank.Count - 1)" @onclick="() => MoveCombi(idx, 1)">▼</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Copy this combi"
                                                @onclick="() => StartCombiCopy(idx)">Copy</button>
                                        @if (_combiCopySource is not null)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary px-2" title="Paste here"
                                                    @onclick="() => PasteCombiInto(idx)">Paste</button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
                <p class="text-body-secondary small">
                    Reorder (▲▼) swaps two combis and automatically retargets the set-list slots that use them, so your
                    songs keep their sound. "Used by" is how many set-list slots load each combi. Copy overwrites the target.
                    <strong>Sort A–Z</strong> / <strong>Compact</strong> reorganize the whole bank (init/empty slots go last),
                    retargeting references the same way. Use <strong>Find</strong> to jump to a combi by name or number;
                    clear it before reordering so you can see the neighbour a swap will hit.
                </p>
            }
            break;
        }

        case View.Programs:
        {
            if (_catalog is null || _catalog.ProgramBanks.Count == 0)
            {
                <p class="text-body-secondary">No Programs found (this file has no <code>PRG1</code> chunk).</p>
            }
            else
            {
                var bank = _catalog.ProgramBanks[_selectedProgramBank];
                var refCounts = CurrentUsage.Programs.ToDictionary(p => (p.BankIndex, p.Number), p => p.ReferenceCount);
                var rows = Enumerable.Range(0, bank.Count)
                    .Where(i => _editMode || _showEmptySlots || !string.IsNullOrEmpty(bank[i]))
                    .Where(i => MatchesFilter(bank[i], i, _programFilter))
                    .ToList();

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-5">
                        <label class="form-label small mb-1">Program bank</label>
                        <select class="form-select form-select-sm" @onchange="OnProgramBankChanged">
                            @for (var i = 0; i < _catalog.ProgramBanks.Count; i++)
                            {
                                <option value="@i" selected="@(i == _selectedProgramBank)">
                                    @PcgBankLabels.Program(i) (@CountNonEmpty(_catalog.ProgramBanks[i]) programs)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Find</label>
                        <input type="text" class="form-control form-control-sm" placeholder="name or #…"
                               @bind="_programFilter" @bind:event="oninput" />
                    </div>
                    <div class="col-md-4 d-flex gap-3 align-items-center pt-3">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="programEdit" @bind="_editMode" />
                            <label class="form-check-label small" for="programEdit">Edit mode</label>
                        </div>
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="programShowEmpty" @bind="_showEmptySlots" />
                            <label class="form-check-label small" for="programShowEmpty">Show empty</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    <h2 class="h5 mb-0">Program bank @PcgBankLabels.Program(_selectedProgramBank)</h2>
                    <div class="d-flex gap-2">
                        @if (_editMode)
                        {
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Sort this bank by name (A–Z, init/empty slots last) — references follow"
                                        @onclick="SortProgramBank">Sort A–Z</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        title="Push init/empty slots to the end — references follow"
                                        @onclick="CompactProgramBank">Compact</button>
                            </div>
                        }
                        @if (_dirty)
                        {
                            <button type="button" class="btn btn-sm btn-success" @onclick="DownloadEditedPcg">Download edited .PCG</button>
                        }
                    </div>
                </div>

                @if (_dirty)
                {
                    <p class="text-success small mb-2">
                        Unsaved edits held in memory — click <strong>Download edited .PCG</strong> to save a new file. The uploaded file is never modified.
                    </p>
                }

                @if (!string.IsNullOrWhiteSpace(_programFilter))
                {
                    <div class="text-body-secondary small mb-2">
                        @rows.Count match@(rows.Count == 1 ? "" : "es") for "@_programFilter" in this bank
                        <button type="button" class="btn btn-link btn-sm p-0 ms-1 align-baseline"
                                @onclick="@(() => _programFilter = string.Empty)">clear</button>
                    </div>
                }

                @if (_programCopySource is not null)
                {
                    <div class="alert alert-info d-flex justify-content-between align-items-center py-1 px-2 small">
                        <span>Copying program <strong>@_programCopySourceName</strong> — click <em>Paste</em> on a target.</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _programCopySource = null">Cancel</button>
                    </div>
                }

                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width:4rem">#</th>
                            <th>Name</th>
                            <th style="width:6rem" title="Combi timbres + program-type set-list slots that use this program">Used by</th>
                            @if (_editMode)
                            {
                                <th style="width:13rem">Edit</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var idx in rows)
                        {
                            var name = bank[idx];
                            var isEmpty = string.IsNullOrEmpty(name);
                            var refs = refCounts.GetValueOrDefault((_selectedProgramBank, idx));
                            <tr @key="idx" class="@(isEmpty ? "text-body-secondary" : null)">
                                <td>@idx.ToString("D3")</td>
                                <td>
                                    @if (_editMode)
                                    {
                                        <input class="form-control form-control-sm" maxlength="24" placeholder="(empty)"
                                               value="@name" @onchange="@(e => RenameProgramAt(idx, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        @(isEmpty ? "—" : name)
                                    }
                                </td>
                                <td>@(refs > 0 ? refs.ToString() : "")</td>
                                @if (_editMode)
                                {
                                    <td class="text-nowrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move up"
                                                disabled="@(idx == 0)" @onclick="() => MoveProgram(idx, -1)">▲</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Move down"
                                                disabled="@(idx >= bank.Count - 1)" @onclick="() => MoveProgram(idx, 1)">▼</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2" title="Copy this program"
                                                @onclick="() => StartProgramCopy(idx)">Copy</button>
                                        @if (_programCopySource is not null)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary px-2" title="Paste here"
                                                    @onclick="() => PasteProgramInto(idx)">Paste</button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
                <p class="text-body-secondary small">
                    Reorder (▲▼) swaps two programs and automatically retargets the combi timbres and set-list slots that
                    use them, so your sounds stay intact. "Used by" counts those references. Copy overwrites the target.
                    <strong>Sort A–Z</strong> / <strong>Compact</strong> reorganize the whole bank (init/empty slots go last),
                    retargeting references the same way. Use <strong>Find</strong> to jump to a program by name or number;
                    clear it before reordering so you can see the neighbour a swap will hit.
                </p>
            }
            break;
        }

        case View.Copy:
        {
            <h2 class="h5">Copy between files</h2>
            <p class="text-body-secondary small">
                Open a second <code>.PCG</code> as a read-only <strong>source</strong>, then copy programs,
                combis, or set-list slots into the file you're editing. A copy <strong>overwrites</strong> the
                destination slot you choose; edits accumulate in memory until you download the edited .PCG.
            </p>

            <div class="row g-3 mb-3">
                <div class="col-lg-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                            <span class="text-body-secondary small">Destination — your main file</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary" title="Save an unmodified copy under a new name"
                                    @onclick="DownloadDestinationCopy">Download a copy</button>
                        </div>
                        <div class="fw-semibold text-truncate" title="@_fileName">@_fileName</div>
                        <div class="text-body-secondary small">@Format.Bytes(_pcg.Length)@(_dirty ? " — has unsaved edits" : "")</div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="border rounded p-3 h-100">
                        @if (_srcPcg is null)
                        {
                            <label class="form-label small fw-semibold mb-1">Source — choose a second .PCG to copy from</label>
                            <InputFile OnChange="OnSourceFileSelected" accept=".PCG,.pcg" class="form-control form-control-sm" />
                            @if (_srcLoading)
                            {
                                <div class="mt-2 text-body-secondary small">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Reading and parsing @_srcFileName …
                                </div>
                            }
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                                <span class="text-body-secondary small">Source — read-only</span>
                                <span class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="DownloadSourceCopy">Download a copy</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearSource">Clear</button>
                                </span>
                            </div>
                            <div class="fw-semibold text-truncate" title="@_srcFileName">@_srcFileName</div>
                            <div class="text-body-secondary small">@Format.Bytes(_srcPcg.Length)</div>
                        }
                        @if (_srcError is not null)
                        {
                            <div class="alert alert-danger mt-2 mb-0 py-1 px-2 small">@_srcError</div>
                        }
                    </div>
                </div>
            </div>

            @if (_dirty)
            {
                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    <p class="text-success small mb-0">
                        Unsaved edits held in memory — click <strong>Download edited .PCG</strong> to save a new file.
                    </p>
                    <button type="button" class="btn btn-sm btn-success" @onclick="DownloadEditedPcg">Download edited .PCG</button>
                </div>
            }

            @if (_srcPcg is not null && _srcCatalog is not null)
            {
                var compat = PcgCompat.Compare(_srcPcg, _pcg);
                if (!compat.AllMatch)
                {
                    <div class="alert alert-danger">
                        <strong>Record layouts differ</strong> (@compat.MismatchSummary) — these files don't appear
                        to be from the same model, so copying is disabled.
                    </div>
                }
                else
                {
                    var srcRows = CrossSourceRows();

                    <div class="d-flex align-items-end gap-2 flex-wrap mb-2">
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm @(_crossKind == CrossKind.Programs ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="() => SetCrossKind(CrossKind.Programs)">Programs</button>
                            <button type="button" class="btn btn-sm @(_crossKind == CrossKind.Combis ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="() => SetCrossKind(CrossKind.Combis)">Combis</button>
                            <button type="button" class="btn btn-sm @(_crossKind == CrossKind.SetListSlots ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="() => SetCrossKind(CrossKind.SetListSlots)">Set-list slots</button>
                        </div>
                        <div>
                            <label class="form-label small mb-1">@(_crossKind == CrossKind.SetListSlots ? "Source set list" : "Source bank")</label>
                            <select class="form-select form-select-sm" @onchange="OnCrossSrcBankChanged">
                                @if (_crossKind == CrossKind.Programs)
                                {
                                    @for (var i = 0; i < _srcCatalog.ProgramBanks.Count; i++)
                                    {
                                        <option value="@i" selected="@(i == _crossSrcBank)">@PcgBankLabels.Program(i) (@CountNonEmpty(_srcCatalog.ProgramBanks[i]))</option>
                                    }
                                }
                                else if (_crossKind == CrossKind.Combis)
                                {
                                    @for (var i = 0; i < _srcCatalog.CombiBanks.Count; i++)
                                    {
                                        <option value="@i" selected="@(i == _crossSrcBank)">@PcgBankLabels.Combi(i) (@CountNonEmpty(_srcCatalog.CombiBanks[i]))</option>
                                    }
                                }
                                else
                                {
                                    @for (var i = 0; i < _srcSetLists.Count; i++)
                                    {
                                        <option value="@i" selected="@(i == _crossSrcBank)">@i.ToString("D3") — @_srcSetLists[i].DisplayName (@_srcSetLists[i].NamedSlots.Count())</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="form-label small mb-1">Find</label>
                            <input type="text" class="form-control form-control-sm" placeholder="name or #…"
                                   @bind="_crossFilter" @bind:event="oninput" />
                        </div>
                    </div>

                    @if (_crossSelection is { } sel)
                    {
                        <div class="alert alert-info">
                            <div class="d-flex align-items-end gap-2 flex-wrap">
                                <div class="me-2 pb-1">
                                    Copy <strong>@sel.Name</strong>
                                    <span class="text-body-secondary small">(@CrossSrcLabel(sel.Bank) #@sel.Index.ToString("D3"))</span> to:
                                </div>
                                <div>
                                    <label class="form-label small mb-1">@(_crossKind == CrossKind.SetListSlots ? "Set list" : "Bank")</label>
                                    <select class="form-select form-select-sm" @onchange="OnCrossDstBankChanged">
                                        @if (_crossKind == CrossKind.Programs)
                                        {
                                            @for (var i = 0; i < _catalog!.ProgramBanks.Count; i++)
                                            {
                                                <option value="@i" selected="@(i == _crossDstBank)">@PcgBankLabels.Program(i)</option>
                                            }
                                        }
                                        else if (_crossKind == CrossKind.Combis)
                                        {
                                            @for (var i = 0; i < _catalog!.CombiBanks.Count; i++)
                                            {
                                                <option value="@i" selected="@(i == _crossDstBank)">@PcgBankLabels.Combi(i)</option>
                                            }
                                        }
                                        else
                                        {
                                            @for (var i = 0; i < _setLists.Count; i++)
                                            {
                                                <option value="@i" selected="@(i == _crossDstBank)">@i.ToString("D3") — @_setLists[i].DisplayName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small mb-1">Slot <span class="text-body-secondary">(current occupant shown)</span></label>
                                    <select class="form-select form-select-sm" style="max-width:22rem" @onchange="OnCrossDstIndexChanged">
                                        @if (_crossKind == CrossKind.SetListSlots)
                                        {
                                            @foreach (var slot in _setLists[_crossDstBank].Slots)
                                            {
                                                <option value="@slot.Index" selected="@(slot.Index == _crossDstIndex)">@slot.Index.ToString("D3") — @(slot.IsEmpty ? "(empty)" : slot.Name)</option>
                                            }
                                        }
                                        else
                                        {
                                            var dstNames = _crossKind == CrossKind.Programs
                                                ? _catalog!.ProgramBanks[_crossDstBank]
                                                : _catalog!.CombiBanks[_crossDstBank];
                                            @for (var i = 0; i < dstNames.Count; i++)
                                            {
                                                <option value="@i" selected="@(i == _crossDstIndex)">@i.ToString("D3") — @(string.IsNullOrEmpty(dstNames[i]) ? "(empty)" : dstNames[i])</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <button type="button" class="btn btn-sm btn-primary" @onclick="DoCrossCopy">Copy</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelCrossSelection">Cancel</button>
                            </div>
                            <div class="small mt-1">Copying <strong>overwrites</strong> the destination slot shown above.</div>
                            @if (_crossKind == CrossKind.Combis && _crossSelectedCombi is not null)
                            {
                                var timbres = _crossSelectedCombi.Timbres.Where(t => t.UsesInternalProgram).ToList();
                                var matching = timbres.Count(t =>
                                    (_srcCatalog.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)")
                                    == (_catalog!.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)"));
                                <div class="small mt-2">
                                    In the destination this combi will play whatever lives at its timbres' program slots:
                                    <strong>@matching of @timbres.Count</strong> internal timbres currently resolve to the
                                    same program name in both files.
                                    <details class="mt-1">
                                        <summary class="text-body-secondary">show timbres</summary>
                                        <ul class="mb-0">
                                            @foreach (var t in timbres)
                                            {
                                                var srcName = _srcCatalog.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)";
                                                var dstName = _catalog!.ResolveProgram(t.ProgramBankPcgId, t.ProgramNumber) ?? "(empty)";
                                                <li>
                                                    T@(t.Index + 1): @PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(t.ProgramBankPcgId)) #@t.ProgramNumber.ToString("D3")
                                                    — source '@srcName'@(srcName == dstName ? " (same in destination)" : $" vs destination '{dstName}'")
                                                </li>
                                            }
                                        </ul>
                                    </details>
                                </div>
                            }
                        </div>
                    }

                    @if (_crossLastCopy is not null)
                    {
                        <div class="alert alert-success py-1 px-2 small">@_crossLastCopy</div>
                    }

                    <div class="text-body-secondary small mb-1">
                        @srcRows.Count item(s)@(string.IsNullOrWhiteSpace(_crossFilter) ? "" : $" matching \"{_crossFilter}\"") in the source — click <em>Select</em>, then choose a destination.
                    </div>
                    <table class="table table-sm table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width:4rem">#</th>
                                <th>Name</th>
                                @if (_crossKind == CrossKind.SetListSlots)
                                {
                                    <th>Loads</th>
                                }
                                <th style="width:6rem"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in srcRows.Take(MaxRows))
                            {
                                <tr @key="row.Index" class="@(_crossSelection is { } cs && cs.Bank == _crossSrcBank && cs.Index == row.Index ? "table-active" : null)">
                                    <td>@row.Index.ToString("D3")</td>
                                    <td>@row.Name</td>
                                    @if (_crossKind == CrossKind.SetListSlots)
                                    {
                                        <td class="small text-body-secondary">@row.Extra</td>
                                    }
                                    <td><button type="button" class="btn btn-sm btn-outline-primary px-2" @onclick="() => SelectCrossItem(row.Index, row.Name)">Select</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            break;
        }

        case View.Differences:
        {
            <h2 class="h5">Differences</h2>
            @if (_srcPcg is null || _srcCatalog is null)
            {
                <p class="text-body-secondary">
                    Open a second <code>.PCG</code> as the read-only source on the
                    <button type="button" class="btn btn-sm btn-outline-secondary align-baseline"
                            @onclick="() => _view = View.Copy">Copy</button>
                    tab, then come back — this view lists every program, combi, and set-list slot that
                    differs between that file (before) and the file you're editing (after).
                </p>
            }
            else
            {
                var compat = PcgCompat.Compare(_srcPcg, _pcg);
                if (!compat.AllMatch)
                {
                    <div class="alert alert-danger">
                        <strong>Record layouts differ</strong> (@compat.MismatchSummary) — these files don't
                        appear to be from the same model, so they can't be compared.
                    </div>
                }
                else
                {
                    var diff = _diffReport ??= PcgDiff.Compare(_srcPcg, _pcg);

                    <p class="text-body-secondary small mb-2">
                        Changes from <strong>@_srcFileName</strong> (before) to
                        <strong>@_fileName</strong> (after)@(_dirty ? " — including your unsaved edits" : "").
                        A <em>moved</em> entry is a byte-identical patch found at a new position (a reorg);
                        <em>edited</em> referrers commonly accompany a move because their references were retargeted.
                    </p>

                    @if (diff.IsEmpty)
                    {
                        <div class="alert alert-success">
                            The two files' programs, combis, and set lists are identical.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                            <div class="text-body-secondary small">
                                Programs: @DiffSummary(diff.Programs) &nbsp;·&nbsp; Combis: @DiffSummary(diff.Combis)
                                &nbsp;·&nbsp; Set-list slots: @DiffSummary(diff.SetListSlots)@(
                                    diff.RenamedSetLists.Count > 0 ? $" · set lists renamed: {diff.RenamedSetLists.Count}" : "")
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportDifferencesCsv">CSV</button>
                        </div>

                        @DiffSection("Programs", diff.Programs, PcgBankLabels.Program)
                        @DiffSection("Combis", diff.Combis, PcgBankLabels.Combi)
                        @DiffSection("Set-list slots", diff.SetListSlots, sl => $"SL {sl:D3}")

                        @if (diff.RenamedSetLists.Count > 0)
                        {
                            <h3 class="h6 mt-3">Renamed set lists (@diff.RenamedSetLists.Count)</h3>
                            <table class="table table-sm table-hover align-middle">
                                <thead><tr><th style="width:6rem">Set list</th><th>Name</th></tr></thead>
                                <tbody>
                                    @foreach (var e in diff.RenamedSetLists)
                                    {
                                        <tr>
                                            <td>@e.Bank.ToString("D3")</td>
                                            <td>@DisplayName(e.NameBefore) <span class="text-body-secondary">→</span> @DisplayName(e.NameAfter)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                }
            }
            break;
        }

        case View.Usage:
        {
            var usage = CurrentUsage;
            var usageBanks = usage.Programs.Select(p => p.BankIndex).Distinct().OrderBy(b => b).ToList();
            IEnumerable<ProgramUsage> usageQuery = usage.Programs;
            if (_usageBankFilter >= 0)
                usageQuery = usageQuery.Where(p => p.BankIndex == _usageBankFilter);
            if (!string.IsNullOrWhiteSpace(_usageFilter))
            {
                var needle = _usageFilter.Trim();
                usageQuery = usageQuery.Where(p =>
                    p.Name.Contains(needle, StringComparison.OrdinalIgnoreCase)
                    || p.Number.ToString("D3").Contains(needle)
                    || PcgBankLabels.Program(p.BankIndex).Contains(needle, StringComparison.OrdinalIgnoreCase));
            }
            usageQuery = _usageSort switch
            {
                UsageSort.Name => usageQuery.OrderBy(p => p.Name, StringComparer.OrdinalIgnoreCase),
                UsageSort.MostUsed => usageQuery.OrderByDescending(p => p.ReferenceCount)
                                                .ThenBy(p => p.BankIndex).ThenBy(p => p.Number),
                _ => usageQuery.OrderBy(p => p.BankIndex).ThenBy(p => p.Number),
            };
            var programsView = usageQuery.ToList();
            var usageFiltered = _usageBankFilter >= 0 || !string.IsNullOrWhiteSpace(_usageFilter);
            <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                <h2 class="h5 mb-0">Program usage</h2>
                <div class="btn-group">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportUsageCsv">CSV</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportUsageHtml">HTML</button>
                </div>
            </div>
            <p class="text-body-secondary small">
                Which Programs are referenced by combi timbres and program-type set-list slots —
                <strong>@usage.Programs.Count</strong> referenced,
                <strong>@usage.UnreferencedPrograms.Count</strong> unreferenced programs,
                <strong>@usage.UnreferencedCombis.Count</strong> unreferenced combis.
                "Unreferenced" means nothing in <em>this file</em> points at it; Song-type references aren't decoded yet.
            </p>

            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Find program</label>
                    <input type="text" class="form-control form-control-sm" placeholder="name, # or bank…"
                           @bind="_usageFilter" @bind:event="oninput" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-1">Bank</label>
                    <select class="form-select form-select-sm" @bind="_usageBankFilter">
                        <option value="-1">All banks</option>
                        @foreach (var b in usageBanks)
                        {
                            <option value="@b">@PcgBankLabels.Program(b)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-1">Sort</label>
                    <select class="form-select form-select-sm" @bind="_usageSort">
                        <option value="@UsageSort.BankNumber">Bank, #</option>
                        <option value="@UsageSort.Name">Name</option>
                        <option value="@UsageSort.MostUsed">Most used</option>
                    </select>
                </div>
            </div>

            <div class="text-body-secondary small mb-2">
                Showing @programsView.Count of @usage.Programs.Count referenced program@(usage.Programs.Count == 1 ? "" : "s")@(usageFiltered ? " (filtered)" : "").
                @if (usageFiltered)
                {
                    <button type="button" class="btn btn-link btn-sm p-0 ms-1 align-baseline" @onclick="ClearUsageFilters">clear</button>
                }
            </div>

            <table class="table table-sm table-hover align-middle">
                <thead>
                    <tr>
                        <th style="width:5rem">Bank</th>
                        <th style="width:4rem">#</th>
                        <th>Program</th>
                        <th style="width:4rem" class="text-end">Refs</th>
                        <th>Used by</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in programsView)
                    {
                        <tr>
                            <td>@PcgBankLabels.Program(p.BankIndex)</td>
                            <td>@p.Number.ToString("D3")</td>
                            <td>@(string.IsNullOrEmpty(p.Name) ? "—" : p.Name)</td>
                            <td class="text-end">@p.ReferenceCount</td>
                            <td>
                                <details>
                                    <summary class="small text-body-secondary">show</summary>
                                    <ul class="small mb-0">
                                        @foreach (var s in p.Sites)
                                        {
                                            <li>@s.Description</li>
                                        }
                                    </ul>
                                </details>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (usage.UnreferencedCombis.Count > 0)
            {
                <details class="mb-3">
                    <summary class="h6 d-inline">Unreferenced combis (@usage.UnreferencedCombis.Count)</summary>
                    <p class="text-body-secondary small mb-1 mt-1">Combis no set-list slot loads — cleanup candidates.</p>
                    <ul class="small">
                        @foreach (var c in usage.UnreferencedCombis)
                        {
                            <li>@PcgBankLabels.Combi(c.BankIndex) #@c.Number.ToString("D3") — @c.Name</li>
                        }
                    </ul>
                </details>
            }

            @if (usage.UnreferencedPrograms.Count > 0)
            {
                <details>
                    <summary class="h6 d-inline">Unreferenced programs (@usage.UnreferencedPrograms.Count)</summary>
                    <p class="text-body-secondary small mb-1 mt-1">Not used by any combi timbre or program slot in this file (many factory programs land here).</p>
                    <ul class="small">
                        @foreach (var p in usage.UnreferencedPrograms.Take(MaxRows))
                        {
                            <li>@PcgBankLabels.Program(p.BankIndex) #@p.Number.ToString("D3") — @p.Name</li>
                        }
                    </ul>
                    @if (usage.UnreferencedPrograms.Count > MaxRows)
                    {
                        <p class="text-body-secondary small">… showing first @MaxRows of @usage.UnreferencedPrograms.Count.</p>
                    }
                </details>
            }
            break;
        }

        case View.Duplicates:
        {
            var dupCombis = PcgDuplicates.Combis(_pcg);
            var dupPrograms = PcgDuplicates.Programs(_pcg);

            <h2 class="h5">Duplicate patches</h2>
            <p class="text-body-secondary small">
                Programs and combis that share a name. <span class="badge text-bg-secondary">identical</span>
                means the records are byte-for-byte the same (a true redundant copy); without it, the name is
                reused for a different sound.
            </p>

            <h3 class="h6 mt-3">Combis — @dupCombis.Count duplicate name@(dupCombis.Count == 1 ? "" : "s")</h3>
            @if (dupCombis.Count == 0)
            {
                <p class="text-body-secondary small">No duplicate combi names.</p>
            }
            else
            {
                <table class="table table-sm align-middle">
                    <thead><tr><th>Name</th><th style="width:5rem" class="text-end">Count</th><th>Members</th></tr></thead>
                    <tbody>
                        @foreach (var g in dupCombis)
                        {
                            <tr>
                                <td>
                                    @g.Name
                                    @if (g.AllByteIdentical) { <span class="badge text-bg-secondary">identical</span> }
                                </td>
                                <td class="text-end">@g.Count</td>
                                <td class="small text-body-secondary">@MemberList(g, isProgram: false)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <h3 class="h6 mt-4">Programs — @dupPrograms.Count duplicate name@(dupPrograms.Count == 1 ? "" : "s")</h3>
            @if (dupPrograms.Count == 0)
            {
                <p class="text-body-secondary small">No duplicate program names.</p>
            }
            else
            {
                <table class="table table-sm align-middle">
                    <thead><tr><th>Name</th><th style="width:5rem" class="text-end">Count</th><th>Members</th></tr></thead>
                    <tbody>
                        @foreach (var g in dupPrograms)
                        {
                            <tr>
                                <td>
                                    @g.Name
                                    @if (g.AllByteIdentical) { <span class="badge text-bg-secondary">identical</span> }
                                </td>
                                <td class="text-end">@g.Count</td>
                                <td class="small text-body-secondary">@MemberList(g, isProgram: true)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            break;
        }

        case View.Search:
        {
            var hits = _catalog is null
                ? new List<SearchHit>()
                : PcgSearch.Find(_catalog, _setLists, _nameQuery).ToList();

            <h2 class="h5">Search names</h2>
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <input type="text" class="form-control form-control-sm"
                           placeholder="search Program / Combi / Set List names…"
                           @bind="_nameQuery" @bind:event="oninput" />
                </div>
            </div>

            @if (string.IsNullOrWhiteSpace(_nameQuery))
            {
                <p class="text-body-secondary small">Type to search names across Programs, Combis, and Set List slots.</p>
            }
            else
            {
                <div class="text-body-secondary small mb-2">
                    @hits.Count match@(hits.Count == 1 ? "" : "es")@(hits.Count > MaxRows ? $" — showing first {MaxRows}" : "")
                </div>
                <table class="table table-sm table-hover align-middle">
                    <thead><tr><th style="width:7rem">Type</th><th>Name</th><th style="width:15rem">Location</th></tr></thead>
                    <tbody>
                        @foreach (var h in hits.Take(MaxRows))
                        {
                            <tr>
                                <td><span class="badge text-bg-light">@HitKindLabel(h.Kind)</span></td>
                                <td>@h.Name</td>
                                <td class="small text-body-secondary">@h.Location</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            break;
        }

        case View.Strings:
        {
            var filtered = FilteredStrings.ToList();
            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-5">
                    <label class="form-label small mb-1">Chunk</label>
                    <select class="form-select form-select-sm" @onchange="OnChunkChanged">
                        @for (var i = 0; i < _chunkChoices.Count; i++)
                        {
                            var (chunk, depth) = _chunkChoices[i];
                            <option value="@i" selected="@(ReferenceEquals(chunk, _selectedChunk))">
                                @(new string(' ', depth * 3))@chunk.Id — @PcgChunkInfo.Describe(chunk.Id) (@Format.Bytes(chunk.Size))
                            </option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Min length</label>
                    <input type="number" min="1" max="64" class="form-control form-control-sm"
                           value="@_minLen" @onchange="OnMinLenChanged" />
                </div>
                <div class="col-6 col-md-4">
                    <label class="form-label small mb-1">Search</label>
                    <input type="text" class="form-control form-control-sm" placeholder="filter…"
                           @bind="_search" @bind:event="oninput" />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-body-secondary small">
                    @filtered.Count string(s)@(filtered.Count > MaxRows ? $" — showing first {MaxRows}" : "")
                </div>
                <div class="btn-group">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportStringsCsv">CSV</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportStringsJson">JSON</button>
                </div>
            </div>

            <table class="table table-sm table-hover font-monospace small">
                <thead><tr><th style="width:9rem">Offset</th><th>Text</th></tr></thead>
                <tbody>
                    @foreach (var s in filtered.Take(MaxRows))
                    {
                        <tr>
                            <td class="text-body-secondary">@Format.Hex(s.Offset)</td>
                            <td>@s.Value</td>
                        </tr>
                    }
                </tbody>
            </table>
            break;
        }

        case View.Tree:
        {
            <p class="text-body-secondary">Full chunk hierarchy — click a row to expand or collapse.</p>
            @foreach (var top in _pcg.TopLevel)
            {
                <ChunkNode Chunk="top" Open="true" />
            }
            break;
        }
    }
}

@code {
    enum View { Overview, SetLists, Combis, Programs, Copy, Differences, Usage, Duplicates, Search, Strings, Tree }
    enum UsageSort { BankNumber, Name, MostUsed }
    enum CrossKind { Programs, Combis, SetListSlots }

    const long MaxFileSize = 256L * 1024 * 1024; // OpenReadStream ceiling
    const int MaxRows = 1000;                    // cap rendered string rows

    PcgFile? _pcg;
    string? _fileName;
    string? _error;
    bool _loading;
    View _view = View.Overview;

    List<(PcgChunk Chunk, int Depth)> _chunkChoices = new();
    PcgChunk? _selectedChunk;
    int _minLen = 3;
    string _search = string.Empty;
    string _nameQuery = string.Empty;
    List<PcgString> _stringsForChunk = new();
    List<SetList> _setLists = new();
    PcgCatalog? _catalog;
    int _selectedSetList;
    bool _showEmptySlots;

    // Editing state
    bool _editMode;
    bool _dirty;
    (int SetList, int Slot)? _copySource;
    string _copySourceName = string.Empty;

    // Slot notes / re-point panels (one of each open at a time)
    int? _descSlot;
    int? _repointSlot;
    PcgItemKind _repointKind = PcgItemKind.Combi;
    int _repointBank;
    int _repointIndex;

    // Combi reorganization state
    int _selectedCombiBank;
    (int Bank, int Index)? _combiCopySource;
    string _combiCopySourceName = string.Empty;
    IReadOnlyDictionary<(int Bank, int Index), int> _combiRefCounts = new Dictionary<(int, int), int>();
    UsageReport? _usageReport;

    // Program reorganization state
    int _selectedProgramBank;
    (int Bank, int Index)? _programCopySource;
    string _programCopySourceName = string.Empty;

    // Find / sort navigation aids (per-tab)
    string _programFilter = string.Empty;
    string _combiFilter = string.Empty;
    string _usageFilter = string.Empty;
    int _usageBankFilter = -1;                 // -1 = all banks
    UsageSort _usageSort = UsageSort.BankNumber;

    // Cross-file copy state (the main file is the destination; the source is read-only)
    PcgFile? _srcPcg;
    string? _srcFileName;
    string? _srcError;
    bool _srcLoading;
    PcgCatalog? _srcCatalog;
    List<SetList> _srcSetLists = new();
    CrossKind _crossKind = CrossKind.Programs;
    int _crossSrcBank;                          // source bank (or set-list index)
    string _crossFilter = string.Empty;
    (int Bank, int Index, string Name)? _crossSelection;
    Combi? _crossSelectedCombi;                 // timbre preview for a selected combi
    int _crossDstBank;
    int _crossDstIndex;
    string? _crossLastCopy;
    PcgDiffReport? _diffReport;                 // Differences tab cache; rebuilt after any edit

    IEnumerable<PcgString> FilteredStrings =>
        string.IsNullOrWhiteSpace(_search)
            ? _stringsForChunk
            : _stringsForChunk.Where(s => s.Value.Contains(_search, StringComparison.OrdinalIgnoreCase));

    // Built on first view of the Usage tab and cached until the next edit / file load.
    UsageReport CurrentUsage => _usageReport ??= PcgUsage.BuildUsageReport(_pcg!);

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _pcg = null;
        _fileName = e.File.Name;
        _loading = true;
        try
        {
            using var ms = new MemoryStream();
            await using (var stream = e.File.OpenReadStream(MaxFileSize))
            {
                await stream.CopyToAsync(ms);
            }

            _pcg = PcgReader.Parse(ms.ToArray());
            _view = View.SetLists; // musicians first: "are my songs here?"
            _showAdvanced = false;
            _dirty = false;
            _editMode = false;
            _copySource = null;
            _combiCopySource = null;
            _programCopySource = null;
            _programFilter = _combiFilter = _usageFilter = string.Empty;
            _usageBankFilter = -1;
            _usageSort = UsageSort.BankNumber;
            LoadDerived(preserveSelection: false);
        }
        catch (Exception ex)
        {
            _error = $"Could not parse '{_fileName}': {ex.Message}";
            Logger.LogWarning(ex, "Failed to parse PCG {File}", _fileName);
        }
        finally
        {
            _loading = false;
        }
    }

    void LoadDerived(bool preserveSelection)
    {
        if (_pcg is null) return;

        _chunkChoices = _pcg.Flatten().ToList();
        _selectedChunk = _pcg.FindFirst("SDB1") ?? _pcg.FindFirst("SLS1") ?? _pcg.TopLevel.FirstOrDefault();
        RefreshStrings();

        _setLists = SetListReader.Read(_pcg).ToList();
        _catalog = PcgCatalog.Build(_pcg);
        _combiRefCounts = PcgUsage.CombiReferenceCounts(_setLists);
        _usageReport = null; // rebuilt lazily the next time the Usage tab is viewed
        _diffReport = null;  // likewise for the Differences tab

        var combiBankCount = _catalog.CombiBanks.Count;
        var programBankCount = _catalog.ProgramBanks.Count;
        if (preserveSelection)
        {
            _selectedSetList = Math.Clamp(_selectedSetList, 0, Math.Max(0, _setLists.Count - 1));
            _selectedCombiBank = Math.Clamp(_selectedCombiBank, 0, Math.Max(0, combiBankCount - 1));
            _selectedProgramBank = Math.Clamp(_selectedProgramBank, 0, Math.Max(0, programBankCount - 1));
        }
        else
        {
            _selectedSetList = _setLists.FindIndex(s => s.NamedSlots.Any());
            if (_selectedSetList < 0) _selectedSetList = 0;
            _selectedCombiBank = 0;
            _selectedProgramBank = 0;
        }
    }

    // Applies an edit (a new byte image) and refreshes, staying on the current set list.
    void ApplyEdit(byte[] newData)
    {
        _pcg = PcgReader.Parse(newData);
        _dirty = true;
        LoadDerived(preserveSelection: true);
    }

    void RefreshStrings()
    {
        _stringsForChunk = _pcg is null || _selectedChunk is null
            ? new List<PcgString>()
            : PcgStrings.Extract(_pcg.Data, _selectedChunk, _minLen).ToList();
    }

    void OnChunkChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < _chunkChoices.Count)
        {
            _selectedChunk = _chunkChoices[idx].Chunk;
            RefreshStrings();
        }
    }

    void OnMinLenChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _minLen = Math.Clamp(v, 1, 64);
            RefreshStrings();
        }
    }

    IEnumerable<PcgChunk> TopLevelSections()
    {
        if (_pcg is null) return Enumerable.Empty<PcgChunk>();
        return _pcg.TopLevel.Count == 1 && _pcg.TopLevel[0].HasChildren
            ? _pcg.TopLevel[0].Children
            : _pcg.TopLevel;
    }

    // The technical tabs a musician shouldn't have to wade through; reachable via "Advanced".
    static readonly View[] AdvancedViews = { View.Overview, View.Strings, View.Tree };
    bool _showAdvanced;

    static string TabLabel(View v) => v switch
    {
        View.Overview => "File info",
        View.SetLists => "Set Lists",
        View.Combis => "Combis",
        View.Programs => "Programs",
        View.Copy => "Copy",
        View.Differences => "Differences",
        View.Usage => "Usage",
        View.Duplicates => "Duplicates",
        View.Search => "Search",
        View.Strings => "Strings",
        View.Tree => "Chunk tree",
        _ => v.ToString(),
    };

    string SelectedChunkName => _selectedChunk?.Id ?? "pcg";

    async Task ExportStringsCsv()
    {
        var sb = new StringBuilder();
        sb.Append("offset,text\n");
        foreach (var s in FilteredStrings)
            sb.Append("0x").Append(s.Offset.ToString("X")).Append(",\"")
              .Append(s.Value.Replace("\"", "\"\"")).Append("\"\n");
        await Download($"{SelectedChunkName}-strings.csv", "text/csv", sb.ToString());
    }

    async Task ExportStringsJson()
    {
        var items = FilteredStrings
            .Select(s => new { offset = s.Offset, hex = "0x" + s.Offset.ToString("X"), text = s.Value });
        var json = System.Text.Json.JsonSerializer.Serialize(
            items, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await Download($"{SelectedChunkName}-strings.json", "application/json", json);
    }

    async Task ExportUsageCsv()
    {
        var usage = CurrentUsage;
        var sb = new StringBuilder();
        sb.Append("program_bank,program_number,program_name,ref_count,used_by_kind,used_by_detail\n");
        foreach (var p in usage.Programs)
            foreach (var site in p.Sites)
                sb.Append(PcgBankLabels.Program(p.BankIndex)).Append(',')
                  .Append(p.Number).Append(",\"")
                  .Append(Csv(p.Name)).Append("\",")
                  .Append(p.ReferenceCount).Append(',')
                  .Append(site.Kind).Append(",\"")
                  .Append(Csv(site.Description)).Append("\"\n");
        await Download("program-usage.csv", "text/csv", sb.ToString());
    }

    async Task ExportCurrentSetListHtml()
    {
        if (_catalog is null) return;
        var sl = _setLists[_selectedSetList];
        await Download($"setlist-{sl.Index:D3}.html", "text/html", PcgHtmlReport.SetList(sl, _catalog));
    }

    async Task ExportAllSetListsHtml()
    {
        if (_catalog is null) return;
        await Download("setlists.html", "text/html", PcgHtmlReport.AllSetLists(_setLists, _catalog));
    }

    async Task ExportUsageHtml() =>
        await Download("program-usage.html", "text/html", PcgHtmlReport.Usage(CurrentUsage));

    void OnSetListChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < _setLists.Count)
        {
            _selectedSetList = idx;
            _descSlot = null;
            _repointSlot = null;
        }
    }

    async Task ExportCurrentSetListCsv()
    {
        var sl = _setLists[_selectedSetList];
        var sb = new StringBuilder();
        sb.Append("slot,slot_name,kind,bank,number,loads,description\n");
        AppendSlotRows(sb, sl, includeSetListColumns: false);
        await Download($"setlist-{sl.Index:D3}.csv", "text/csv", sb.ToString());
    }

    async Task ExportAllSetListsCsv()
    {
        var sb = new StringBuilder();
        sb.Append("set_list,set_list_name,slot,slot_name,kind,bank,number,loads,description\n");
        foreach (var sl in _setLists)
            AppendSlotRows(sb, sl, includeSetListColumns: true);
        await Download("setlists.csv", "text/csv", sb.ToString());
    }

    void AppendSlotRows(StringBuilder sb, SetList sl, bool includeSetListColumns)
    {
        foreach (var slot in sl.Slots)
        {
            if (slot.IsEmpty && !_showEmptySlots) continue;
            if (includeSetListColumns)
                sb.Append(sl.Index).Append(",\"").Append(Csv(sl.Name)).Append("\",");
            var target = _catalog?.Resolve(slot.Reference) ?? string.Empty;
            sb.Append(slot.Index).Append(",\"").Append(Csv(slot.Name)).Append("\",")
              .Append(slot.Reference.Kind).Append(',')
              .Append(slot.Reference.Bank).Append(',')
              .Append(slot.Reference.Index).Append(",\"").Append(Csv(target)).Append("\",\"")
              .Append(Csv(slot.Description)).Append("\"\n");
        }
    }

    static string Csv(string value) => value.Replace("\"", "\"\"");

    // ----- Editing operations (each produces a new byte image via PcgEditor) -----

    void MoveSlot(int slot, int delta)
    {
        if (_pcg is null) return;
        int target = slot + delta;
        if (target < 0 || target >= _setLists[_selectedSetList].Slots.Count) return;
        ApplyEdit(PcgEditor.SwapSetListSlots(_pcg, _selectedSetList, slot, target));
    }

    void RenameSlot(int slot, string? name)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.RenameSetListSlot(_pcg, _selectedSetList, slot, name ?? string.Empty));
    }

    void RenameCurrentSetList(string? name)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.RenameSetList(_pcg, _selectedSetList, name ?? string.Empty));
    }

    void StartCopy(SetListSlot slot)
    {
        _copySource = (_selectedSetList, slot.Index);
        _copySourceName = slot.IsEmpty ? $"slot {slot.Index:D3}" : slot.Name;
    }

    void ToggleDescEditor(int slot)
    {
        _repointSlot = null;
        _descSlot = _descSlot == slot ? null : slot;
    }

    void SetSlotDescription(int slot, string? text)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.SetSetListSlotDescription(_pcg, _selectedSetList, slot, text ?? string.Empty));
    }

    void ToggleRepoint(SetListSlot slot)
    {
        _descSlot = null;
        if (_repointSlot == slot.Index)
        {
            _repointSlot = null;
            return;
        }
        _repointSlot = slot.Index;
        var r = slot.Reference;
        if (r.Kind == PcgItemKind.Program)
        {
            _repointKind = PcgItemKind.Program;
            _repointBank = Math.Max(0, PcgCatalog.ProgramBankIndexForPcgId(r.Bank));
            _repointIndex = r.Index;
        }
        else
        {
            _repointKind = PcgItemKind.Combi;
            int combiBanks = Math.Max(1, _catalog?.CombiBanks.Count ?? 1);
            _repointBank = r.Kind == PcgItemKind.Combi ? Math.Min(r.Bank, combiBanks - 1) : 0;
            _repointIndex = r.Kind == PcgItemKind.Combi ? r.Index : 0;
        }
    }

    void SetRepointKind(PcgItemKind kind)
    {
        _repointKind = kind;
        _repointBank = 0;
        _repointIndex = 0;
    }

    void OnRepointBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            _repointBank = idx;
            _repointIndex = 0;
        }
    }

    void OnRepointIndexChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
            _repointIndex = idx;
    }

    void ApplyRepoint()
    {
        if (_pcg is null || _repointSlot is null) return;
        ApplyEdit(PcgEditor.RepointSetListSlot(_pcg, _selectedSetList, _repointSlot.Value, _repointKind, _repointBank, _repointIndex));
        _repointSlot = null;
    }

    void PasteInto(int slot)
    {
        if (_pcg is null || _copySource is null) return;
        var src = _copySource.Value;
        ApplyEdit(PcgEditor.CopySetListSlot(_pcg, src.SetList, src.Slot, _selectedSetList, slot));
    }

    async Task DownloadEditedPcg()
    {
        if (_pcg is null) return;
        var baseName = string.IsNullOrEmpty(_fileName)
            ? "edited"
            : System.IO.Path.GetFileNameWithoutExtension(_fileName);
        await SaveBytes($"{baseName}-edited.PCG", _pcg.Data);
    }

    async Task SaveBytes(string fileName, byte[] bytes)
    {
        using var stream = new MemoryStream(bytes);
        using var streamRef = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("pcgSaveFile", fileName, streamRef);
    }

    // ----- Combi reorganization -----

    void OnCombiBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && _catalog is not null
            && idx >= 0 && idx < _catalog.CombiBanks.Count)
        {
            _selectedCombiBank = idx;
            _combiFilter = string.Empty;
        }
    }

    void MoveCombi(int index, int delta)
    {
        if (_pcg is null || _catalog is null) return;
        int target = index + delta;
        if (target < 0 || target >= _catalog.CombiBanks[_selectedCombiBank].Count) return;
        ApplyEdit(PcgEditor.SwapCombis(_pcg, _selectedCombiBank, index, _selectedCombiBank, target));
    }

    void RenameCombiAt(int index, string? name)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.RenameCombi(_pcg, _selectedCombiBank, index, name ?? string.Empty));
    }

    void StartCombiCopy(int index)
    {
        if (_catalog is null) return;
        _combiCopySource = (_selectedCombiBank, index);
        var name = _catalog.CombiBanks[_selectedCombiBank][index];
        _combiCopySourceName = string.IsNullOrEmpty(name) ? $"bank {_selectedCombiBank:D2} #{index:D3}" : name;
    }

    void PasteCombiInto(int index)
    {
        if (_pcg is null || _combiCopySource is null) return;
        var src = _combiCopySource.Value;
        ApplyEdit(PcgEditor.CopyCombi(_pcg, src.Bank, src.Index, _selectedCombiBank, index));
    }

    void SortCombiBank()
    {
        if (_pcg is null) return;
        if (PcgOrganizer.SortCombiBankByName(_pcg, _selectedCombiBank) is { } edited)
            ApplyEdit(edited);
    }

    void CompactCombiBank()
    {
        if (_pcg is null) return;
        if (PcgOrganizer.CompactCombiBank(_pcg, _selectedCombiBank) is { } edited)
            ApplyEdit(edited);
    }

    // ----- Program reorganization -----

    void OnProgramBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && _catalog is not null
            && idx >= 0 && idx < _catalog.ProgramBanks.Count)
        {
            _selectedProgramBank = idx;
            _programFilter = string.Empty;
        }
    }

    void MoveProgram(int index, int delta)
    {
        if (_pcg is null || _catalog is null) return;
        int target = index + delta;
        if (target < 0 || target >= _catalog.ProgramBanks[_selectedProgramBank].Count) return;
        ApplyEdit(PcgEditor.SwapPrograms(_pcg, _selectedProgramBank, index, _selectedProgramBank, target));
    }

    void RenameProgramAt(int index, string? name)
    {
        if (_pcg is null) return;
        ApplyEdit(PcgEditor.RenameProgram(_pcg, _selectedProgramBank, index, name ?? string.Empty));
    }

    void StartProgramCopy(int index)
    {
        if (_catalog is null) return;
        _programCopySource = (_selectedProgramBank, index);
        var name = _catalog.ProgramBanks[_selectedProgramBank][index];
        _programCopySourceName = string.IsNullOrEmpty(name) ? $"bank {_selectedProgramBank:D2} #{index:D3}" : name;
    }

    void PasteProgramInto(int index)
    {
        if (_pcg is null || _programCopySource is null) return;
        var src = _programCopySource.Value;
        ApplyEdit(PcgEditor.CopyProgram(_pcg, src.Bank, src.Index, _selectedProgramBank, index));
    }

    // ----- Cross-file copy (Copy tab) -----

    async Task OnSourceFileSelected(InputFileChangeEventArgs e)
    {
        _srcError = null;
        _srcPcg = null;
        _srcCatalog = null;
        _srcSetLists = new();
        _srcFileName = e.File.Name;
        _srcLoading = true;
        try
        {
            using var ms = new MemoryStream();
            await using (var stream = e.File.OpenReadStream(MaxFileSize))
            {
                await stream.CopyToAsync(ms);
            }

            _srcPcg = PcgReader.Parse(ms.ToArray());
            _srcCatalog = PcgCatalog.Build(_srcPcg);
            _srcSetLists = SetListReader.Read(_srcPcg).ToList();
            _crossSrcBank = 0;
            _crossFilter = string.Empty;
            _diffReport = null;
            CancelCrossSelection();
        }
        catch (Exception ex)
        {
            _srcError = $"Could not parse '{_srcFileName}': {ex.Message}";
            _srcPcg = null;
            Logger.LogWarning(ex, "Failed to parse source PCG {File}", _srcFileName);
        }
        finally
        {
            _srcLoading = false;
        }
    }

    void ClearSource()
    {
        _srcPcg = null;
        _srcCatalog = null;
        _srcSetLists = new();
        _srcFileName = null;
        _srcError = null;
        _diffReport = null;
        CancelCrossSelection();
    }

    void SetCrossKind(CrossKind kind)
    {
        _crossKind = kind;
        _crossSrcBank = 0;
        _crossFilter = string.Empty;
        CancelCrossSelection();
    }

    void SelectCrossItem(int index, string name)
    {
        _crossSelection = (_crossSrcBank, index, name);
        _crossSelectedCombi = _crossKind == CrossKind.Combis && _srcPcg is not null
            ? CombiReader.Read(_srcPcg).FirstOrDefault(c => c.Bank == _crossSrcBank && c.Index == index)
            : null;
        _crossDstBank = 0;
        _crossDstIndex = 0;
        _crossLastCopy = null;
    }

    void CancelCrossSelection()
    {
        _crossSelection = null;
        _crossSelectedCombi = null;
        _crossDstBank = 0;
        _crossDstIndex = 0;
        _crossLastCopy = null;
    }

    void DoCrossCopy()
    {
        if (_pcg is null || _srcPcg is null || _crossSelection is null) return;
        var sel = _crossSelection.Value;
        var edited = _crossKind switch
        {
            CrossKind.Programs => PcgEditor.CopyProgramAcross(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDstBank, _crossDstIndex),
            CrossKind.Combis => PcgEditor.CopyCombiAcross(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDstBank, _crossDstIndex),
            _ => PcgEditor.CopySetListSlotAcross(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDstBank, _crossDstIndex),
        };
        ApplyEdit(edited);
        _crossLastCopy = $"Copied '{sel.Name}' to {CrossDstLabel()} — pick another destination to copy again, or download the edited .PCG.";
    }

    void OnCrossSrcBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            _crossSrcBank = idx;
            _crossFilter = string.Empty;
            CancelCrossSelection();
        }
    }

    void OnCrossDstBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            _crossDstBank = idx;
            _crossDstIndex = 0;
        }
    }

    void OnCrossDstIndexChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
            _crossDstIndex = idx;
    }

    // Source rows for the current kind/bank/filter: (index, name, extra) with empties hidden.
    List<(int Index, string Name, string Extra)> CrossSourceRows()
    {
        var rows = new List<(int, string, string)>();
        if (_srcCatalog is null) return rows;

        switch (_crossKind)
        {
            case CrossKind.Programs:
            case CrossKind.Combis:
            {
                var banks = _crossKind == CrossKind.Programs ? _srcCatalog.ProgramBanks : _srcCatalog.CombiBanks;
                if (_crossSrcBank < 0 || _crossSrcBank >= banks.Count) break;
                var bank = banks[_crossSrcBank];
                for (int i = 0; i < bank.Count; i++)
                    if (!string.IsNullOrEmpty(bank[i]) && MatchesFilter(bank[i], i, _crossFilter))
                        rows.Add((i, bank[i], string.Empty));
                break;
            }
            default:
            {
                if (_crossSrcBank < 0 || _crossSrcBank >= _srcSetLists.Count) break;
                foreach (var slot in _srcSetLists[_crossSrcBank].Slots)
                    if (!slot.IsEmpty && MatchesFilter(slot.Name, slot.Index, _crossFilter))
                        rows.Add((slot.Index, slot.Name,
                            $"{slot.Reference.Kind} {SlotBankLabel(slot.Reference)} #{slot.Reference.Index:D3}"));
                break;
            }
        }
        return rows;
    }

    string CrossSrcLabel(int bank) => _crossKind switch
    {
        CrossKind.Programs => PcgBankLabels.Program(bank),
        CrossKind.Combis => PcgBankLabels.Combi(bank),
        _ => $"Set List {bank:D3}",
    };

    string CrossDstLabel() => _crossKind switch
    {
        CrossKind.Programs => $"{PcgBankLabels.Program(_crossDstBank)} #{_crossDstIndex:D3}",
        CrossKind.Combis => $"{PcgBankLabels.Combi(_crossDstBank)} #{_crossDstIndex:D3}",
        _ => $"Set List {_crossDstBank:D3} slot {_crossDstIndex:D3}",
    };

    // ----- Differences tab -----

    // One section table (Programs / Combis / Set-list slots); bankLabel maps the Bank field.
    private RenderFragment DiffSection(string title, IReadOnlyList<DiffEntry> entries, Func<int, string> bankLabel) => __builder =>
    {
        if (entries.Count == 0) return;
        <h3 class="h6 mt-3">@title (@entries.Count)</h3>
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:6.5rem">Change</th>
                    <th style="width:11rem">Where</th>
                    <th>Name</th>
                    <th>Detail</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    <tr>
                        <td><span class="badge @DiffBadgeClass(e.Kind)">@e.Kind.ToString().ToLowerInvariant()</span></td>
                        <td class="text-nowrap">
                            @bankLabel(e.Bank)
                            @if (e.Kind == DiffKind.Moved)
                            {
                                <span> #@e.IndexBefore.ToString("D3") <span class="text-body-secondary">→</span> #@e.IndexAfter.ToString("D3")</span>
                            }
                            else
                            {
                                <span> #@e.IndexAfter.ToString("D3")</span>
                            }
                        </td>
                        <td>
                            @if (e.Kind is DiffKind.Renamed or DiffKind.Replaced)
                            {
                                <span>@DisplayName(e.NameBefore) <span class="text-body-secondary">→</span> @DisplayName(e.NameAfter)</span>
                            }
                            else if (e.Kind == DiffKind.Removed)
                            {
                                @DisplayName(e.NameBefore)
                            }
                            else
                            {
                                @DisplayName(e.NameAfter)
                            }
                        </td>
                        <td class="small text-body-secondary">@e.Detail</td>
                    </tr>
                }
            </tbody>
        </table>
    };

    static string DiffBadgeClass(DiffKind kind) => kind switch
    {
        DiffKind.Added => "text-bg-success",
        DiffKind.Removed => "text-bg-danger",
        DiffKind.Moved => "text-bg-info",
        DiffKind.Renamed => "text-bg-warning",
        DiffKind.Edited => "text-bg-primary",
        _ => "text-bg-dark", // Replaced
    };

    static string DiffSummary(IReadOnlyList<DiffEntry> entries) =>
        entries.Count == 0
            ? "—"
            : string.Join(" · ", entries.GroupBy(e => e.Kind).OrderBy(g => g.Key)
                .Select(g => $"{g.Count()} {g.Key.ToString().ToLowerInvariant()}"));

    static string DisplayName(string name) => string.IsNullOrEmpty(name) ? "(unnamed)" : name;

    async Task ExportDifferencesCsv()
    {
        if (_pcg is null || _srcPcg is null) return;
        var diff = _diffReport ??= PcgDiff.Compare(_srcPcg, _pcg);
        var sb = new StringBuilder();
        sb.Append("section,kind,bank,index_before,index_after,name_before,name_after,detail\n");
        void Rows(string section, IEnumerable<DiffEntry> entries)
        {
            foreach (var e in entries)
                sb.Append(section).Append(',').Append(e.Kind).Append(',').Append(e.Bank).Append(',')
                  .Append(e.IndexBefore).Append(',').Append(e.IndexAfter).Append(",\"")
                  .Append(Csv(e.NameBefore)).Append("\",\"").Append(Csv(e.NameAfter)).Append("\",\"")
                  .Append(Csv(e.Detail ?? string.Empty)).Append("\"\n");
        }
        Rows("program", diff.Programs);
        Rows("combi", diff.Combis);
        Rows("setlist_slot", diff.SetListSlots);
        Rows("setlist_name", diff.RenamedSetLists);
        await Download("differences.csv", "text/csv", sb.ToString());
    }

    async Task DownloadDestinationCopy()
    {
        if (_pcg is null) return;
        var baseName = string.IsNullOrEmpty(_fileName)
            ? "pcg"
            : System.IO.Path.GetFileNameWithoutExtension(_fileName);
        await SaveBytes($"{baseName}-copy.PCG", _pcg.Data);
    }

    async Task DownloadSourceCopy()
    {
        if (_srcPcg is null) return;
        var baseName = string.IsNullOrEmpty(_srcFileName)
            ? "source"
            : System.IO.Path.GetFileNameWithoutExtension(_srcFileName);
        await SaveBytes($"{baseName}-copy.PCG", _srcPcg.Data);
    }

    void SortProgramBank()
    {
        if (_pcg is null) return;
        if (PcgOrganizer.SortProgramBankByName(_pcg, _selectedProgramBank) is { } edited)
            ApplyEdit(edited);
    }

    void CompactProgramBank()
    {
        if (_pcg is null) return;
        if (PcgOrganizer.CompactProgramBank(_pcg, _selectedProgramBank) is { } edited)
            ApplyEdit(edited);
    }

    static int CountNonEmpty(IReadOnlyList<string> names)
    {
        var count = 0;
        foreach (var name in names)
            if (!string.IsNullOrEmpty(name))
                count++;
        return count;
    }

    // True when a patch row matches the Find box: empty query, a name substring, or a number match.
    static bool MatchesFilter(string? name, int index, string query)
    {
        if (string.IsNullOrWhiteSpace(query)) return true;
        query = query.Trim();
        if (!string.IsNullOrEmpty(name) && name.Contains(query, StringComparison.OrdinalIgnoreCase))
            return true;
        return index.ToString("D3").Contains(query) || index.ToString().Contains(query);
    }

    void ClearUsageFilters()
    {
        _usageFilter = string.Empty;
        _usageBankFilter = -1;
        _usageSort = UsageSort.BankNumber;
    }

    static string SlotBankLabel(SetListReference r) => r.Kind switch
    {
        PcgItemKind.Combi => PcgBankLabels.Combi(r.Bank),
        PcgItemKind.Program => PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(r.Bank)),
        _ => "—",
    };

    static string MemberList(DuplicateGroup g, bool isProgram)
    {
        const int max = 12;
        var labels = g.Members.Take(max).Select(m =>
            $"{(isProgram ? PcgBankLabels.Program(m.Bank) : PcgBankLabels.Combi(m.Bank))} #{m.Index:D3}");
        var text = string.Join(", ", labels);
        return g.Count > max ? $"{text} … +{g.Count - max} more" : text;
    }

    static string HitKindLabel(SearchHitKind k) => k switch
    {
        SearchHitKind.Program => "Program",
        SearchHitKind.Combi => "Combi",
        SearchHitKind.SetListSlot => "Set List",
        _ => k.ToString(),
    };

    async Task Download(string fileName, string mime, string content) =>
        await JS.InvokeVoidAsync("pcgDownload", fileName, mime, content);
}
