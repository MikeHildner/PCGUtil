    // ----- Cross-file copy (Copy tab) -----

    async Task OnSourceFileSelected(InputFileChangeEventArgs e)
    {
        _srcError = null;
        _srcPcg = null;
        _srcCatalog = null;
        _srcSetLists = new();
        _srcFileName = e.File.Name;
        _srcLoading = true;
        try
        {
            using var ms = new MemoryStream();
            await using (var stream = e.File.OpenReadStream(MaxFileSize))
            {
                await stream.CopyToAsync(ms);
            }

            _srcPcg = PcgReader.Parse(ms.ToArray());
            _srcCatalog = PcgCatalog.Build(_srcPcg);
            _srcSetLists = SetListReader.Read(_srcPcg).ToList();
            _crossSrcBank = CrossSrcDefaultBank();
            _crossFilter = string.Empty;
            _diffReport = null;
            _crossDeepMode = false;
            _srcCombis = null;      // wizard song list re-reads the new source
            _addSelection = null;   // a prior selection points into the old file
            _addPlan = null;
            ResetCrossTimbres();
            CancelCrossSelection();
        }
        catch (Exception ex)
        {
            _srcError = $"Could not parse '{_srcFileName}': {ex.Message}";
            _srcPcg = null;
            Logger.LogWarning(ex, "Failed to parse source PCG {File}", _srcFileName);
        }
        finally
        {
            _srcLoading = false;
        }
    }

    void ClearSource()
    {
        _srcPcg = null;
        _srcCatalog = null;
        _srcSetLists = new();
        _srcFileName = null;
        _srcError = null;
        _diffReport = null;
        _crossDeepMode = false;
        ResetCrossTimbres();
        CancelCrossSelection();
        ResetAddWizard();
    }

    void SetCrossKind(CrossKind kind)
    {
        _crossKind = kind;
        _crossSrcBank = CrossSrcDefaultBank();
        _crossFilter = string.Empty;
        ResetCrossTimbres();
        CancelCrossSelection();
    }

    // Timbre inspector for source-file combis on the Copy tab (mirrors ToggleTimbres).
    int? _crossTimbreIndex;
    Combi? _crossTimbreDetail;

    void ToggleCrossTimbres(int index)
    {
        if (_crossTimbreIndex == index)
        {
            ResetCrossTimbres();
            return;
        }
        _crossTimbreIndex = index;
        _crossTimbreDetail = _srcPcg is null ? null
            : CombiReader.Read(_srcPcg).FirstOrDefault(c => c.Bank == _crossSrcBank && c.Index == index);
    }

    void ResetCrossTimbres()
    {
        _crossTimbreIndex = null;
        _crossTimbreDetail = null;
    }

    // First bank the source/destination file carries for the active cross-copy kind.
    int CrossSrcDefaultBank() => _crossKind switch
    {
        CrossKind.Programs when _srcCatalog is not null => SnapToPresent(0, _srcCatalog.ProgramBanks),
        CrossKind.Combis when _srcCatalog is not null => SnapToPresent(0, _srcCatalog.CombiBanks),
        _ => 0,
    };

    int CrossDstDefaultBank() => _crossKind switch
    {
        CrossKind.Programs when _catalog is not null => SnapToPresent(0, _catalog.ProgramBanks),
        CrossKind.Combis when _catalog is not null => SnapToPresent(0, _catalog.CombiBanks),
        _ => 0,
    };

    void SelectCrossItem(int index, string name)
    {
        _crossSelection = (_crossSrcBank, index, name);
        _crossSelectedCombi = _crossKind == CrossKind.Combis && _srcPcg is not null
            ? CombiReader.Read(_srcPcg).FirstOrDefault(c => c.Bank == _crossSrcBank && c.Index == index)
            : null;
        _crossDeepPlan = null;
        _crossDstBank = CrossDstDefaultBank();
        // Program records can't cross HD-1/EXi banks; land the default on a matching bank.
        if (_crossKind == CrossKind.Programs && _srcCatalog is not null && _catalog is not null
            && _srcCatalog.ProgramBankTypes.ElementAtOrDefault(_crossSrcBank) is { } srcType)
        {
            _crossDstBank = PresentBanks(_catalog.ProgramBanks)
                .Where(i => _catalog.ProgramBankTypes[i] == srcType)
                .DefaultIfEmpty(_crossDstBank).First();
        }
        _crossDstIndex = 0;
        _crossLastCopy = null;
    }

    void CancelCrossSelection()
    {
        _crossSelection = null;
        _crossSelectedCombi = null;
        _crossDeepPlan = null;
        _crossDstBank = CrossDstDefaultBank();
        _crossDstIndex = 0;
        _crossLastCopy = null;
    }

    void DoCrossCopy()
    {
        try
        {
            DoCrossCopyCore();
            _crossLastCopyIsError = false;
        }
        catch (InvalidOperationException ex)
        {
            // Editor guards (bank type, stale plan, record layout) refuse rather than
            // corrupt; surface the reason instead of dropping the circuit.
            _crossLastCopy = ex.Message;
            _crossLastCopyIsError = true;
        }
    }

    bool _crossLastCopyIsError;

    void DoCrossCopyCore()
    {
        if (_pcg is null || _srcPcg is null || _crossSelection is null) return;
        var sel = _crossSelection.Value;

        if (_crossKind == CrossKind.Combis && _crossDeepMode)
        {
            if (CurrentDeepPlan() is not { CanApply: true } plan) return;
            ApplyEdit(PcgEditor.CopyCombiDeepAcross(_srcPcg, _pcg, _crossDstBank, _crossDstIndex, plan));
            var into = string.Join(" and ", plan.Copies.Select(m => m.DestinationBank).Distinct()
                .Select(b => PcgBankLabels.Program(b)));
            _crossLastCopy = $"Copied '{sel.Name}' to {CrossDstLabel()} with {plan.Copies.Count()} program(s)"
                + (into.Length > 0 ? $" into {into}" : "")
                + (plan.Reused.Any() ? $" ({plan.Reused.Count()} already there, reused)" : "")
                + " — download the edited .PCG when you're done.";
            return;
        }

        var edited = _crossKind switch
        {
            CrossKind.Programs => PcgEditor.CopyProgramAcross(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDstBank, _crossDstIndex),
            CrossKind.Combis => PcgEditor.CopyCombiAcross(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDstBank, _crossDstIndex),
            _ => PcgEditor.CopySetListSlotAcross(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDstBank, _crossDstIndex),
        };
        ApplyEdit(edited);
        _crossLastCopy = $"Copied '{sel.Name}' to {CrossDstLabel()} — pick another destination to copy again, or download the edited .PCG.";
    }

    // ----- Deep copy (combi + the programs its timbres reference) -----

    bool _crossDeepMode;
    int? _crossDeepHd1Bank;  // destination for newly copied HD-1 programs
    int? _crossDeepExiBank;  // destination for newly copied EXi programs
    DeepCopyPlan? _crossDeepPlan;

    void SetCrossDeepMode(bool deep)
    {
        _crossDeepMode = deep;
        if (deep)
        {
            _crossDeepHd1Bank = DefaultDeepProgramBank(ProgramBankType.Hd1);
            _crossDeepExiBank = DefaultDeepProgramBank(ProgramBankType.Exi);
        }
        _crossDeepPlan = null;
    }

    void OnCrossDeepBankChanged(ProgramBankType type, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            if (type == ProgramBankType.Hd1)
                _crossDeepHd1Bank = idx;
            else
                _crossDeepExiBank = idx;
            _crossDeepPlan = null;
            _addPlan = null; // shared program-bank choices feed the wizard plan too
        }
    }

    // Present program bank of the given engine type with the most free slots
    // (ties go to the lowest index); null when the file has no bank of that type.
    int? DefaultDeepProgramBank(ProgramBankType type)
    {
        if (_catalog is null) return null;
        int? best = null;
        int bestFree = -1;
        foreach (var i in PresentBanks(_catalog.ProgramBanks))
        {
            if (_catalog.ProgramBankTypes[i] != type)
                continue;
            int free = PcgDeepCopy.FreeProgramSlots(_catalog.ProgramBanks[i]).Count;
            if (free > bestFree)
            {
                best = i;
                bestFree = free;
            }
        }
        return best;
    }

    DeepCopyPlan? CurrentDeepPlan()
    {
        if (!_crossDeepMode || _crossKind != CrossKind.Combis || _pcg is null || _srcPcg is null
            || _crossSelection is not { } sel)
            return null;
        _crossDeepHd1Bank = SanitizeDeepBank(_crossDeepHd1Bank, ProgramBankType.Hd1);
        _crossDeepExiBank = SanitizeDeepBank(_crossDeepExiBank, ProgramBankType.Exi);
        return _crossDeepPlan ??= PcgDeepCopy.Plan(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDeepHd1Bank, _crossDeepExiBank);
    }

    // Keeps a per-type deep-copy bank choice valid (present + right engine type); falls
    // back to the type's default bank when the choice no longer holds.
    int? SanitizeDeepBank(int? bank, ProgramBankType type)
    {
        if (_catalog is not null && bank is { } b
            && b >= 0 && b < _catalog.ProgramBanks.Count
            && _catalog.ProgramBanks[b].Count > 0
            && _catalog.ProgramBankTypes[b] == type)
            return bank;
        return DefaultDeepProgramBank(type);
    }

    static string DeepSkipText(DeepCopyTimbreSkip s) => s.Reason switch
    {
        DeepCopySkipReason.ExternalStatus => "off/external — plays no internal program",
        DeepCopySkipReason.Unresolved =>
            $"points at {PcgBankLabels.Program(PcgCatalog.ProgramBankIndexForPcgId(s.ProgramBankPcgId))} #{s.ProgramNumber:D3}, which isn't in the source file — left as-is",
        _ => "points at an Init/empty placeholder program — left as-is",
    };

    // ----- "Add sounds from another file" wizard (guided deep copy) -----

    enum AddStep { Source, Pick, Review, Done }

    AddStep _addStep;
    (int Bank, int Index, string Name)? _addSelection;
    (int Bank, int Index)? _addTimbreOpen;
    Combi? _addTimbreDetail;
    int _addDstBank;
    int _addDstIndex;
    DeepCopyPlan? _addPlan;
    string _addFilter = "";
    string? _addLastResult;
    string? _addError;
    IReadOnlyList<Combi>? _srcCombis;

    // Source-file combis, decoded once per loaded source.
    IReadOnlyList<Combi> SrcCombis =>
        _srcCombis ??= _srcPcg is null ? Array.Empty<Combi>() : CombiReader.Read(_srcPcg);

    void OpenAddSounds()
    {
        _view = View.AddSounds;
        _addStep = _srcPcg is null ? AddStep.Source : AddStep.Pick;
        _addError = null;
        _addLastResult = null;
    }

    async Task OnAddSourceSelected(InputFileChangeEventArgs e)
    {
        await OnSourceFileSelected(e);
        if (_srcPcg is not null)
            _addStep = AddStep.Pick;
    }

    void ToggleAddTimbres(Combi c)
    {
        if (_addTimbreOpen == (c.Bank, c.Index))
        {
            _addTimbreOpen = null;
            _addTimbreDetail = null;
            return;
        }
        _addTimbreOpen = (c.Bank, c.Index);
        _addTimbreDetail = c;
    }

    void ChooseAddSong(Combi c)
    {
        _addSelection = (c.Bank, c.Index, c.Name);
        (_addDstBank, _addDstIndex) = FirstFreeCombiSlot() ?? (0, 0);
        _crossDeepHd1Bank = DefaultDeepProgramBank(ProgramBankType.Hd1);
        _crossDeepExiBank = DefaultDeepProgramBank(ProgramBankType.Exi);
        _addPlan = null;
        _addError = null;
        _addStep = AddStep.Review;
    }

    // First empty (Init) combi slot the destination carries, searching banks in order.
    (int Bank, int Index)? FirstFreeCombiSlot()
    {
        if (_catalog is null)
            return null;
        foreach (var b in PresentBanks(_catalog.CombiBanks))
        {
            var free = PcgDeepCopy.FreeCombiSlots(_catalog.CombiBanks[b]);
            if (free.Count > 0)
                return (b, free[0]);
        }
        return null;
    }

    DeepCopyPlan? CurrentAddPlan()
    {
        if (_pcg is null || _srcPcg is null || _addSelection is not { } sel)
            return null;
        _crossDeepHd1Bank = SanitizeDeepBank(_crossDeepHd1Bank, ProgramBankType.Hd1);
        _crossDeepExiBank = SanitizeDeepBank(_crossDeepExiBank, ProgramBankType.Exi);
        return _addPlan ??= PcgDeepCopy.Plan(_srcPcg, sel.Bank, sel.Index, _pcg, _crossDeepHd1Bank, _crossDeepExiBank);
    }

    void OnAddDstBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            _addDstBank = idx;
            var free = _catalog is not null ? PcgDeepCopy.FreeCombiSlots(_catalog.CombiBanks[idx]) : Array.Empty<int>();
            _addDstIndex = free.Count > 0 ? free[0] : 0;
        }
    }

    void OnAddDstIndexChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
            _addDstIndex = idx;
    }

    void ApplyAddSong()
    {
        if (_pcg is null || _srcPcg is null || _addSelection is not { } sel)
            return;
        if (CurrentAddPlan() is not { CanApply: true } plan)
            return;
        try
        {
            ApplyEdit(PcgEditor.CopyCombiDeepAcross(_srcPcg, _pcg, _addDstBank, _addDstIndex, plan));
            _addLastResult = $"'{sel.Name}' is now at {PcgBankLabels.Combi(_addDstBank)} #{_addDstIndex:D3}"
                + (plan.Copies.Any() ? $", with {plan.Copies.Count()} sound(s) copied into your file" : "")
                + (plan.Reused.Any() ? $" ({plan.Reused.Count()} shared with sounds already there)" : "")
                + ".";
            _addError = null;
            _addStep = AddStep.Done;
        }
        catch (InvalidOperationException ex)
        {
            _addError = ex.Message; // stale plan / type guard — shown on the review step
        }
    }

    void AddAnotherSong()
    {
        _addSelection = null;
        _addPlan = null;
        _addError = null;
        _addTimbreOpen = null;
        _addTimbreDetail = null;
        _addStep = AddStep.Pick;
    }

    void ResetAddWizard()
    {
        _addStep = AddStep.Source;
        _addSelection = null;
        _addTimbreOpen = null;
        _addTimbreDetail = null;
        _addPlan = null;
        _addFilter = "";
        _addLastResult = null;
        _addError = null;
        _srcCombis = null;
    }

    void OnCrossSrcBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            _crossSrcBank = idx;
            ResetCrossTimbres();
            _crossFilter = string.Empty;
            CancelCrossSelection();
        }
    }

    void OnCrossDstBankChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
        {
            _crossDstBank = idx;
            _crossDstIndex = 0;
        }
    }

    void OnCrossDstIndexChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0)
            _crossDstIndex = idx;
    }

    // Source rows for the current kind/bank/filter: (index, name, extra) with empties hidden.
    List<(int Index, string Name, string Extra)> CrossSourceRows()
    {
        var rows = new List<(int, string, string)>();
        if (_srcCatalog is null) return rows;

        switch (_crossKind)
        {
            case CrossKind.Programs:
            case CrossKind.Combis:
            {
                var banks = _crossKind == CrossKind.Programs ? _srcCatalog.ProgramBanks : _srcCatalog.CombiBanks;
                if (_crossSrcBank < 0 || _crossSrcBank >= banks.Count) break;
                var bank = banks[_crossSrcBank];
                for (int i = 0; i < bank.Count; i++)
                    if (!string.IsNullOrEmpty(bank[i]) && MatchesFilter(bank[i], i, _crossFilter))
                        rows.Add((i, bank[i], string.Empty));
                break;
            }
            default:
            {
                if (_crossSrcBank < 0 || _crossSrcBank >= _srcSetLists.Count) break;
                foreach (var slot in _srcSetLists[_crossSrcBank].Slots)
                    if (!slot.IsEmpty && MatchesFilter(slot.Name, slot.Index, _crossFilter))
                        rows.Add((slot.Index, slot.Name,
                            $"{slot.Reference.Kind} {SlotBankLabel(slot.Reference)} #{slot.Reference.Index:D3}"));
                break;
            }
        }
        return rows;
    }

    string CrossSrcLabel(int bank) => _crossKind switch
    {
        CrossKind.Programs => PcgBankLabels.Program(bank),
        CrossKind.Combis => PcgBankLabels.Combi(bank),
        _ => $"Set List {bank:D3}",
    };

    string CrossDstLabel() => _crossKind switch
    {
        CrossKind.Programs => $"{PcgBankLabels.Program(_crossDstBank)} #{_crossDstIndex:D3}",
        CrossKind.Combis => $"{PcgBankLabels.Combi(_crossDstBank)} #{_crossDstIndex:D3}",
        _ => $"Set List {_crossDstBank:D3} slot {_crossDstIndex:D3}",
    };

    // ----- Differences tab -----

    // One section table (Programs / Combis / Set-list slots); bankLabel maps the Bank field.
    private RenderFragment DiffSection(string title, IReadOnlyList<DiffEntry> entries, Func<int, string> bankLabel) => __builder =>
    {
        if (entries.Count == 0) return;
        <h3 class="h6 mt-3">@title (@entries.Count)</h3>
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th style="width:6.5rem">Change</th>
                    <th style="width:11rem">Where</th>
                    <th>Name</th>
                    <th class="d-none d-md-table-cell">Detail</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    <tr>
                        <td><span class="badge @DiffBadgeClass(e.Kind)">@e.Kind.ToString().ToLowerInvariant()</span></td>
                        <td class="text-nowrap">
                            @bankLabel(e.Bank)
                            @if (e.Kind == DiffKind.Moved)
                            {
                                <span> #@e.IndexBefore.ToString("D3") <span class="text-body-secondary">→</span> #@e.IndexAfter.ToString("D3")</span>
                            }
                            else
                            {
                                <span> #@e.IndexAfter.ToString("D3")</span>
                            }
                        </td>
                        <td>
                            @if (e.Kind is DiffKind.Renamed or DiffKind.Replaced)
                            {
                                <span>@DisplayName(e.NameBefore) <span class="text-body-secondary">→</span> @DisplayName(e.NameAfter)</span>
                            }
                            else if (e.Kind == DiffKind.Removed)
                            {
                                @DisplayName(e.NameBefore)
                            }
                            else
                            {
                                @DisplayName(e.NameAfter)
                            }
                        </td>
                        <td class="small text-body-secondary d-none d-md-table-cell">@e.Detail</td>
                    </tr>
                }
            </tbody>
        </table>
    };

    static string DiffBadgeClass(DiffKind kind) => kind switch
    {
        DiffKind.Added => "text-bg-success",
        DiffKind.Removed => "text-bg-danger",
        DiffKind.Moved => "text-bg-info",
        DiffKind.Renamed => "text-bg-warning",
        DiffKind.Edited => "text-bg-primary",
        _ => "text-bg-dark", // Replaced
    };

    static string DiffSummary(IReadOnlyList<DiffEntry> entries) =>
        entries.Count == 0
            ? "—"
            : string.Join(" · ", entries.GroupBy(e => e.Kind).OrderBy(g => g.Key)
                .Select(g => $"{g.Count()} {g.Key.ToString().ToLowerInvariant()}"));

    static string DisplayName(string name) => string.IsNullOrEmpty(name) ? "(unnamed)" : name;

    async Task ExportDifferencesCsv()
    {
        if (_pcg is null || _srcPcg is null) return;
        var diff = _diffReport ??= PcgDiff.Compare(_srcPcg, _pcg);
        var sb = new StringBuilder();
        sb.Append("section,kind,bank,index_before,index_after,name_before,name_after,detail\n");
        void Rows(string section, IEnumerable<DiffEntry> entries)
        {
            foreach (var e in entries)
                sb.Append(section).Append(',').Append(e.Kind).Append(',').Append(e.Bank).Append(',')
                  .Append(e.IndexBefore).Append(',').Append(e.IndexAfter).Append(",\"")
                  .Append(Csv(e.NameBefore)).Append("\",\"").Append(Csv(e.NameAfter)).Append("\",\"")
                  .Append(Csv(e.Detail ?? string.Empty)).Append("\"\n");
        }
        Rows("program", diff.Programs);
        Rows("combi", diff.Combis);
        Rows("setlist_slot", diff.SetListSlots);
        Rows("setlist_name", diff.RenamedSetLists);
        await Download("differences.csv", "text/csv", sb.ToString());
    }

    async Task DownloadDestinationCopy()
    {
        if (_pcg is null) return;
        var baseName = string.IsNullOrEmpty(_fileName)
            ? "pcg"
            : System.IO.Path.GetFileNameWithoutExtension(_fileName);
        await SaveBytes($"{baseName}-copy.PCG", _pcg.Data);
    }

    async Task DownloadSourceCopy()
    {
        if (_srcPcg is null) return;
        var baseName = string.IsNullOrEmpty(_srcFileName)
            ? "source"
            : System.IO.Path.GetFileNameWithoutExtension(_srcFileName);
        await SaveBytes($"{baseName}-copy.PCG", _srcPcg.Data);
    }

